if ARCH_P2

comment "Parallax Propeller 2 Options"

choice
	prompt "P2 chip selection"
	default ARCH_CHIP_P2X8C4M64P

config ARCH_CHIP_P2X8C4M64P
	bool "P2X8C4M64P"
	select ARCH_HAVE_RESET
	select ARCH_HAVE_UDELAY
	select ARCH_HAVE_DYNAMIC_UDELAY
	select UART0_SERIALDRIVER

config ARCH_CHIP_P2_CUSTOM
	bool "Custom P2 chip"
	select ARCH_CHIP_CUSTOM
	select UART0_SERIALDRIVER
endchoice

config ARCH_CHIP
	string
	default "p2x8c4m64p" if ARCH_CHIP_P2X8C4M64P

config P2_SYSCLK_HZ
	int "P2 system clock frequency"
	default 180000000

config P2_XTAL_HZ
	int "P2 module TCXO frequency"
	default 20000000

config P2_UPWARD_STACK
	bool
	default y

config P2_BOOT_TRACE
	bool "Emit early P2 kernel bring-up trace markers"
	default n
	help
		Emit short, polled serial markers while the kernel establishes the
		CPU0 heap, idle context, interrupt channel, timer, and first context
		restore.  This is intended for bounded hardware bring-up and may be
		disabled once a board configuration is stable.

config P2_STORAGE
	bool "P2 Edge shared flash/microSD pins"
	default n
	select SPI
	help
		Enable the P2 Edge board owner for P58-P61.  Flash and microSD
		share data pins and exchange clock/chip-select roles, so they must
		use the two logical SPI lower halves supplied by this owner.

config P2_STORAGE_LOCK_TIMEOUT_TICKS
	int "Storage-owner lock timeout in ticks"
	depends on P2_STORAGE
	range 1 10000
	default 500
	help
		Maximum time a logical SPI lower half waits for the shared P58-P61
		owner.  A timeout fails closed without changing line state.

config P2_STORAGE_MAX_FREQUENCY
	int "Maximum polled storage SPI frequency"
	depends on P2_STORAGE
	range 100000 5000000
	default 1000000
	help
		Conservative ceiling for the initial C-polled lower halves.  The
		actual clock is returned to the generic SPI client.

config P2_SMARTPIN
	bool "P2 Smart Pin ownership and lower-half support"
	default n
	help
		Enable the central board pin manager and P2 Smart Pin lower-half
		drivers.  Individual standard NuttX device interfaces remain
		board-selectable.

config P2_HUB_OVERLAYS
	bool "Experimental Hub execution overlays"
	default n
	depends on P2_EC32MB_PSRAM_UNIFIED
	depends on !SMP
	help
		Reserve a fixed execution slot at the top of Hub RAM and build the
		resident dispatcher used by compiler-generated function overlays.
		Overlay images are copied from tagged PSRAM by a board-registered
		loader callback.  The dispatcher performs no filesystem or flash I/O.

		This first implementation deliberately permits one owning task and one
		root overlay call at a time.  A second task, interrupt-context entry,
		invalid metadata, loader failure, or image-integrity failure stops
		execution rather than branching into an unverified Hub image.

		Leave this disabled unless the complete overlay image has been packed,
		relocated into tagged PSRAM, and registered before its first stub call.

config P2_HUB_OVERLAY_SLOT_SIZE
	int "Hub overlay execution slot size"
	depends on P2_HUB_OVERLAYS
	range 4096 262144
	default 131072
	help
		Bytes reserved at the high end of the loader-safe Hub window for one
		overlay group.  The value must be a multiple of four.  The linker
		checks alignment and rejects an image whose resident allocation reaches
		this slot.

config P2_HUB_OVERLAY_SHADOW_DEPTH
	int "Overlay return shadow depth"
	depends on P2_HUB_OVERLAYS
	range 4 1024
	default 64
	help
		Maximum number of simultaneously active root or cross-group overlay
		calls.  Calls within the already-loaded group return directly and do
		not consume a record.  Each record holds the exact return resume plus
		caller and callee group identifiers in 12 bytes of fixed Hub memory;
		the default depth therefore costs 768 bytes and the maximum costs
		12288 bytes.  Shadow records are never placed in PSRAM.

config P2_HUB_OVERLAY_GROUP_COUNT
	int "Compiler-generated Hub overlay groups"
	depends on P2_HUB_OVERLAYS
	range 1 256
	default 32
	help
		Number of deterministic overlay groups used for large translation-unit
		sets such as CPython.  More groups reduce the maximum bytes sharing one
		execution slot, at the cost of a larger resident descriptor table.  The
		linker discovers the actual group IDs and rejects missing IDs or a group
		whose linked body exceeds the configured slot.

source "arch/p2/src/p2x8c4m64p/Kconfig"
endif
