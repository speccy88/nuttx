if ARCH_P2

comment "Parallax Propeller 2 Options"

choice
	prompt "P2 chip selection"
	default ARCH_CHIP_P2X8C4M64P

config ARCH_CHIP_P2X8C4M64P
	bool "P2X8C4M64P"
	select ARCH_HAVE_RESET
	select ARCH_HAVE_UDELAY
	select ARCH_HAVE_DYNAMIC_UDELAY
	select UART0_SERIALDRIVER

config ARCH_CHIP_P2_CUSTOM
	bool "Custom P2 chip"
	select ARCH_CHIP_CUSTOM
	select UART0_SERIALDRIVER
endchoice

config ARCH_CHIP
	string
	default "p2x8c4m64p" if ARCH_CHIP_P2X8C4M64P

config P2_EXPERIMENTAL_OVERCLOCK
	bool "Allow an experimental P2 system-clock overclock"
	default n
	help
		Permit system clocks above the board-qualified 180 MHz operating
		point.  This is intended only for explicitly labelled performance
		experiments.  Operation depends on the individual P2, voltage,
		temperature, wiring, and peripherals and is not guaranteed.

config P2_SYSCLK_HZ
	int "P2 system clock frequency"
	range 20000000 180000000 if !P2_EXPERIMENTAL_OVERCLOCK
	range 20000000 360000000 if P2_EXPERIMENTAL_OVERCLOCK
	default 180000000

config P2_XTAL_HZ
	int "P2 module TCXO frequency"
	default 20000000

config P2_UPWARD_STACK
	bool
	default y

config P2_BOOT_TRACE
	bool "Emit early P2 kernel bring-up trace markers"
	default n
	help
		Emit short, polled serial markers while the kernel establishes the
		CPU0 heap, idle context, interrupt channel, timer, and first context
		restore.  This is intended for bounded hardware bring-up and may be
		disabled once a board configuration is stable.

config P2_STORAGE
	bool "P2 Edge shared flash/microSD pins"
	default n
	select SPI
	help
		Enable the P2 Edge board owner for P58-P61.  Flash and microSD
		share data pins and exchange clock/chip-select roles, so they must
		use the two logical SPI lower halves supplied by this owner.

config P2_STORAGE_LOCK_TIMEOUT_TICKS
	int "Storage-owner lock timeout in ticks"
	depends on P2_STORAGE
	range 1 10000
	default 500
	help
		Maximum time a logical SPI lower half waits for the shared P58-P61
		owner.  A timeout fails closed without changing line state.

config P2_STORAGE_MAX_FREQUENCY
	int "Maximum storage SPI frequency"
	depends on P2_STORAGE
	range 100000 5000000 if !P2_STORAGE_SMARTPIN_SPI
	range 100000 45000000 if P2_STORAGE_SMARTPIN_SPI
	default 1000000
	help
		Storage clock ceiling.  The C-polled implementation is limited to
		5 MHz.  The optional SD receive Smart-Pin path supports clocks up to
		sysclk/4 (45 MHz at the board's supported 180 MHz system clock).
		The actual clock is returned to the generic SPI client.

config P2_STORAGE_SMARTPIN_SPI
	bool "Smart-Pin accelerated onboard SD reads"
	depends on P2_STORAGE && MMCSD_SPI
	default n
	help
		Accelerate full SD data-block reads on the shared P58-P61 socket with
		a P2 pulse generator and synchronous receive Smart Pin.  Commands,
		tokens, CRC bytes, and writes retain the conservative polled path.
		The board socket is one-bit SPI, so this improves onboard operation
		but cannot approach the 40 MB/s native four-bit target.

config P2_STORAGE_SD_MODE3
	bool "Use SPI mode 3 for the onboard SD card"
	depends on P2_STORAGE_SMARTPIN_SPI
	default y
	help
		Use the SD card's supported SPI mode 3 so the shared P61 line remains
		high while idle and can be driven directly by the accelerated pulse
		Smart Pin.  The flash remains safely deselected by the storage owner.

config P2_SMARTPIN
	bool "P2 Smart Pin ownership and lower-half support"
	default n
	help
		Enable the central board pin manager and P2 Smart Pin lower-half
		drivers.  Individual standard NuttX device interfaces remain
		board-selectable.

source "arch/p2/src/p2x8c4m64p/Kconfig"
endif
