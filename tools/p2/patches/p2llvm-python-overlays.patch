+; RUN: %python %S/../../../utils/p2-overlay-link.py --fragment-only --slot-address 0x50000 --slot-size 0x10000 --lma-address 0x80000 --max-groups 4 -o %t/packed.ld %t/overlay.a 2>&1 | FileCheck %s --check-prefix=PACK
+; RUN: FileCheck %s --check-prefix=SCRIPT < %t/packed.ld
+; RUN: ld.lld -T %S/Inputs/hub-overlay-base.ld -T %t/packed.ld -e _start --gc-sections -o %t/linked.elf %t/driver.o %t/overlay.a
+; RUN: llvm-readelf -SW -s %t/linked.elf | FileCheck %s --check-prefix=LINK
+; RUN: llvm-readelf -x .p2.xdata %t/linked.elf | FileCheck %s --check-prefix=DESCRIPTORS
+;
+; This is the complete ABI path.  A compiler-generated member is discovered
+; by the helper and extracted lazily by LLD through its resident public
+; veneer.  The automatic TU is group 1 and explicit group 4 forces two
+; anchor-only gaps, exercising data commands inside OVERLAY members.  GC keeps
+; descriptors and their body relocations live without --whole-archive.
+;
+; RELOCS: R_P2_32 __p2_overlay_groupref_{{[0-9a-f]+}}_{{[0-9a-f]+}}
+; PACK: p2-overlay-link.py: link-assigned packing: functions=2, automatic-groups=1, dense-groups=4
+; PACK-NEXT: p2-overlay-link.py: overlay sizes:
+; SCRIPT-COUNT-2: __p2_overlay_groupref_{{[0-9a-f]+}}_{{[0-9a-f]+}} = 1;
+; SCRIPT: __p2_overlay_group_count = 5;
+; SCRIPT-COUNT-4: LONG(0)
+; SCRIPT: .p2.overlay.group.00000002
+; SCRIPT: .p2.overlay.group.00000003
+; SCRIPT: .p2.overlay.group.00000004
+;
+; LINK-DAG: .p2.xdata PROGBITS 10000000 {{[0-9a-f]+}} 000018
+; LINK-DAG: .p2.overlay.group.00000001 PROGBITS 00050000 {{[0-9a-f]+}} {{[0-9a-f]+}}
+; LINK-DAG: .p2.overlay.group.00000002 PROGBITS 00050000 {{[0-9a-f]+}} 000004
+; LINK-DAG: .p2.overlay.group.00000003 PROGBITS 00050000 {{[0-9a-f]+}} 000004
+; LINK-DAG: .p2.overlay.group.00000004 PROGBITS 00050000 {{[0-9a-f]+}} {{[0-9a-f]+}}
+; LINK-DAG: {{[0-9a-f]+}} {{[0-9]+}} FUNC GLOBAL DEFAULT {{[0-9]+}} auto_entry
+; LINK-COUNT-2: 00000001 0 NOTYPE GLOBAL DEFAULT ABS __p2_overlay_groupref_{{[0-9a-f]+}}_{{[0-9a-f]+}}
+; LINK-NOT: UND __p2_overlay_groupref_
+;
+; DESCRIPTORS: 0x10000000 01000000 04000000 01000000 {{[0-9a-f]+}}
+; DESCRIPTORS-NEXT: 0x10000010 04000000 04000000
+
+;--- driver.ll
+source_filename = "/src/driver.c"
+target triple = "p2-unknown-nuttx"
+
+declare i32 @auto_entry(i32)
+
+define i32 @_start() {
+entry:
+  %result = call i32 @auto_entry(i32 41)
+  ret i32 %result
+}
+
+define void @__p2_overlay_enter() {
+entry:
+  ret void
+}
+
+;--- overlay.ll
+source_filename = "/src/runtime.c"
+target triple = "p2-unknown-nuttx"
+
+define i32 @auto_entry(i32 %value) #0 {
+entry:
+  %result = call i32 @auto_helper(i32 %value)
+  ret i32 %result
+}
+
+define internal i32 @auto_helper(i32 %value) #0 {
+entry:
+  %result = add i32 %value, 1
+  ret i32 %result
+}
+
+define i32 @fixed_entry(i32 %value) #1 {
+entry:
+  %result = xor i32 %value, 85
+  ret i32 %result
+}
+
+declare void @__p2_overlay_enter()
+
+attributes #0 = { noinline }
+attributes #1 = { noinline "p2-hub-overlay-group"="4" }
