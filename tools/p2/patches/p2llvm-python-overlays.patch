+bool P2UnifiedMemory::isSupportedUnifiedAtomicLibcall(StringRef Name) const {
+  // This is deliberately an exact fixed-width whitelist.  The corresponding
+  // NuttX arch_atomic.c functions serialize with spin_lock_irqsave_notrace(),
+  // and compiling that translation unit with -p2-unified-memory routes their
+  // ordinary target/expected accesses through __p2_xmem_load/store helpers.
+  // Generic-size atomics, NAND, and __sync_* do not have that verified ABI.
+  static constexpr StringLiteral Operations[] = {
+      "load",      "store",     "exchange", "compare_exchange",
+      "fetch_add", "fetch_sub", "fetch_and", "fetch_or",
+      "fetch_xor"};
+  static constexpr StringLiteral Widths[] = {"1", "2", "4", "8"};
+
+  if (!Name.consume_front("__atomic_"))
+    return false;
+  for (StringRef Operation : Operations) {
+    StringRef Suffix = Name;
+    if (!Suffix.consume_front(Operation) || !Suffix.consume_front("_"))
+      continue;
+    for (StringRef Width : Widths)
+      if (Suffix == Width)
+        return true;
+  }
+
+  return false;
+}
