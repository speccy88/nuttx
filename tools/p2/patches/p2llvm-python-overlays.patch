+; RUN: llc -march=p2 -O2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/src -p2-hub-overlay-source-namespace=llvm-test -p2-hub-overlay-source-variant=v1 -p2-hub-overlay-slot-address=0x50000 -filetype=obj %s -o %t.o
+; RUN: llvm-readobj --sections %t.o | FileCheck %s --check-prefix=SECTIONS
+; RUN: llvm-readobj --symbols %t.o | FileCheck %s --check-prefix=SYMBOLS
+; RUN: llc -march=p2 -O2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/src -p2-hub-overlay-source-namespace=llvm-test -p2-hub-overlay-source-variant=v1 -p2-hub-overlay-slot-address=0x50000 -print-after=p2-hub-overlay -filetype=null %s 2>&1 | FileCheck %s --check-prefix=IR
+;
+; Link-assigned automatic bodies use stable per-function sections.  The
+; optimized direct-call DFS keeps the private helper immediately after its
+; public caller; an explicit group remains on the legacy fixed-ID ABI.
+;
+; SECTIONS-DAG: Name: .p2.overlay.auto.e480aa5115a07c330980b7f7f4c893e9bb2044a2924780e71c4f893a2d75cef5.00000000.ec903cd897e2dc9088a3f158ab9f09135e35490c611ac248647ff6e14b00d4b4
+; SECTIONS-DAG: Name: .p2.overlay.auto.e480aa5115a07c330980b7f7f4c893e9bb2044a2924780e71c4f893a2d75cef5.00000001.863d67db2f4d65cfd2e324bffb1fbce3c60524657f8ca50a5095a48f43fefc48
+; SECTIONS-DAG: Name: .p2.overlay.auto.e480aa5115a07c330980b7f7f4c893e9bb2044a2924780e71c4f893a2d75cef5.00000002.f2877f254345e103755c2b381c5e11c1cafcdc373f2e580b098e316c5b504711
+; SECTIONS-DAG: Name: .p2.overlay.body.00000007
+; SYMBOLS-COUNT-3: Name: __p2_overlay_groupref_{{[0-9a-f]+}}_{{[0-9a-f]+}}
+; SYMBOLS: Section: Undefined
+; IR-COUNT-3: ptrtoint (i8* @__p2_overlay_groupref_{{[0-9a-f]+}}_{{[0-9a-f]+}} to i32)
+; IR: @__p2_ovlentry.{{[0-9]+}}.fixed = internal constant { i32, i32 } { i32 7,
+
+source_filename = "startup.c"
+target triple = "p2-unknown-nuttx"
+
+define i32 @entry(i32 %value) {
+entry:
+  %result = call i32 @helper(i32 %value)
+  ret i32 %result
+}
+
+define internal i32 @helper(i32 %value) {
+entry:
+  %result = add i32 %value, 1
+  ret i32 %result
+}
+
+define i32 @other(i32 %value) {
+entry:
+  %result = xor i32 %value, 85
+  ret i32 %result
+}
+
+define i32 @fixed(i32 %value) #0 {
+entry:
+  %result = sub i32 %value, 2
+  ret i32 %result
+}
+
+define void @__p2_overlay_enter() {
+entry:
+  ret void
+}
+
+attributes #0 = { noinline "p2-hub-overlay-group"="7" }
