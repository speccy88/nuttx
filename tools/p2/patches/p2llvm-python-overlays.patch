@@ -0,0 +1,214 @@
+#!/usr/bin/env python3
+
+# Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+# See https://llvm.org/LICENSE.txt for license information.
+# SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+
+import importlib.util
+import pathlib
+import sys
+import unittest
+from unittest import mock
+
+
+SCRIPT = pathlib.Path(__file__).parents[1] / "p2-overlay-link.py"
+SPEC = importlib.util.spec_from_file_location("p2_overlay_link", SCRIPT)
+assert SPEC is not None and SPEC.loader is not None
+overlay = importlib.util.module_from_spec(SPEC)
+sys.modules[SPEC.name] = overlay
+SPEC.loader.exec_module(overlay)
+
+
+def auto(module, order, function, size, alignment=4):
+    tu_token = "{:064x}".format(module)
+    order_token = "{:08x}".format(order)
+    function_token = "{:064x}".format(function)
+    name = ".p2.overlay.auto.{}.{}.{}".format(
+        tu_token, order_token, function_token
+    )
+    return overlay.AutoSection(
+        name=name,
+        tu_token=tu_token,
+        order=order,
+        function_token=function_token,
+        size=size,
+        alignment=alignment,
+        label="fixture.o",
+    )
+
+
+class P2OverlayLinkIdentityTests(unittest.TestCase):
+    def scan(self, *names):
+        sections = tuple(
+            overlay.ELFSection(name.encode("ascii"), 4, 4) for name in names
+        )
+        with mock.patch.object(
+            overlay,
+            "_object_blobs",
+            return_value=(("fixture.o", b""),),
+        ), mock.patch.object(
+            overlay, "_elf_sections", return_value=sections
+        ):
+            return overlay._scan_overlay_sections((pathlib.Path("fixture.o"),))
+
+    def test_auto_grammar_requires_full_lowercase_sha256_tokens(self):
+        valid = auto(1, 0xAB, 2, 4).name
+        fixed, automatic = self.scan(valid)
+        self.assertEqual(fixed, {})
+        self.assertEqual(len(automatic), 1)
+        self.assertEqual(len(automatic[0].tu_token), 64)
+        self.assertEqual(len(automatic[0].function_token), 64)
+
+        malformed = (
+            ".p2.overlay.auto.{}.{:08x}.{}".format("1" * 16, 0, "2" * 16),
+            ".p2.overlay.auto.{}.00000000.{}".format("A" * 64, "2" * 64),
+            ".p2.overlay.auto.{}.0000000A.{}".format("1" * 64, "2" * 64),
+            ".p2.overlay.auto.{}.00000000.{}".format("1" * 64, "B" * 64),
+        )
+        for name in malformed:
+            with self.subTest(name=name), self.assertRaisesRegex(
+                overlay.InputError, "malformed link-assigned section"
+            ):
+                self.scan(name)
+
+    def test_duplicate_identity_dimensions_fail_deterministically(self):
+        first = auto(1, 0, 2, 4)
+        with self.assertRaisesRegex(
+            overlay.InputError, "duplicate link-assigned section"
+        ):
+            self.scan(first.name, first.name)
+
+        same_order = auto(1, 0, 3, 4)
+        with self.assertRaisesRegex(
+            overlay.InputError, "duplicate link-assigned call order"
+        ):
+            self.scan(first.name, same_order.name)
+
+        same_groupref = auto(1, 1, 2, 4)
+        with self.assertRaisesRegex(
+            overlay.InputError, "duplicate link-assigned group reference"
+        ):
+            self.scan(first.name, same_groupref.name)
+
+
+class P2OverlayLinkPackingTests(unittest.TestCase):
+    SLOT_ADDRESS = 0x50000
+    SLOT_SIZE = 0x10000
+
+    def test_small_translation_unit_is_one_atomic_call_order_unit(self):
+        sections = (
+            auto(2, 0, 30, 1000),
+            auto(2, 1, 20, 2000),
+            auto(2, 2, 10, 3000),
+        )
+        units = overlay._build_auto_units(
+            sections, self.SLOT_ADDRESS, self.SLOT_SIZE
+        )
+        self.assertEqual(len(units), 1)
+        self.assertEqual(units[0].sections, sections)
+        self.assertFalse(units[0].hard_cap)
+
+    def test_oversized_function_bin_absorbs_following_hot_helpers(self):
+        sections = (auto(7, 0, 100, 9000),) + tuple(
+            auto(7, index + 1, 101 + index, 7000) for index in range(4)
+        )
+        units = overlay._build_auto_units(
+            sections, self.SLOT_ADDRESS, self.SLOT_SIZE
+        )
+        self.assertEqual(len(units), 5)
+        self.assertTrue(units[0].hard_cap)
+        packed = overlay._pack_auto_units(
+            units,
+            overlay.AUTO_INITIAL_TARGET,
+            self.SLOT_ADDRESS,
+            self.SLOT_SIZE,
+        )
+        self.assertEqual(packed, (sections,))
+        self.assertEqual(
+            overlay._exact_auto_group_size(
+                packed[0], self.SLOT_ADDRESS
+            ).required_bytes,
+            37004,
+        )
+
+    def test_target_is_raised_to_satisfy_maximum_group_count(self):
+        sections = tuple(
+            auto(module, 0, module + 100, 6000) for module in range(1, 5)
+        )
+        units = overlay._build_auto_units(
+            sections, self.SLOT_ADDRESS, self.SLOT_SIZE
+        )
+        initial = overlay._pack_auto_units(
+            units,
+            overlay.AUTO_INITIAL_TARGET,
+            self.SLOT_ADDRESS,
+            self.SLOT_SIZE,
+        )
+        self.assertEqual(len(initial), 4)
+        target, packed = overlay._choose_auto_packing(
+            units, 2, self.SLOT_ADDRESS, self.SLOT_SIZE
+        )
+        self.assertEqual(target, 12004)
+        self.assertEqual(len(packed), 2)
+        self.assertEqual([len(group) for group in packed], [2, 2])
+
+    def test_mixed_fixed_ids_are_reserved_and_output_is_dense(self):
+        fixed = {
+            4: [overlay.ELFSection(b".p2.overlay.body.00000004", 8, 4)],
+            5: [overlay.ELFSection(b".p2.overlay.body.00000005", 8, 4)],
+        }
+        automatic = (
+            auto(1, 0, 11, 6000),
+            auto(2, 0, 22, 6000),
+        )
+        with mock.patch.object(
+            overlay, "_scan_overlay_sections", return_value=(fixed, automatic)
+        ):
+            plan = overlay.build_overlay_plan(
+                (), self.SLOT_ADDRESS, self.SLOT_SIZE, 5
+            )
+
+        self.assertEqual(plan.groups, (1, 2, 3, 4, 5))
+        self.assertEqual(tuple(plan.auto_groups), (1, 2))
+        self.assertEqual(plan.sizes[3].required_bytes, 4)
+        self.assertEqual(plan.sizes[4].required_bytes, 12)
+        self.assertEqual(plan.sizes[5].required_bytes, 12)
+        self.assertEqual(plan.grouprefs[automatic[0].groupref], 1)
+        self.assertEqual(plan.grouprefs[automatic[1].groupref], 2)
+
+        script = overlay.generate_script(
+            plan.groups,
+            self.SLOT_ADDRESS,
+            self.SLOT_SIZE,
+            0x80000,
+            fragment_only=True,
+            auto_groups=plan.auto_groups,
+            grouprefs=plan.grouprefs,
+            anchors=plan.anchors,
+        )
+        self.assertEqual(script.count("      LONG(0)"), 5)
+        self.assertIn(automatic[0].groupref + " = 1;", script)
+        self.assertIn(automatic[1].groupref + " = 2;", script)
+        self.assertLess(script.index(automatic[0].name), script.index(automatic[1].name))
+        self.assertIn(".p2.overlay.group.00000003", script)
+
+    def test_legacy_script_has_no_anchor_or_grouprefs(self):
+        script = overlay.generate_script(
+            (1,), self.SLOT_ADDRESS, self.SLOT_SIZE, 0x80000
+        )
+        self.assertNotIn("LONG(0)", script)
+        self.assertNotIn(overlay.GROUPREF_PREFIX, script)
+        self.assertIn("*(.p2.overlay.body.00000001)", script)
+
+    def test_single_function_larger_than_slot_minus_anchor_is_rejected(self):
+        section = auto(9, 0, 99, self.SLOT_SIZE)
+        with self.assertRaisesRegex(
+            overlay.InputError, "including its group anchor, exceeding"
+        ):
+            overlay._build_auto_units(
+                (section,), self.SLOT_ADDRESS, self.SLOT_SIZE
+            )
+
+
+if __name__ == "__main__":
+    unittest.main()
