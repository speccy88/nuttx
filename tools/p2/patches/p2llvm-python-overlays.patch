diff --git a/clang/test/CodeGen/p2-hub-overlay-codegen.c b/clang/test/CodeGen/p2-hub-overlay-codegen.c
new file mode 100644
index 0000000000000000000000000000000000000000..be83519a0917066cb0930cbb05aa5d87b85ae9c0
--- /dev/null
+++ b/clang/test/CodeGen/p2-hub-overlay-codegen.c
@@ -0,0 +1,47 @@
+// RUN: %clang_cc1 -triple p2-unknown-nuttx -O0 -emit-obj -mllvm -p2-hub-overlays -mllvm -p2-hub-overlays-all -mllvm -p2-hub-overlay-auto-groups=1 -mllvm -p2-hub-overlay-slot-address=0x50000 -o %t.O0.o %s
+// RUN: llvm-readobj --sections %t.O0.o | FileCheck %s --check-prefix=SECTION
+// RUN: llvm-readobj --relocations %t.O0.o | FileCheck %s --check-prefix=RELOC
+// RUN: %clang_cc1 -triple p2-unknown-nuttx -Os -emit-obj -mllvm -p2-hub-overlays -mllvm -p2-hub-overlays-all -mllvm -p2-hub-overlay-auto-groups=1 -mllvm -p2-hub-overlay-slot-address=0x50000 -o %t.Os.o %s
+// RUN: llvm-readobj --sections %t.Os.o | FileCheck %s --check-prefix=SECTION
+// RUN: llvm-readobj --relocations %t.Os.o | FileCheck %s --check-prefix=RELOC
+// RUN: %clang_cc1 -triple p2-unknown-nuttx -O2 -emit-obj -mllvm -p2-hub-overlays -mllvm -p2-hub-overlays-all -mllvm -p2-hub-overlay-auto-groups=1 -mllvm -p2-hub-overlay-slot-address=0x50000 -o %t.O2.o %s
+// RUN: llvm-readobj --sections %t.O2.o | FileCheck %s --check-prefix=SECTION
+// RUN: llvm-readobj --relocations %t.O2.o | FileCheck %s --check-prefix=RELOC
+
+// Unannotated ordinary and variadic CPython-style C functions are eligible in
+// overlay-all mode at every supported optimization level. Their public
+// addresses remain the three contiguous resident veneers.
+
+// SECTION: Name: .p2.overlay.body.00000001
+// SECTION: Name: .p2.overlay.stubs
+// SECTION: Size: 12
+// SECTION: AddressAlignment: 4
+// SECTION: Name: .p2.xdata.ro.overlay.entries
+// SECTION: Size: 24
+// RELOC: Section {{.*}} .rela.p2.overlay.stubs
+// RELOC-COUNT-3: R_P2_20 __p2_overlay_enter
+
+// Header annotations on declarations are accepted in translation units that
+// do not own the corresponding definition.
+__attribute__((p2_hub_overlay(1))) int defined_elsewhere(int);
+
+int recursive(int value) {
+  return value == 0 ? 1 : value * recursive(value - 1);
+}
+
+int variadic_sum(int fixed, ...) {
+  __builtin_va_list args;
+  __builtin_va_start(args, fixed);
+  int value = __builtin_va_arg(args, int);
+  __builtin_va_end(args);
+  return fixed + value;
+}
+
+int python_entry(int value) {
+  return variadic_sum(recursive(value), 17);
+}
+
+int (*python_entry_pointer)(int) = python_entry;
+
+__attribute__((p2_hub_resident)) void __p2_overlay_enter(void) {
+}
