+// RUN: %clang_cc1 -triple p2-unknown-nuttx -emit-llvm -o - %s | FileCheck %s
+// RUN: not %clang_cc1 -triple p2-unknown-nuttx -DINVALID_GROUP -fsyntax-only %s 2>&1 | FileCheck %s --check-prefix=ERR
+// RUN: %clang_cc1 -triple p2-unknown-nuttx -O2 -emit-obj -mllvm -p2-hub-overlays -mllvm -p2-hub-overlay-slot-address=0x50000 -o %t.o %s
+// RUN: llvm-readobj --sections %t.o | FileCheck %s --check-prefix=OBJ
+
+#ifdef INVALID_GROUP
+__attribute__((p2_hub_overlay(0))) int invalid_group(void);
+// ERR: error: 'p2_hub_overlay' attribute requires a positive integral compile time constant expression
+#endif
+
+__attribute__((p2_hub_overlay(7))) int overlaid(int value) {
+  return value + 1;
+}
+
+__attribute__((p2_hub_overlay(7))) int variadic(int fixed, ...) {
+  __builtin_va_list args;
+  __builtin_va_start(args, fixed);
+  int value = __builtin_va_arg(args, int);
+  __builtin_va_end(args);
+  return fixed + value;
+}
+
+__attribute__((p2_hub_resident)) int resident(int value) {
+  return value - 1;
+}
+
+// CHECK: define{{.*}} @overlaid{{.*}} #[[OVERLAY:[0-9]+]]
+// CHECK: define{{.*}} @variadic{{.*}} #[[OVERLAY]]
+// CHECK: define{{.*}} @resident{{.*}} #[[RESIDENT:[0-9]+]]
+// CHECK: attributes #[[OVERLAY]] = {{.*}}"p2-hub-overlay-group"="7"
+// CHECK: attributes #[[RESIDENT]] = {{.*}}"p2-hub-resident"
+// OBJ: Name: .p2.overlay.body.00000007
