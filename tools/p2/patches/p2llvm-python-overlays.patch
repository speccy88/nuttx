index 0000000000000000000000000000000000000000..c480c79d994eb2f26820fab5f9ed02a6852bf0f8
--- /dev/null
+++ b/llvm/test/CodeGen/P2/hub-overlay-size-preflight.ll
@@ -0,0 +1,116 @@
+; RUN: rm -rf %t && split-file %s %t
+; RUN: llvm-mc -triple=p2-unknown-nuttx -filetype=obj %t/boundary-a.s -o %t/boundary-a.o
+; RUN: llvm-mc -triple=p2-unknown-nuttx -filetype=obj %t/boundary-b.s -o %t/boundary-b.o
+; RUN: %python %S/../../../utils/p2-overlay-link.py --slot-address 0x50000 --slot-size 0x10 --lma-address 0x80000 -o %t/boundary.ld %t/boundary-a.o %t/boundary-b.o 2>&1 | FileCheck %s --check-prefix=BOUNDARY
+; RUN: FileCheck %s --check-prefix=SCRIPT < %t/boundary.ld
+; RUN: ld.lld -T %t/boundary.ld -o %t/boundary.elf %t/boundary-a.o %t/boundary-b.o
+; RUN: llvm-readelf -S %t/boundary.elf | FileCheck %s --check-prefix=BOUNDARY-ELF
+;
+; RUN: llvm-mc -triple=p2-unknown-nuttx -filetype=obj %t/alignment-a.s -o %t/alignment-a.o
+; RUN: llvm-mc -triple=p2-unknown-nuttx -filetype=obj %t/alignment-b.s -o %t/alignment-b.o
+; RUN: llvm-mc -triple=p2-unknown-nuttx -filetype=obj %t/alignment-c.s -o %t/alignment-c.o
+; RUN: not %python %S/../../../utils/p2-overlay-link.py --slot-address 0x50000 --slot-size 0x10 --lma-address 0x80000 -o %t/alignment.ld %t/alignment-a.o %t/alignment-b.o %t/alignment-c.o 2>&1 | FileCheck %s --check-prefix=ALIGNMENT
+;
+; RUN: llvm-mc -triple=p2-unknown-nuttx -filetype=obj %t/archive-a.s -o %t/archive-a.o
+; RUN: llvm-mc -triple=p2-unknown-nuttx -filetype=obj %t/archive-b.s -o %t/archive-b.o
+; RUN: llvm-ar cr %t/collision.a %t/archive-a.o %t/archive-b.o
+; RUN: not %python %S/../../../utils/p2-overlay-link.py --slot-address 0x50000 --slot-size 0x10 --lma-address 0x80000 -o %t/archive.ld %t/collision.a 2>&1 | FileCheck %s --check-prefix=ARCHIVE
+;
+; RUN: %python %t/make-elf64be.py %t/elf64be.o
+; RUN: %python %S/../../../utils/p2-overlay-link.py --slot-address 0x50000 --slot-size 0x10 --lma-address 0x80000 -o %t/elf64be.ld %t/elf64be.o 2>&1 | FileCheck %s --check-prefix=ELF64BE
+;
+; BOUNDARY: p2-overlay-link.py: overlay sizes: 1=0x10(input=0x9,align=0x7); slot=0x10
+; BOUNDARY-NOT: error:
+; SCRIPT: .p2.overlay.group.00000001
+; BOUNDARY-ELF: .p2.overlay.group.00000001 PROGBITS 00050000 {{[0-9a-f]+}} 000010
+;
+; ALIGNMENT: p2-overlay-link.py: overlay sizes: 1=0x18(input=0xa,align=0xe); slot=0x10
+; ALIGNMENT-NEXT: p2-overlay-link.py: error: overlay size preflight failed: group 1 requires 0x18 bytes (0xa input + 0xe alignment across 3 sections), exceeding the 0x10-byte Hub slot by 0x8
+;
+; ARCHIVE: p2-overlay-link.py: overlay sizes: 1=0x11(input=0x11,align=0x0); slot=0x10
+; ARCHIVE-NEXT: p2-overlay-link.py: error: overlay size preflight failed: group 1 requires 0x11 bytes (0x11 input + 0x0 alignment across 2 sections), exceeding the 0x10-byte Hub slot by 0x1
+;
+; ELF64BE: p2-overlay-link.py: overlay sizes: 1=0x10(input=0x9,align=0x7); slot=0x10
+
+;--- boundary-a.s
+.section .p2.overlay.body.00000001,"ax",@progbits
+.space 1
+
+;--- boundary-b.s
+.section .p2.overlay.body.00000001,"ax",@progbits
+.balign 8
+.space 8
+
+;--- alignment-a.s
+.section .p2.overlay.body.00000001,"ax",@progbits
+.space 2
+
+;--- alignment-b.s
+.section .p2.overlay.body.00000001,"ax",@progbits
+.balign 8
+.space 7
+
+;--- alignment-c.s
+.section .p2.overlay.body.00000001,"ax",@progbits
+.balign 8
+.space 1
+
+;--- archive-a.s
+.section .p2.overlay.body.00000001,"ax",@progbits
+.space 9
+
+;--- archive-b.s
+.section .p2.overlay.body.00000001,"ax",@progbits
+.space 8
+
+;--- make-elf64be.py
+import struct
+import sys
+from pathlib import Path
+
+name = b".p2.overlay.body.00000001"
+names = b"\0" + name + b"\0.shstrtab\0"
+body = bytes(9)
+header_size = struct.calcsize(">16sHHIQQQIHHHHHH")
+section_size = struct.calcsize(">IIQQQQIIQQ")
+names_offset = header_size + len(body)
+sections_offset = (names_offset + len(names) + 7) & -8
+ident = b"\x7fELF" + bytes((2, 2, 1)) + bytes(9)
+header = struct.pack(
+    ">16sHHIQQQIHHHHHH",
+    ident,
+    1,
+    0,
+    1,
+    0,
+    0,
+    sections_offset,
+    0,
+    header_size,
+    0,
+    0,
+    section_size,
+    3,
+    2,
+)
+null_section = bytes(section_size)
+overlay_section = struct.pack(
+    ">IIQQQQIIQQ", 1, 1, 6, 0, header_size, len(body), 0, 0, 8, 0
+)
+names_section = struct.pack(
+    ">IIQQQQIIQQ",
+    names.index(b".shstrtab"),
+    3,
+    0,
+    0,
+    names_offset,
+    len(names),
+    0,
+    0,
+    1,
+    0,
+)
+padding = bytes(sections_offset - names_offset - len(names))
+Path(sys.argv[1]).write_bytes(
+    header + body + names + padding + null_section + overlay_section + names_section
+)
diff --git a/llvm/test/CodeGen/P2/hub-overlay.ll b/llvm/test/CodeGen/P2/hub-overlay.ll
new file mode 100644
index 0000000000000000000000000000000000000000..b44f266272955d39db6cdf9e4e2c0095aede3f39
--- /dev/null
+++ b/llvm/test/CodeGen/P2/hub-overlay.ll
@@ -0,0 +1,127 @@
+; RUN: llc -march=p2 -O0 -p2-unified-memory -p2-hub-overlays -p2-hub-overlay-slot-address=0x50000 -filetype=obj %s -o %t.o
+; RUN: llvm-readobj --sections %t.o | FileCheck %s --check-prefix=OBJ
+; RUN: llvm-readobj --symbols %t.o | FileCheck %s --check-prefix=SYM
+; RUN: llvm-readobj --symbols %t.o | FileCheck %s --check-prefix=STUB
+; RUN: llvm-objdump -dr %t.o | FileCheck %s --check-prefix=DIS
+; RUN: llc -march=p2 -O2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlay-slot-address=0x50000 -filetype=obj %s -o %t.o2
+; RUN: llvm-readobj --sections %t.o2 | FileCheck %s --check-prefix=OBJ
+; RUN: llc -march=p2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlay-slot-address=0x50000 -print-after=p2-hub-overlay -filetype=null %s 2>&1 | FileCheck %s --check-prefix=IR
+;
+; The five public/static symbols remain addressable veneers.  Each is exactly
+; one P2 instruction in a single contiguous section: 5 * 4 == 20 bytes.  The
+; five parallel immutable runtime records are 5 * 8 == 40 external bytes.
+;
+; OBJ: Name: .p2.overlay.body.00000001
+; OBJ: Name: .p2.overlay.body.00000002
+; OBJ: Name: .p2.overlay.stubs
+; OBJ: Size: 20
+; OBJ: AddressAlignment: 4
+; OBJ: Name: .p2.xdata.ro.overlay.entries
+; OBJ: Size: 40
+; OBJ: AddressAlignment: 8
+; SYM-DAG: Name: selected ({{[0-9]+}})
+; SYM-DAG: Name: selected_alias ({{[0-9]+}})
+; SYM-DAG: Name: recurse ({{[0-9]+}})
+; SYM-DAG: Name: variadic ({{[0-9]+}})
+; STUB-COUNT-5: Section: .p2.overlay.stubs
+;
+; Every veneer relocation targets the one resident dispatcher.  Cross-group
+; calls and calls from resident code still target veneers.  Calls between
+; implementations in the same compiler-known group, including recursion,
+; target private bodies directly and avoid redundant dispatcher entry.
+;
+; DIS-DAG: R_P2_20 other
+; DIS-DAG: R_P2_20 .p2.overlay.stubs+0xc
+; DIS-DAG: R_P2_20 .p2.overlay.body.00000001+0x18
+; DIS-DAG: R_P2_20 .p2.overlay.body.00000002+0x
+; DIS-COUNT-5: R_P2_20 __p2_overlay_enter
+;
+; Dispatcher memory/synchronization effects invalidate purity attributes
+; inferred for the old implementation, and all tail markers are cleared so a
+; CALLA return address always reaches the veneer.
+;
+; IR: @__p2_ovlentry.0.selected = internal constant
+; IR-SAME: section ".p2.xdata.ro.overlay.entries"
+; IR-LABEL: define internal i32 @__p2_ovlbody.0.selected
+; IR: call i32 @other
+; IR-LABEL: define internal i32 @__p2_ovlbody.1.other
+; IR: call i32 @__p2_ovlbody.3.local_function
+; IR-LABEL: define internal i32 @__p2_ovlbody.2.recurse
+; IR: call i32 @__p2_ovlbody.2.recurse
+; IR-LABEL: define internal i32 @__p2_ovlbody.3.local_function
+; IR: define i32 @selected
+; IR: attributes #[[BODY:[0-9]+]] = { noinline "p2-hub-resident" }
+; IR: attributes #[[VENEERATTR:[0-9]+]] = { naked noinline nounwind "p2-hub-resident" }
+; IR-NOT: readnone
+; IR-NOT: tail call
+
+target triple = "p2-unknown-nuttx"
+
+@selected_pointer = global i32 (i32)* @selected, align 4
+@selected_alias = alias i32 (i32), i32 (i32)* @selected
+
+declare void @llvm.va_start(i8*)
+declare void @llvm.va_end(i8*)
+
+define i32 @selected(i32 %value) #3 {
+entry:
+  %cross = call i32 @other(i32 %value)
+  ret i32 %cross
+}
+
+define i32 @other(i32 %value) #1 {
+entry:
+  %local = call i32 @local_function(i32 %value)
+  %result = add i32 %local, 7
+  ret i32 %result
+}
+
+define i32 @recurse(i32 %value) #0 {
+entry:
+  %done = icmp eq i32 %value, 0
+  br i1 %done, label %base, label %step
+
+base:
+  ret i32 1
+
+step:
+  %next = sub i32 %value, 1
+  %nested = call i32 @recurse(i32 %next)
+  %result = add i32 %value, %nested
+  ret i32 %result
+}
+
+define internal i32 @local_function(i32 %value) #1 {
+entry:
+  %result = xor i32 %value, 85
+  ret i32 %result
+}
+
+define i32 @variadic(i32 %fixed, ...) #1 {
+entry:
+  %cursor = alloca i8*, align 4
+  %raw = bitcast i8** %cursor to i8*
+  call void @llvm.va_start(i8* %raw)
+  %argument = va_arg i8** %cursor, i32
+  call void @llvm.va_end(i8* %raw)
+  %result = add i32 %fixed, %argument
+  ret i32 %result
+}
+
+define i32 @resident_caller(i32 %value) #2 {
+entry:
+  %one = call i32 @selected(i32 %value)
+  %two = call i32 @local_function(i32 %one)
+  %three = call i32 (i32, ...) @variadic(i32 %two, i32 9)
+  ret i32 %three
+}
+
+define void @__p2_overlay_enter() #2 {
+entry:
+  ret void
+}
+
+attributes #0 = { noinline "p2-hub-overlay-group"="1" }
+attributes #1 = { noinline "p2-hub-overlay-group"="2" }
+attributes #2 = { noinline "p2-hub-resident" }
+attributes #3 = { nofree noinline norecurse nosync readnone willreturn "p2-hub-overlay-group"="1" }
diff --git a/llvm/test/CodeGen/P2/indirectbr.ll b/llvm/test/CodeGen/P2/indirectbr.ll
new file mode 100644
index 0000000000000000000000000000000000000000..a87c41b7365db05e62277dd6d2acf851604b9305
--- /dev/null
+++ b/llvm/test/CodeGen/P2/indirectbr.ll
@@ -0,0 +1,46 @@
+; RUN: llc -march=p2 -O0 < %s | FileCheck %s --check-prefixes=CHECK,O0
+; RUN: llc -march=p2 -O1 < %s | FileCheck %s --check-prefixes=CHECK,OPT
+; RUN: llc -march=p2 -O2 < %s | FileCheck %s --check-prefixes=CHECK,OPT
+; RUN: llc -march=p2 -O3 < %s | FileCheck %s --check-prefixes=CHECK,OPT
+;
+; A register-indirect jump is an unconditional CFG terminator.  Losing those
+; semantics made the optimized machine-block placement pipeline treat case0 as
+; entry fallthrough and delete both the selector calculation and JMPr.
+
+target triple = "p2-unknown-nuttx"
+
+@targets = private constant [2 x i8*] [
+  i8* blockaddress(@dispatch, %case0),
+  i8* blockaddress(@dispatch, %case1)
+], align 4
+
+define i32 @dispatch(i32 %selector) {
+; CHECK-LABEL: dispatch:
+; CHECK: and [[INDEX:r[0-9]+]], #1
+; CHECK: shl [[INDEX]], #2
+; CHECK: mov [[BASE:r[0-9]+]], targets
+; CHECK: add [[BASE]], [[INDEX]]
+; CHECK: rdlong [[DEST:r[0-9]+]], [[BASE]]
+; CHECK-NOT: _ret_
+; CHECK-NEXT: jmp [[DEST]]
+; CHECK-NOT: jmp{{.*}}wc
+; CHECK-NOT: jmp{{.*}}wz
+; CHECK: [[CASE0:.Ltmp[0-9]+]]:
+; O0: mov r0, #17
+; OPT: mov r31, #17
+; CHECK: [[CASE1:.Ltmp[0-9]+]]:
+; O0: mov r0, #29
+; OPT: mov r31, #29
+entry:
+  %index = and i32 %selector, 1
+  %slot = getelementptr inbounds [2 x i8*], [2 x i8*]* @targets,
+                                 i32 0, i32 %index
+  %target = load i8*, i8** %slot, align 4
+  indirectbr i8* %target, [label %case0, label %case1]
+
+case0:
+  ret i32 17
+
+case1:
+  ret i32 29
+}
diff --git a/llvm/test/CodeGen/P2/inline-asm-getrnd.ll b/llvm/test/CodeGen/P2/inline-asm-getrnd.ll
