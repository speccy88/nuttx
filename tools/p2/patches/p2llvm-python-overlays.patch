+; RUN: not cmp %t/v1.o %t/v2.o
+; RUN: not %python %S/../../../utils/p2-overlay-link.py --fragment-only --slot-address 0x50000 --slot-size 0x10000 --lma-address 0x80000 -o %t/duplicate.ld %t/checkout-a.o %t/checkout-b.o 2>&1 | FileCheck %s --check-prefix=DUPLICATE
+;
+; RUN: not --crash llc -march=p2 -O2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/checkout-a -p2-hub-overlay-source-namespace=runtime -p2-hub-overlay-slot-address=0x50000 -filetype=obj %t/outside.ll -o /dev/null 2>&1 | FileCheck %s --check-prefix=OUTSIDE
+; RUN: not --crash llc -march=p2 -O2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/checkout-a/src -p2-hub-overlay-source-namespace=runtime -p2-hub-overlay-slot-address=0x50000 -filetype=obj %t/escape.ll -o /dev/null 2>&1 | FileCheck %s --check-prefix=OUTSIDE
+; RUN: not --crash llc -march=p2 -O2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/checkout-a -p2-hub-overlay-source-namespace=runtime -p2-hub-overlay-slot-address=0x50000 -filetype=obj %t/stdin.ll -o /dev/null 2>&1 | FileCheck %s --check-prefix=NOT-PATH
+; RUN: not --crash llc -march=p2 -O2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/checkout-a -p2-hub-overlay-source-namespace=runtime -p2-hub-overlay-slot-address=0x50000 -filetype=obj %t/empty.ll -o /dev/null 2>&1 | FileCheck %s --check-prefix=EMPTY
