index 0000000000000000000000000000000000000000..632a9ef1332d492adbbf3c2e8935a0c79e469c0e
--- /dev/null
+++ b/llvm/test/CodeGen/P2/hub-overlay-errors.ll
@@ -0,0 +1,36 @@
+; RUN: not --crash llc -march=p2 -p2-hub-overlays -p2-hub-overlay-slot-address=0x50000 -o /dev/null %s 2>&1 | FileCheck %s --check-prefix=BLOCK
+; RUN: not --crash llc -march=p2 -p2-hub-overlays -p2-hub-overlay-slot-address=0 -o /dev/null %S/hub-overlay.ll 2>&1 | FileCheck %s --check-prefix=SLOT
+; RUN: not --crash llc -march=p2 -p2-hub-overlays-all -p2-hub-overlay-group=1 -p2-hub-overlay-slot-address=0x50000 -o /dev/null %S/hub-overlay.ll 2>&1 | FileCheck %s --check-prefix=ENABLE
+; RUN: not --crash llc -march=p2 -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-slot-address=0x50000 -o /dev/null %S/hub-overlay-link-assigned.ll 2>&1 | FileCheck %s --check-prefix=SOURCE-ROOT
+; RUN: not --crash llc -march=p2 -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/src -p2-hub-overlay-slot-address=0x50000 -o /dev/null %S/hub-overlay-link-assigned.ll 2>&1 | FileCheck %s --check-prefix=NAMESPACE
+; RUN: not --crash llc -march=p2 -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=relative -p2-hub-overlay-source-namespace=test -p2-hub-overlay-slot-address=0x50000 -o /dev/null %S/hub-overlay-link-assigned.ll 2>&1 | FileCheck %s --check-prefix=ABSOLUTE
+; RUN: not --crash llc -march=p2 -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/src -p2-hub-overlay-source-namespace=Bad -p2-hub-overlay-slot-address=0x50000 -o /dev/null %S/hub-overlay-link-assigned.ll 2>&1 | FileCheck %s --check-prefix=BAD-NAMESPACE
+; RUN: not --crash llc -march=p2 -p2-hub-overlays -p2-hub-overlays-all -p2-hub-overlay-link-assigned -p2-hub-overlay-source-root=/src -p2-hub-overlay-source-namespace=test -p2-hub-overlay-source-variant=Bad -p2-hub-overlay-slot-address=0x50000 -o /dev/null %S/hub-overlay-link-assigned.ll 2>&1 | FileCheck %s --check-prefix=BAD-VARIANT
+; RUN: not --crash llc -march=p2 -p2-hub-overlays -p2-hub-overlay-source-root=/src -p2-hub-overlay-slot-address=0x50000 -o /dev/null %S/hub-overlay.ll 2>&1 | FileCheck %s --check-prefix=IDENTITY-MODE
+;
+; BLOCK: P2 Hub overlay lowering failed: explicit function 'computed_target' has a blockaddress/code-label use
+; SLOT: P2 Hub overlay lowering failed: -p2-hub-overlay-slot-address must be a four-byte-aligned, nonzero Hub address below 0x7c000
+; ENABLE: P2 Hub overlay lowering failed: -p2-hub-overlays-all requires -p2-hub-overlays
+; SOURCE-ROOT: P2 Hub overlay lowering failed: -p2-hub-overlay-link-assigned requires -p2-hub-overlay-source-root
+; NAMESPACE: P2 Hub overlay lowering failed: -p2-hub-overlay-source-namespace must match [a-z0-9][a-z0-9._-]{0,63}
+; ABSOLUTE: P2 Hub overlay lowering failed: -p2-hub-overlay-source-root must be an absolute path
+; BAD-NAMESPACE: P2 Hub overlay lowering failed: -p2-hub-overlay-source-namespace must match [a-z0-9][a-z0-9._-]{0,63}
+; BAD-VARIANT: P2 Hub overlay lowering failed: -p2-hub-overlay-source-variant must be empty or match [a-z0-9][a-z0-9._-]{0,63}
+; IDENTITY-MODE: P2 Hub overlay lowering failed: link-assigned source identity options require -p2-hub-overlay-link-assigned
+
+target triple = "p2-unknown-nuttx"
+
+@label_address = global i8* blockaddress(@computed_target, %target)
+
+define void @computed_target(i1 %which) #0 {
+entry:
+  br i1 %which, label %target, label %exit
+
+target:
+  br label %exit
+
+exit:
+  ret void
+}
+
+attributes #0 = { "p2-hub-overlay-group"="1" }
diff --git a/llvm/test/CodeGen/P2/hub-overlay-link-assigned.ll b/llvm/test/CodeGen/P2/hub-overlay-link-assigned.ll
new file mode 100644
index 0000000000000000000000000000000000000000..79763d517af2d21a7e657c3ef7d445ddbdedf69f
--- /dev/null
