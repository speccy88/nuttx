+bool P2UnifiedMemory::lowerVAArg(VAArgInst &VAArg,
+                                 const DataLayout &DL) const {
+  Value *List = VAArg.getPointerOperand();
+  if (isProvablyHubPointer(List, DL))
+    return false;
+
+  // P2 uses VoidPtrBuiltinVaList: a va_list object is one descending Hub-stack
+  // cursor.  Only the va_list object may live in unified memory; a valid cursor
+  // still points into the caller's Hub argument area.  Stage that cursor in a
+  // native alloca so P2ISelLowering's existing VAARG implementation remains
+  // the single source of truth for ABI adjustment and argument loading.
+  auto *ListPtrTy = dyn_cast<PointerType>(List->getType());
+  Type *CursorTy = ListPtrTy ? ListPtrTy->getPointerElementType() : nullptr;
+  if (!CursorTy || !CursorTy->isPointerTy() ||
+      DL.isNonIntegralPointerType(CursorTy) ||
+      DL.getPointerTypeSizeInBits(CursorTy) != 32)
+    fail(VAArg, "P2 dynamic va_arg requires a pointer-sized va_list cursor");
+
+  Function &F = *VAArg.getFunction();
+  IRBuilder<> EntryBuilder(&*F.getEntryBlock().getFirstInsertionPt());
+  AllocaInst *HubList = EntryBuilder.CreateAlloca(
+      CursorTy, nullptr, VAArg.getName() + ".xmem.va_list");
+  HubList->setAlignment(Align(4));
+
+  IRBuilder<> Builder(&VAArg);
+  Builder.SetCurrentDebugLocation(VAArg.getDebugLoc());
+  Value *Address = castAddress(Builder, List);
+  FunctionCallee LoadCursor = getHelper(
+      *VAArg.getModule(), "__p2_xmem_load32", Builder.getInt32Ty(),
+      {Builder.getInt8PtrTy()});
+  Value *RawCursor = Builder.CreateCall(
+      LoadCursor, {Address}, VAArg.getName() + ".xmem.cursor.raw");
+  Value *Cursor = Builder.CreateIntToPtr(
+      RawCursor, CursorTy, VAArg.getName() + ".xmem.cursor");
+  StoreInst *StageCursor = Builder.CreateStore(Cursor, HubList);
+  StageCursor->setAlignment(Align(4));
+
+  VAArgInst *HubVAArg = Builder.CreateVAArg(
+      HubList, VAArg.getType(), VAArg.getName() + ".xmem");
+  HubVAArg->copyMetadata(VAArg);
+
+  LoadInst *UpdatedCursor = Builder.CreateLoad(
+      CursorTy, HubList, VAArg.getName() + ".xmem.cursor.next");
+  UpdatedCursor->setAlignment(Align(4));
+  Value *RawUpdatedCursor = Builder.CreatePtrToInt(
+      UpdatedCursor, Builder.getInt32Ty(),
+      VAArg.getName() + ".xmem.cursor.next.raw");
+  FunctionCallee StoreCursor = getHelper(
+      *VAArg.getModule(), "__p2_xmem_store32", Builder.getVoidTy(),
+      {Builder.getInt8PtrTy(), Builder.getInt32Ty()});
+  Builder.CreateCall(StoreCursor, {Address, RawUpdatedCursor});
+
+  VAArg.replaceAllUsesWith(HubVAArg);
+  VAArg.eraseFromParent();
+  return true;
+}
