diff --git a/llvm/utils/p2-overlay-link.py b/llvm/utils/p2-overlay-link.py
new file mode 100755
index 0000000000000000000000000000000000000000..e5b30b389c02fbc897d72cda1d31edf7440ee5f5
--- /dev/null
+++ b/llvm/utils/p2-overlay-link.py
@@ -0,0 +1,877 @@
+#!/usr/bin/env python3
+#
+# Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+# See https://llvm.org/LICENSE.txt for license information.
+# SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+"""Generate a deterministic LLD script for P2 Hub overlay objects.
+
+The compiler names fixed implementation input sections
+``.p2.overlay.body.GGGGGGGG`` where ``GGGGGGGG`` is a hexadecimal runtime
+group ID.  Link-assigned implementations instead use full lowercase SHA-256
+tokens in
+``.p2.overlay.auto.<64-hex-TU>.<8-hex-order>.<64-hex-function>``.  This tool
+scans ELF objects (including every member of Unix archives), packs the latter
+by module and compiler-provided call order after exact machine-code sizes are
+known, and emits one LLD ``OVERLAY`` description.  Fixed-only inputs preserve
+the legacy contiguous-ID behavior.  In link-assigned mode fixed IDs are
+reserved, automatic groups take the lowest available IDs, and every ID through
+the highest assigned group gets a four-byte anchor so output groups are dense.
+
+The generated standalone script also packs the compiler's four-byte veneers
+and immutable eight-byte external entry records in identical input-file
+order.  Runtime group zero remains reserved and is not an output section.
+``--fragment-only`` instead emits a composable second ``SECTIONS`` block that
+owns only overlay groups and leaves every resident and external-data output
+section to a NuttX base script.
+"""
+
+from __future__ import annotations
+
+import argparse
+import math
+import re
+import struct
+import sys
+from dataclasses import dataclass
+from pathlib import Path
+from typing import (
+    Dict,
+    Iterable,
+    Iterator,
+    List,
+    Mapping,
+    Optional,
+    Sequence,
+    Tuple,
+)
+
+
+GROUP_RE = re.compile(rb"^\.p2\.overlay\.body\.([0-9a-fA-F]{8})$")
+AUTO_RE = re.compile(
+    rb"^\.p2\.overlay\.auto\.([0-9a-f]{64})\."
+    rb"([0-9a-f]{8})\.([0-9a-f]{64})$"
+)
+AUTO_PREFIX = b".p2.overlay.auto."
+GROUPREF_PREFIX = "__p2_overlay_groupref_"
+AR_MAGIC = b"!<arch>\n"
+ELF_MAGIC = b"\x7fELF"
+PINNED_LOADER_LIMIT = 0x7C000
+AUTO_WHOLE_MODULE_LIMIT = 32 * 1024
+AUTO_INITIAL_TARGET = 8 * 1024
+AUTO_GROUP_ANCHOR_SIZE = 4
+DEFAULT_MAX_GROUPS = 1024
+
+
+class InputError(ValueError):
+    pass
+
+
+@dataclass(frozen=True)
+class ELFSection:
+    """The ELF fields needed to model an overlay input section."""
+
+    name: bytes
+    size: int
+    alignment: int
+
+
+@dataclass(frozen=True)
+class GroupSize:
+    """Conservative linked-size estimate for one overlay group."""
+
+    input_bytes: int
+    alignment_bytes: int
+    required_bytes: int
+    section_count: int
+
+
+@dataclass(frozen=True)
+class AutoSection:
+    """One compiler-ordered link-assigned function body."""
+
+    name: str
+    tu_token: str
+    order: int
+    function_token: str
+    size: int
+    alignment: int
+    label: str
+
+    @property
+    def groupref(self) -> str:
+        return GROUPREF_PREFIX + self.tu_token + "_" + self.function_token
+
+
+@dataclass(frozen=True)
+class AutoUnit:
+    """An indivisible packing unit (a small TU or one large-TU function)."""
+
+    sections: Tuple[AutoSection, ...]
+    hard_cap: bool
+
+
+@dataclass(frozen=True)
+class OverlayPlan:
+    """All fixed and link-assigned decisions needed to emit one script."""
+
+    groups: Tuple[int, ...]
+    sizes: Mapping[int, GroupSize]
+    auto_groups: Mapping[int, Tuple[AutoSection, ...]]
+    grouprefs: Mapping[str, int]
+    anchors: bool
+    target_size: int
+
+
+def _range(data: bytes, start: int, size: int, what: str) -> bytes:
+    if start < 0 or size < 0 or start > len(data) or size > len(data) - start:
+        raise InputError(f"{what} is outside the input file")
+    return data[start : start + size]
+
+
+def _cstring(table: bytes, offset: int) -> bytes:
+    if offset < 0 or offset >= len(table):
+        raise InputError("ELF section-name offset is outside the string table")
+    end = table.find(b"\0", offset)
+    if end < 0:
+        raise InputError("ELF section name is not terminated")
+    return table[offset:end]
+
+
+def _elf_sections(data: bytes, label: str) -> Iterator[ELFSection]:
+    if len(data) < 16 or data[:4] != ELF_MAGIC:
+        raise InputError(f"{label}: not an ELF object")
+    elf_class = data[4]
+    encoding = data[5]
+    if elf_class not in (1, 2) or encoding not in (1, 2):
+        raise InputError(f"{label}: unsupported ELF class or byte order")
+    endian = "<" if encoding == 1 else ">"
+    if elf_class == 1:
+        header_format = endian + "16sHHIIIIIHHHHHH"
+        section_format = endian + "IIIIIIIIII"
+        shoff_index, shentsize_index, shnum_index, shstrndx_index = 6, 11, 12, 13
+    else:
+        header_format = endian + "16sHHIQQQIHHHHHH"
+        section_format = endian + "IIQQQQIIQQ"
+        shoff_index, shentsize_index, shnum_index, shstrndx_index = 6, 11, 12, 13
+
+    header_size = struct.calcsize(header_format)
+    if len(data) < header_size:
+        raise InputError(f"{label}: truncated ELF header")
+    header = struct.unpack_from(header_format, data)
+    shoff = int(header[shoff_index])
+    shentsize = int(header[shentsize_index])
+    shnum = int(header[shnum_index])
+    shstrndx = int(header[shstrndx_index])
+    expected = struct.calcsize(section_format)
+    if shentsize != expected or shnum == 0 or shstrndx >= shnum:
+        raise InputError(f"{label}: unsupported or invalid ELF section table")
+    _range(data, shoff, shentsize * shnum, f"{label}: ELF section table")
+
+    sections = [
+        struct.unpack_from(section_format, data, shoff + index * shentsize)
+        for index in range(shnum)
+    ]
+    # sh_offset and sh_size occupy tuple indexes 4 and 5 in both ELF classes.
+    names_header = sections[shstrndx]
+    names = _range(
+        data,
+        int(names_header[4]),
+        int(names_header[5]),
+        f"{label}: ELF section-name table",
+    )
+    for section in sections:
+        alignment = int(section[8])
+        if alignment == 0:
+            alignment = 1
+        if alignment & (alignment - 1):
+            name = _cstring(names, int(section[0])).decode(
+                "utf-8", "backslashreplace"
+            )
+            raise InputError(
+                f"{label}: section {name!r} has non-power-of-two alignment "
+                f"{alignment}"
+            )
+        yield ELFSection(
+            name=_cstring(names, int(section[0])),
+            size=int(section[5]),
+            alignment=alignment,
+        )
+
+
+def _archive_members(data: bytes, label: str) -> Iterator[Tuple[str, bytes]]:
+    if not data.startswith(AR_MAGIC):
+        raise InputError(f"{label}: invalid archive magic")
+    offset = len(AR_MAGIC)
+    long_names = b""
+    while offset < len(data):
+        header = _range(data, offset, 60, f"{label}: archive member header")
+        if header[58:60] != b"`\n":
+            raise InputError(f"{label}: malformed archive member header")
+        try:
+            size = int(header[48:58].decode("ascii").strip(), 10)
+        except (UnicodeDecodeError, ValueError) as exc:
+            raise InputError(f"{label}: invalid archive member size") from exc
+        payload = _range(data, offset + 60, size, f"{label}: archive member")
+        raw_name = header[:16].rstrip()
+        member_name: bytes
+        if raw_name in (b"/", b"/SYM64/", b"/SYM64"):
+            member_name = raw_name.rstrip(b"/") or b"/"
+        elif raw_name == b"//":
+            long_names = payload
+            member_name = b"//"
+        elif raw_name.startswith(b"#1/"):
+            try:
+                name_size = int(raw_name[3:], 10)
+            except ValueError as exc:
+                raise InputError(f"{label}: invalid BSD archive name") from exc
+            member_name = _range(payload, 0, name_size, "BSD archive name")
+            payload = payload[name_size:]
+        elif raw_name.startswith(b"/") and raw_name[1:].isdigit():
+            name_offset = int(raw_name[1:], 10)
+            if name_offset >= len(long_names):
+                raise InputError(f"{label}: archive long-name offset out of range")
+            end = long_names.find(b"/\n", name_offset)
+            if end < 0:
+                end = long_names.find(b"\0", name_offset)
+            if end < 0:
+                raise InputError(f"{label}: unterminated archive long name")
+            member_name = long_names[name_offset:end]
+        else:
+            member_name = raw_name.rstrip(b"/")
+
+        # '/', '/SYM64/' and '__.SYMDEF*' are symbol/name tables, not objects.
+        if member_name not in (b"/", b"//", b"/SYM64") and not member_name.startswith(
+            b"__.SYMDEF"
+        ):
+            try:
+                decoded = member_name.decode("utf-8", "strict")
+            except UnicodeDecodeError:
+                decoded = member_name.decode("utf-8", "backslashreplace")
+            yield f"{label}({decoded})", payload
+        offset += 60 + size
+        if offset & 1:
+            offset += 1
+    if offset != len(data):
+        raise InputError(f"{label}: archive has a truncated alignment byte")
+
+
+def _object_blobs(path: Path) -> Iterator[Tuple[str, bytes]]:
+    try:
+        data = path.read_bytes()
+    except OSError as exc:
+        raise InputError(f"{path}: {exc.strerror}") from exc
+    if data.startswith(ELF_MAGIC):
+        yield str(path), data
+    elif data.startswith(AR_MAGIC):
+        yield from _archive_members(data, str(path))
+    else:
+        raise InputError(f"{path}: expected an ELF object or Unix archive")
+
+
+def _scan_overlay_sections(
+    paths: Sequence[Path],
+) -> Tuple[Dict[int, List[ELFSection]], Tuple[AutoSection, ...]]:
+    """Scan fixed and automatic sections once, including archive members."""
+
+    fixed: Dict[int, List[ELFSection]] = {}
+    automatic: List[AutoSection] = []
+    section_names: Dict[str, str] = {}
+    call_orders: Dict[Tuple[str, int], str] = {}
+    grouprefs: Dict[Tuple[str, str], str] = {}
+    for path in paths:
+        for label, data in _object_blobs(path):
+            for section in _elf_sections(data, label):
+                fixed_match = GROUP_RE.fullmatch(section.name)
+                if fixed_match:
+                    group = int(fixed_match.group(1), 16)
+                    if group == 0:
+                        raise InputError(f"{label}: overlay group zero is reserved")
+                    fixed.setdefault(group, []).append(section)
+                    continue
+
+                auto_match = AUTO_RE.fullmatch(section.name)
+                if auto_match is None:
+                    if section.name.startswith(AUTO_PREFIX):
+                        name = section.name.decode("ascii", "backslashreplace")
+                        raise InputError(
+                            f"{label}: malformed link-assigned section {name!r}"
+                        )
+                    continue
+
+                name = section.name.decode("ascii")
+                tu_token = auto_match.group(1).decode("ascii")
+                order_token = auto_match.group(2).decode("ascii")
+                function_token = auto_match.group(3).decode("ascii")
+                order = int(order_token, 16)
+                if name in section_names:
+                    raise InputError(
+                        f"{label}: duplicate link-assigned section {name!r}; "
+                        f"first seen in {section_names[name]}"
+                    )
+                order_key = (tu_token, order)
+                if order_key in call_orders:
+                    raise InputError(
+                        f"{label}: duplicate link-assigned call order "
+                        f"{tu_token}.{order_token}; first seen in "
+                        f"{call_orders[order_key]}"
+                    )
+                groupref_key = (tu_token, function_token)
+                if groupref_key in grouprefs:
+                    raise InputError(
+                        f"{label}: duplicate link-assigned group reference "
+                        f"{GROUPREF_PREFIX}{tu_token}_{function_token}; "
+                        f"first seen in {grouprefs[groupref_key]}"
+                    )
+                section_names[name] = label
+                call_orders[order_key] = label
+                grouprefs[groupref_key] = label
+                automatic.append(
+                    AutoSection(
+                        name=name,
+                        tu_token=tu_token,
+                        order=order,
+                        function_token=function_token,
+                        size=section.size,
+                        alignment=section.alignment,
+                        label=label,
+                    )
+                )
+    automatic.sort(
+        key=lambda section: (
+            section.tu_token,
+            section.order,
+            section.function_token,
+            section.name,
+        )
+    )
+    return fixed, tuple(automatic)
+
+
+def _conservative_group_size(
+    sections: Sequence[ELFSection], slot_address: int, anchor: bool = False
+) -> GroupSize:
+    """Return the legacy order-independent upper bound for fixed sections."""
+
+    anchor_bytes = AUTO_GROUP_ANCHOR_SIZE if anchor else 0
+    input_bytes = anchor_bytes + sum(section.size for section in sections)
+    common = slot_address + anchor_bytes
+    for section in sections:
+        common = math.gcd(common, section.size)
+    quantum = common & -common if common else 1
+    alignment_bytes = sum(
+        max(0, section.alignment - quantum) for section in sections
+    )
+    return GroupSize(
+        input_bytes=input_bytes,
+        alignment_bytes=alignment_bytes,
+        required_bytes=input_bytes + alignment_bytes,
+        section_count=len(sections) + (1 if anchor else 0),
+    )
+
+
+def discover_group_sizes(
+    paths: Sequence[Path], slot_address: int
+) -> Dict[int, GroupSize]:
+    """Discover legacy fixed groups and conservatively model their spans."""
+
+    fixed, _automatic = _scan_overlay_sections(paths)
+    if not fixed:
+        raise InputError("no .p2.overlay.body.GGGGGGGG input sections found")
+    ordered = tuple(sorted(fixed))
+    expected = tuple(range(1, ordered[-1] + 1))
+    if ordered != expected:
+        missing = sorted(set(expected) - set(fixed))
+        raise InputError(
+            "overlay group IDs must be contiguous from one; missing "
+            + ", ".join(str(value) for value in missing)
+        )
+    return {
+        group: _conservative_group_size(fixed[group], slot_address)
+        for group in ordered
+    }
+
+
+def discover_groups(paths: Sequence[Path]) -> Tuple[int, ...]:
+    """Compatibility helper returning only the discovered group IDs."""
+
+    return tuple(discover_group_sizes(paths, 0))
+
+
+def _exact_auto_group_size(
+    sections: Sequence[AutoSection], slot_address: int
+) -> GroupSize:
+    """Model the exact layout emitted by ordered selectors and one anchor."""
+
+    offset = AUTO_GROUP_ANCHOR_SIZE
+    alignment_bytes = 0
+    for section in sections:
+        absolute = slot_address + offset
+        aligned = (absolute + section.alignment - 1) & -section.alignment
+        padding = aligned - absolute
+        alignment_bytes += padding
+        offset += padding + section.size
+    return GroupSize(
+        input_bytes=AUTO_GROUP_ANCHOR_SIZE
+        + sum(section.size for section in sections),
+        alignment_bytes=alignment_bytes,
+        required_bytes=offset,
+        section_count=len(sections) + 1,
+    )
+
+
+def _build_auto_units(
+    sections: Sequence[AutoSection], slot_address: int, slot_size: int
+) -> Tuple[AutoUnit, ...]:
+    """Keep small translation units whole and expose large-TU call order."""
+
+    modules: Dict[str, List[AutoSection]] = {}
+    for section in sections:
+        modules.setdefault(section.tu_token, []).append(section)
+
+    units = []
+    initial_target = min(AUTO_INITIAL_TARGET, slot_size)
+    for tu_token in sorted(modules):
+        module = tuple(modules[tu_token])
+        module_size = _exact_auto_group_size(module, slot_address)
+        if (
+            module_size.required_bytes <= AUTO_WHOLE_MODULE_LIMIT
+            and module_size.required_bytes <= slot_size
+        ):
+            units.append(AutoUnit(module, hard_cap=False))
+            continue
+
+        for section in module:
+            section_size = _exact_auto_group_size((section,), slot_address)
+            if section_size.required_bytes > slot_size:
+                raise InputError(
+                    f"{section.label}: link-assigned function section "
+                    f"{section.name!r} requires 0x{section_size.required_bytes:x} "
+                    f"bytes including its group anchor, exceeding the "
+                    f"0x{slot_size:x}-byte Hub slot"
+                )
+            units.append(
+                AutoUnit(
+                    (section,),
+                    hard_cap=section_size.required_bytes > initial_target,
+                )
+            )
+    return tuple(units)
+
+
+def _pack_auto_units(
+    units: Sequence[AutoUnit],
+    target_size: int,
+    slot_address: int,
+    slot_size: int,
+) -> Tuple[Tuple[AutoSection, ...], ...]:
+    """Sequentially pack deterministic units under target or hard-cap bins."""
+
+    packed: List[Tuple[AutoSection, ...]] = []
+    current: List[AutoSection] = []
+    current_limit = target_size
+    hard_cap_module = None
+
+    def start(unit: AutoUnit) -> None:
+        nonlocal current, current_limit, hard_cap_module
+
+        unit_size = _exact_auto_group_size(unit.sections, slot_address)
+        if unit_size.required_bytes > slot_size:
+            first = unit.sections[0]
+            raise InputError(
+                f"{first.label}: link-assigned packing unit beginning with "
+                f"{first.name!r} requires 0x{unit_size.required_bytes:x} bytes, "
+                f"exceeding the 0x{slot_size:x}-byte Hub slot"
+            )
+        current = list(unit.sections)
+        if unit.hard_cap:
+            current_limit = slot_size
+            hard_cap_module = unit.sections[0].tu_token
+        else:
+            current_limit = max(target_size, unit_size.required_bytes)
+            hard_cap_module = None
+
+    for unit in units:
+        if not current:
+            start(unit)
+            continue
+
+        same_hard_cap_module = (
+            hard_cap_module is None
+            or unit.sections[0].tu_token == hard_cap_module
+        )
+        trial = tuple(current) + unit.sections
+        trial_size = _exact_auto_group_size(trial, slot_address)
+        if same_hard_cap_module and trial_size.required_bytes <= current_limit:
+            current.extend(unit.sections)
+            continue
+
+        packed.append(tuple(current))
+        start(unit)
+
+    if current:
+        packed.append(tuple(current))
+    return tuple(packed)
+
+
+def _choose_auto_packing(
+    units: Sequence[AutoUnit],
+    available_groups: int,
+    slot_address: int,
+    slot_size: int,
+) -> Tuple[int, Tuple[Tuple[AutoSection, ...], ...]]:
+    if available_groups <= 0:
+        raise InputError("no group IDs remain for link-assigned overlays")
+
+    initial = min(AUTO_INITIAL_TARGET, slot_size)
+    packed = _pack_auto_units(units, initial, slot_address, slot_size)
+    if len(packed) <= available_groups:
+        return initial, packed
+
+    maximum = _pack_auto_units(units, slot_size, slot_address, slot_size)
+    if len(maximum) > available_groups:
+        raise InputError(
+            f"link-assigned overlays require at least {len(maximum)} automatic "
+            f"groups at the 0x{slot_size:x}-byte Hub slot hard cap, but only "
+            f"{available_groups} group IDs are available"
+        )
+
+    low = initial // 4 + 1
+    high = slot_size // 4
+    best_target = slot_size
+    best_packing = maximum
+    while low <= high:
+        middle = (low + high) // 2
+        target = middle * 4
+        candidate = _pack_auto_units(units, target, slot_address, slot_size)
+        if len(candidate) <= available_groups:
+            best_target = target
+            best_packing = candidate
+            high = middle - 1
+        else:
+            low = middle + 1
+    return best_target, best_packing
+
+
+def build_overlay_plan(
+    paths: Sequence[Path],
+    slot_address: int,
+    slot_size: int,
+    max_groups: int,
+) -> OverlayPlan:
+    """Discover, validate, and assign every fixed and automatic group."""
+
+    fixed, automatic = _scan_overlay_sections(paths)
+    if not fixed and not automatic:
+        raise InputError(
+            "no fixed or link-assigned P2 overlay input sections found"
+        )
+
+    if not automatic:
+        ordered = tuple(sorted(fixed))
+        expected = tuple(range(1, ordered[-1] + 1))
+        if ordered != expected:
+            missing = sorted(set(expected) - set(fixed))
+            raise InputError(
+                "overlay group IDs must be contiguous from one; missing "
+                + ", ".join(str(value) for value in missing)
+            )
+        sizes = {
+            group: _conservative_group_size(fixed[group], slot_address)
+            for group in ordered
+        }
+        return OverlayPlan(ordered, sizes, {}, {}, False, 0)
+
+    if max_groups <= 0:
+        raise InputError("--max-groups must be positive")
+    oversized_ids = sorted(group for group in fixed if group > max_groups)
+    if oversized_ids:
+        raise InputError(
+            "fixed overlay group IDs exceed --max-groups: "
+            + ", ".join(str(group) for group in oversized_ids)
+        )
+
+    units = _build_auto_units(automatic, slot_address, slot_size)
+    available_ids = tuple(
+        group for group in range(1, max_groups + 1) if group not in fixed
+    )
+    target, packed = _choose_auto_packing(
+        units, len(available_ids), slot_address, slot_size
+    )
+    assigned_ids = available_ids[: len(packed)]
+    auto_groups = {
+        group: sections for group, sections in zip(assigned_ids, packed)
+    }
+    grouprefs = {
+        section.groupref: group
+        for group, sections in auto_groups.items()
+        for section in sections
+    }
+
+    highest = max(tuple(fixed) + assigned_ids)
+    groups = tuple(range(1, highest + 1))
+    sizes = {}
+    for group in groups:
+        if group in fixed:
+            sizes[group] = _conservative_group_size(
+                fixed[group], slot_address, anchor=True
+            )
+        elif group in auto_groups:
+            sizes[group] = _exact_auto_group_size(
+                auto_groups[group], slot_address
+            )
+        else:
+            sizes[group] = _exact_auto_group_size((), slot_address)
+    return OverlayPlan(
+        groups,
+        sizes,
+        auto_groups,
+        grouprefs,
+        True,
+        target,
+    )
+
+
+def report_group_sizes(sizes: Dict[int, GroupSize], slot_size: int) -> None:
+    parts = []
+    for group, size in sizes.items():
+        parts.append(
+            f"{group}=0x{size.required_bytes:x}"
+            f"(input=0x{size.input_bytes:x},align=0x{size.alignment_bytes:x})"
+        )
+    print(
+        "p2-overlay-link.py: overlay sizes: "
+        + ", ".join(parts)
+        + f"; slot=0x{slot_size:x}",
+        file=sys.stderr,
+    )
+
+
+def validate_group_sizes(sizes: Dict[int, GroupSize], slot_size: int) -> None:
+    failures = []
+    for group, size in sizes.items():
+        if size.required_bytes > slot_size:
+            failures.append(
+                f"group {group} requires 0x{size.required_bytes:x} bytes "
+                f"(0x{size.input_bytes:x} input + "
+                f"0x{size.alignment_bytes:x} alignment across "
+                f"{size.section_count} sections), exceeding the "
+                f"0x{slot_size:x}-byte Hub slot by "
+                f"0x{size.required_bytes - slot_size:x}"
+            )
+    if failures:
+        raise InputError("overlay size preflight failed: " + "; ".join(failures))
+
+
+def _number(value: str) -> int:
+    try:
+        return int(value, 0)
+    except ValueError as exc:
+        raise argparse.ArgumentTypeError(f"invalid integer: {value}") from exc
+
+
+def generate_script(
+    groups: Iterable[int],
+    slot: int,
+    size: int,
+    lma: int,
+    fragment_only: bool = False,
+    auto_groups: Optional[Mapping[int, Sequence[AutoSection]]] = None,
+    grouprefs: Optional[Mapping[str, int]] = None,
+    anchors: bool = False,
+) -> str:
+    group_list = tuple(groups)
+    auto_groups = auto_groups or {}
+    grouprefs = grouprefs or {}
+    lines = ["/* Generated deterministically by llvm/utils/p2-overlay-link.py. */"]
+    for symbol in sorted(grouprefs):
+        lines.append(f"{symbol} = {grouprefs[symbol]};")
+    if fragment_only:
+        # The runtime table count includes reserved group zero.  A base NuttX
+        # script can use this absolute symbol directly to reserve one writable
+        # sixteen-byte record for zero plus one for every emitted group.
+        lines.extend(
+            [
+                f"__p2_overlay_group_count = {len(group_list) + 1};",
+                "SECTIONS",
+                "{",
+            ]
+        )
+    else:
+        lines.extend(
+            [
+                "SECTIONS",
+                "{",
+                "  . = 0x00001000;",
+                "  .text : { *(.text .text.*) }",
+                "  .rodata : { *(.rodata .rodata.*) }",
+                "  .data : { *(.data .data.*) }",
+                "  .bss (NOLOAD) : { *(.bss .bss.*) *(COMMON) }",
+                "",
+                "  .p2.overlay.stubs : ALIGN(4)",
+                "  {",
+                "    __p2_overlay_stubs_start = ABSOLUTE(.);",
+                "    KEEP(*(.p2.overlay.stubs))",
+                "    __p2_overlay_stubs_end = ABSOLUTE(.);",
+                "  }",
+                "  .p2.xdata 0x10000000 : AT (0x02000000)",
+                "  {",
+                "    __p2_overlay_entries_start = ABSOLUTE(.);",
+                "    KEEP(*(.p2.xdata.ro.overlay.entries))",
+                "    __p2_overlay_entries_end = ABSOLUTE(.);",
+                "  }",
+                "",
+            ]
+        )
+    lines.extend(
+        [
+            f"  OVERLAY 0x{slot:08x} : AT (0x{lma:08x})",
+            "  {",
+        ]
+    )
+    for group in group_list:
+        suffix = f"{group:08x}"
+        lines.extend([f"    .p2.overlay.group.{suffix}", "    {"])
+        if anchors:
+            lines.append("      LONG(0)")
+        lines.append(f"      *(.p2.overlay.body.{suffix})")
+        for section in auto_groups.get(group, ()):
+            lines.append(f"      *({section.name})")
+        lines.append("    }")
+    lines.extend(
+        [
+            "  }",
+        ]
+    )
+    for group in group_list:
+        suffix = f"{group:08x}"
+        lines.extend(
+            [
+                f"  __p2_overlay_group_{group}_start = "
+                f"ADDR(.p2.overlay.group.{suffix});",
+                f"  __p2_overlay_group_{group}_end = "
+                f"ADDR(.p2.overlay.group.{suffix}) + "
+                f"SIZEOF(.p2.overlay.group.{suffix});",
+                f"  __p2_overlay_group_{group}_load = "
+                f"LOADADDR(.p2.overlay.group.{suffix});",
+            ]
+        )
+    if not fragment_only:
+        lines.extend(
+            [
+                f"  __p2_overlay_slot_start = 0x{slot:08x};",
+                f"  __p2_overlay_slot_end = 0x{slot + size:08x};",
+            ]
+        )
+    lines.extend(["}", ""])
+    if fragment_only:
+        lines.extend(
+            [
+                f"ASSERT(__p2_overlay_slot_start == 0x{slot:08x},",
+                '       "P2 base linker script has a different overlay slot start")',
+                f"ASSERT(__p2_overlay_slot_end == 0x{slot + size:08x},",
+                '       "P2 base linker script has a different overlay slot size")',
+            ]
+        )
+    else:
+        lines.extend(
+            [
+                "ASSERT((__p2_overlay_stubs_end - __p2_overlay_stubs_start) % 4 == 0,",
+                '       "P2 overlay veneers are not four-byte records")',
+                "ASSERT((__p2_overlay_entries_end - __p2_overlay_entries_start) ==",
+                "       ((__p2_overlay_stubs_end - __p2_overlay_stubs_start) / 4) * 8,",
+                '       "P2 overlay veneer and entry counts differ")',
+            ]
+        )
+    for group in group_list:
+        suffix = f"{group:08x}"
+        lines.extend(
+            [
+                f"ASSERT(SIZEOF(.p2.overlay.group.{suffix}) <= 0x{size:x},",
+                f'       "P2 overlay group {group} exceeds the Hub slot")',
+                f"ASSERT((ADDR(.p2.overlay.group.{suffix}) & 3) == 0,",
+                f'       "P2 overlay group {group} is not instruction aligned")',
+            ]
+        )
+    return "\n".join(lines) + "\n"
+
+
+def parse_args(argv: Sequence[str]) -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--slot-address", required=True, type=_number)
+    parser.add_argument("--slot-size", required=True, type=_number)
+    parser.add_argument("--lma-address", required=True, type=_number)
+    parser.add_argument(
+        "--max-groups",
+        type=_number,
+        default=DEFAULT_MAX_GROUPS,
+        help=(
+            "maximum nonzero runtime group ID when link-assigned sections "
+            f"are present (default: {DEFAULT_MAX_GROUPS})"
+        ),
+    )
+    parser.add_argument(
+        "--fragment-only",
+        action="store_true",
+        help=(
+            "emit only a composable OVERLAY SECTIONS fragment and group count; "
+            "the base script owns resident sections"
+        ),
+    )
+    parser.add_argument("-o", "--output", required=True, type=Path)
+    parser.add_argument("inputs", nargs="+", type=Path)
+    return parser.parse_args(argv)
+
+
+def main(argv: Sequence[str]) -> int:
+    args = parse_args(argv)
+    if args.slot_address <= 0 or args.slot_address & 3:
+        raise InputError("slot address must be nonzero and four-byte aligned")
+    if args.slot_size <= 0 or args.slot_size & 3:
+        raise InputError("slot size must be nonzero and four-byte aligned")
+    if args.slot_address + args.slot_size > PINNED_LOADER_LIMIT:
+        raise InputError("overlay slot exceeds the pinned 0x7c000 Hub limit")
+    if args.lma_address < 0 or args.lma_address > 0xFFFFFFFF:
+        raise InputError("LMA address is outside the 32-bit ELF range")
+    if args.max_groups <= 0 or args.max_groups > 0xFFFFFFFF:
+        raise InputError("--max-groups is outside the nonzero 32-bit range")
+    plan = build_overlay_plan(
+        args.inputs,
+        args.slot_address,
+        args.slot_size,
+        args.max_groups,
+    )
+    if plan.anchors:
+        print(
+            "p2-overlay-link.py: link-assigned packing: "
+            f"functions={len(plan.grouprefs)}, "
+            f"automatic-groups={len(plan.auto_groups)}, "
+            f"dense-groups={len(plan.groups)}, "
+            f"target=0x{plan.target_size:x}, "
+            f"max-groups={args.max_groups}",
+            file=sys.stderr,
+        )
+    report_group_sizes(dict(plan.sizes), args.slot_size)
+    validate_group_sizes(dict(plan.sizes), args.slot_size)
+    output = generate_script(
+        plan.groups,
+        args.slot_address,
+        args.slot_size,
+        args.lma_address,
+        fragment_only=args.fragment_only,
+        auto_groups=plan.auto_groups,
+        grouprefs=plan.grouprefs,
+        anchors=plan.anchors,
+    )
+    try:
+        args.output.write_text(output, encoding="utf-8")
+    except OSError as exc:
+        raise InputError(f"{args.output}: {exc.strerror}") from exc
+    return 0
+
+
+if __name__ == "__main__":
+    try:
+        raise SystemExit(main(sys.argv[1:]))
+    except InputError as exc:
+        print(f"p2-overlay-link.py: error: {exc}", file=sys.stderr)
+        raise SystemExit(1)
