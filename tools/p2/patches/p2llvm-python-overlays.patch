--- /dev/null
+++ b/llvm/test/CodeGen/P2/hub-overlay-link.ll
@@ -0,0 +1,50 @@
+; RUN: llc -march=p2 -O2 -p2-unified-memory -p2-hub-overlays -p2-hub-overlay-slot-address=0x50000 -filetype=obj %S/hub-overlay.ll -o %t.o
+; RUN: %python %S/../../../utils/p2-overlay-link.py --slot-address 0x50000 --slot-size 0x10000 --lma-address 0x80000 -o %t.ld %t.o
+; RUN: ld.lld -T %t.ld -o %t.elf %t.o
+; RUN: llvm-readelf -S -l -s %t.elf | FileCheck %s
+; RUN: llvm-objdump -dr %t.elf | FileCheck %s --check-prefix=DIS
+; RUN: %python %S/../../../utils/p2-overlay-link.py --fragment-only --slot-address 0x50000 --slot-size 0x10000 --lma-address 0x80000 -o %t.fragment.ld %t.o
+; RUN: FileCheck %s --check-prefix=FRAGMENT < %t.fragment.ld
+; RUN: ld.lld -T %S/Inputs/hub-overlay-base.ld -T %t.fragment.ld -o %t.fragment.elf %t.o
+; RUN: llvm-readelf -S -l -s %t.fragment.elf | FileCheck %s --check-prefix=FRAGMENT-ELF
+;
+; Both implementation groups execute at exactly the shared Hub slot VMA, but
+; have consecutive, distinct LMAs for deterministic host extraction.
+;
+; CHECK: .p2.overlay.stubs     PROGBITS {{0*}}[[STUB:[0-9a-f]+]] {{[0-9a-f]+}} 000014
+; CHECK: .p2.xdata             PROGBITS 10000000 {{[0-9a-f]+}} 000028
+; CHECK: .p2.overlay.group.00000001 PROGBITS 00050000
+; CHECK: .p2.overlay.group.00000002 PROGBITS 00050000
+; CHECK: LOAD {{.*}} 0x00050000 0x00080000
+; CHECK: LOAD {{.*}} 0x00050000 0x{{[0-9a-f]+}}
+; CHECK: 00050000 {{.*}} __p2_overlay_group_1_start
+; CHECK: 00050000 {{.*}} __p2_overlay_group_2_start
+; CHECK: 00050000 {{.*}} __p2_overlay_slot_start
+;
+; The integration mode owns no resident output sections.  It advertises the
+; complete runtime table count, verifies the base slot contract, and composes
+; as a second SECTIONS block after a NuttX-style base script.
+;
+; FRAGMENT: __p2_overlay_group_count = 3;
+; FRAGMENT-NOT: .text :
+; FRAGMENT-NOT: .data :
+; FRAGMENT-NOT: .p2.overlay.stubs :
+; FRAGMENT-NOT: .p2.xdata :
+; FRAGMENT: OVERLAY 0x00050000 : AT (0x00080000)
+; FRAGMENT: .p2.overlay.group.00000001
+; FRAGMENT: .p2.overlay.group.00000002
+; FRAGMENT: ASSERT(__p2_overlay_slot_start == 0x00050000
+; FRAGMENT: ASSERT(__p2_overlay_slot_end == 0x00060000
+; FRAGMENT-ELF: .p2.overlay.group.00000001 PROGBITS 00050000
+; FRAGMENT-ELF: .p2.overlay.group.00000002 PROGBITS 00050000
+; FRAGMENT-ELF: 00000003 {{.*}} __p2_overlay_group_count
+;
+; Linked entry records contain slot-relative body offsets, and every body call
+; continues to target a resident veneer.
+;
+; DIS: Disassembly of section .p2.overlay.stubs:
+; DIS-COUNT-5: calla #\{{[0-9]+}}
+; DIS: Disassembly of section .p2.overlay.group.00000001:
+; DIS: calla #\{{[0-9]+}}
+; DIS: Disassembly of section .p2.overlay.group.00000002:
+; DIS: reta
diff --git a/llvm/test/CodeGen/P2/hub-overlay-same-group-addrspace.ll b/llvm/test/CodeGen/P2/hub-overlay-same-group-addrspace.ll
new file mode 100644
index 0000000000000000000000000000000000000000..c942a259fab55e3cc7bf9f937b5297e6fa430123
--- /dev/null
+++ b/llvm/test/CodeGen/P2/hub-overlay-same-group-addrspace.ll
@@ -0,0 +1,33 @@
+; RUN: llc -march=p2 -O0 -p2-hub-overlays -p2-hub-overlay-slot-address=0x50000 -stop-after=p2-hub-overlay -o %t.mir %s
+; RUN: llc -march=p2 -x=mir -run-pass=none -o /dev/null %t.mir
+; RUN: FileCheck %s --input-file=%t.mir
+;
+; A same-group call through an address-space cast may target the private body,
+; but the replacement must retain an addrspacecast.  Rebuilding this operand
+; with a bitcast produces invalid IR because the veneer and call operand are in
+; different address spaces.  Reparse the stopped MIR to run the IR verifier
+; without asking the P2 instruction selector to lower a non-default code
+; address space.
+;
+; CHECK-LABEL: define internal i32 @__p2_ovlbody.1.caller
+; CHECK: %result = call i32 addrspacecast (i32 (i32) addrspace(1)* @__p2_ovlbody.0.callee to i32 (i32)*)(i32 %value)
+
+target triple = "p2-unknown-nuttx"
+
+define i32 @callee(i32 %value) addrspace(1) #0 {
+entry:
+  ret i32 %value
+}
+
+define i32 @caller(i32 %value) addrspace(1) #0 {
+entry:
+  %result = call addrspace(0) i32 addrspacecast (i32 (i32) addrspace(1)* @callee to i32 (i32)*)(i32 %value)
+  ret i32 %result
+}
+
+define void @__p2_overlay_enter() {
+entry:
+  unreachable
+}
+
+attributes #0 = { "p2-hub-overlay-group"="1" }
diff --git a/llvm/test/CodeGen/P2/hub-overlay-same-group-metadata.ll b/llvm/test/CodeGen/P2/hub-overlay-same-group-metadata.ll
new file mode 100644
index 0000000000000000000000000000000000000000..cc009b6dcbf8ee18e7931287a2b93424232e15d4
--- /dev/null
+++ b/llvm/test/CodeGen/P2/hub-overlay-same-group-metadata.ll
@@ -0,0 +1,35 @@
+; RUN: llc -march=p2 -O0 -p2-hub-overlays -p2-hub-overlay-slot-address=0x50000 -stop-after=p2-hub-overlay -o %t.mir %s
+; RUN: llc -march=p2 -x=mir -run-pass=none -o /dev/null %t.mir
+; RUN: FileCheck %s --input-file=%t.mir
+;
+; Redirecting an ABI-compatible casted call from the public veneer to its
+; same-group private body promotes an indirect CallBase.  Its indirect-call
+; value profile no longer applies, while its callees metadata still names the
+; old public target; neither attachment may survive.
+;
+; CHECK-LABEL: define internal i32 @__p2_ovlbody.1.caller
+; CHECK: %result = call i32 bitcast (i32 (i8*)* @__p2_ovlbody.0.callee to i32 (i32*)*)(i32* %value){{$}}
+; CHECK-NEXT: ret i32 %result
+
+target triple = "p2-unknown-nuttx"
+
+define i32 @callee(i8* %value) #0 {
+entry:
+  ret i32 7
+}
+
+define i32 @caller(i32* %value) #0 {
+entry:
+  %result = call i32 bitcast (i32 (i8*)* @callee to i32 (i32*)*)(i32* %value), !prof !0, !callees !1
+  ret i32 %result
+}
+
+define void @__p2_overlay_enter() {
+entry:
+  unreachable
+}
+
+attributes #0 = { "p2-hub-overlay-group"="1" }
+
+!0 = !{!"VP", i32 0, i64 1, i64 1234, i64 1}
+!1 = !{i32 (i8*)* @callee}
diff --git a/llvm/test/CodeGen/P2/hub-overlay-size-preflight.ll b/llvm/test/CodeGen/P2/hub-overlay-size-preflight.ll
