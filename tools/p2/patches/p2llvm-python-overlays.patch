+static void
+validateExternalInitializer(const Constant &Initializer,
+                            const GlobalVariable &Owner, const DataLayout &DL,
+                            SmallPtrSetImpl<const Constant *> &Seen) {
+  if (!Seen.insert(&Initializer).second)
+    return;
+
+  validateExternalDataType(Initializer.getType(), Owner);
+
+  // prepareAndValidateExternalGlobal() has already made every undef/poison
+  // leaf concrete.  Keep this check as an invariant and a fail-closed guard
+  // for constant forms not handled by the materializer.
+  if (isa<UndefValue>(Initializer))
+    failExternalData(Owner, "internal error: undefined value remained after "
+                            "external-data materialization");
+  if (isa<BlockAddress>(Initializer))
+    failExternalData(Owner,
+                     "blockaddress relocations are unsupported in external "
+                     "data");
+  if (isa<DSOLocalEquivalent>(Initializer))
+    failExternalData(Owner,
+                     "dso_local_equivalent relocations are unsupported in "
+                     "external data");
+  if (isa<GlobalAlias>(Initializer))
+    failExternalData(Owner,
+                     "global-alias relocations are unsupported in external "
+                     "data");
+  if (isa<GlobalIFunc>(Initializer))
+    failExternalData(Owner,
+                     "ifunc relocations are unsupported in external data");
+
+  if (auto *Referenced = dyn_cast<GlobalValue>(&Initializer)) {
+    if (Referenced->getAddressSpace() != 0)
+      failExternalData(Owner,
+                       Twine("relocation against nonzero-address-space symbol "
+                             "'@") +
+                           Referenced->getName() + "'");
+    if (Referenced->isThreadLocal())
+      failExternalData(Owner, Twine("relocation against TLS symbol '@") +
+                                  Referenced->getName() + "'");
+    if (Referenced->hasCommonLinkage() || Referenced->isWeakForLinker())
+      failExternalData(Owner,
+                       Twine("relocation against common/weak symbol '@") +
+                           Referenced->getName() + "' is ambiguous");
+    return;
+  }
+
+  if (auto *Expression = dyn_cast<ConstantExpr>(&Initializer)) {
+    switch (Expression->getOpcode()) {
+    case Instruction::BitCast:
+      validateExternalInitializer(*cast<Constant>(Expression->getOperand(0)),
+                                  Owner, DL, Seen);
+      return;
+    case Instruction::GetElementPtr: {
+      auto *GEP = cast<GEPOperator>(Expression);
+      auto *PointerTy = cast<PointerType>(GEP->getPointerOperandType());
+      APInt Offset(DL.getIndexSizeInBits(PointerTy->getAddressSpace()), 0);
+      if (Offset.getBitWidth() != 32 ||
+          !GEP->accumulateConstantOffset(DL, Offset))
+        failExternalData(Owner, "GEP relocation is not a fixed 32-bit symbol "
+                                "addend");
+      validateExternalInitializer(*cast<Constant>(GEP->getPointerOperand()),
+                                  Owner, DL, Seen);
+      return;
+    }
+    case Instruction::PtrToInt:
+      if (!Expression->getType()->isIntegerTy(32))
+        failExternalData(Owner,
+                         "pointer relocations stored as integers must be "
+                         "exactly 32 bits");
+      validateExternalInitializer(*cast<Constant>(Expression->getOperand(0)),
+                                  Owner, DL, Seen);
+      return;
+    case Instruction::IntToPtr:
+      if (!isa<ConstantInt>(Expression->getOperand(0)))
+        failExternalData(Owner,
+                         "inttoptr external-data initializers must use a "
+                         "literal address");
+      return;
+    case Instruction::AddrSpaceCast:
+      failExternalData(Owner, "addrspacecast relocations are unsupported in "
+                              "external data");
+    default:
+      failExternalData(
+          Owner, Twine("unsupported external-data relocation expression '") +
+                     Expression->getOpcodeName() + "'");
+    }
+  }
+
+  for (const Use &Operand : Initializer.operands())
+    validateExternalInitializer(*cast<Constant>(Operand.get()), Owner, DL,
+                                Seen);
+}
+
+static bool prepareAndValidateExternalGlobal(GlobalVariable &Global,
+                                             const DataLayout &DL) {
+  validateExternalDataType(Global.getValueType(), Global);
+
+  if (Global.isThreadLocal())
+    failExternalData(Global, "TLS storage is unsupported");
+  if (Global.hasCommonLinkage())
+    failExternalData(Global,
+                     "common linkage has no unique external-data owner; use "
+                     "-fno-common");
+  if (Global.isWeakForLinker())
+    failExternalData(Global,
+                     "weak/linkonce linkage has no unique external-data "
+                     "owner");
+  if (Global.hasAppendingLinkage())
+    failExternalData(Global, "appending linkage is unsupported");
+  if (Global.hasComdat())
+    failExternalData(Global, "COMDAT storage is unsupported");
+  if (Global.hasAvailableExternallyLinkage())
+    failExternalData(Global,
+                     "available_externally storage cannot own an external "
+                     "image");
+  if (Global.getAddressSpace() != 0)
+    failExternalData(Global, "nonzero global address spaces are unsupported");
+
+  if (!Global.hasInitializer())
+    return false;
+
+  Constant *Initializer = Global.getInitializer();
+  Constant *Materialized = materializeUndefinedExternalData(Initializer);
+  bool Changed = Materialized != Initializer;
+  if (Changed)
+    Global.setInitializer(Materialized);
+
+  if (Global.hasSection() && isSectionFamily(Global.getSection(), ".p2.xbss") &&
+      !Global.getInitializer()->isNullValue())
+    failExternalData(Global, ".p2.xbss sections require a zero initializer");
+
+  SmallPtrSet<const Constant *, 32> Seen;
+  validateExternalInitializer(*Global.getInitializer(), Global, DL, Seen);
+  return Changed;
+}
+
+static bool prepareAndValidateExternalData(Module &M) {
+  bool HasExternalData = false;
+  bool Changed = false;
+  const DataLayout &DL = M.getDataLayout();
+
+  for (GlobalVariable &Global : M.globals()) {
+    if (!isP2ExternalDataGlobal(Global))
+      continue;
+
+    HasExternalData = true;
+    Changed |= prepareAndValidateExternalGlobal(Global, DL);
+
