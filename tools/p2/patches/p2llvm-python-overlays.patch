+def P2HubOverlayDocs : Documentation {
+  let Category = DocCatFunction;
+  let Heading = "P2HubOverlay";
+  let Content = [{
+  Clang for P2 supports ``__attribute__((p2_hub_overlay(group)))`` to place a
+  function implementation in a numbered Hub code-overlay group. Group zero is
+  reserved for resident code. The attribute is inert unless the explicit
+  ``-mllvm -p2-hub-overlays`` compiler option is also present. The public
+  function symbol remains a four-byte resident dispatch stub, so direct calls
+  and function pointers keep their normal ABI identity.
+  }];
+}
+
+def P2HubResidentDocs : Documentation {
+  let Category = DocCatFunction;
+  let Heading = "P2HubResident";
+  let Content = [{
+  ``__attribute__((p2_hub_resident))`` excludes a P2 function from
+  ``-mllvm -p2-hub-overlays-all``. Use it for startup, interrupt, overlay
+  loader, dispatcher, and other code that must remain executable while the
+  shared Hub overlay slot is being replaced.
+  }];
+}
