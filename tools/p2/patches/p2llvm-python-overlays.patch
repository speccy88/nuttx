+MCSection *P2TargetObjectFile::getExplicitSectionGlobal(
+    const GlobalObject *GO, SectionKind Kind, const TargetMachine &TM) const {
+  // ELF's generic named-section inference only recognizes conventional
+  // .bss names.  The P2 external-data ABI deliberately uses .p2.xbss*, so
+  // force those validated zero-initialized sections to occupy no file data.
+  // The unified-memory pass rejects COMDAT/weak/common xdata before this
+  // point, which makes a shared non-unique section unambiguous.
+  if (isa<GlobalVariable>(GO) && isP2XBSSSection(GO->getSection()))
+    return getContext().getELFSection(GO->getSection(), ELF::SHT_NOBITS,
+                                      ELF::SHF_ALLOC | ELF::SHF_WRITE);
+  return Base::getExplicitSectionGlobal(GO, Kind, TM);
+}
