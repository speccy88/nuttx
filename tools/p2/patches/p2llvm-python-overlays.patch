+static bool isSectionFamily(StringRef Section, StringRef Root) {
+  return Section == Root ||
+         (Section.startswith(Root) && Section.size() > Root.size() &&
+          Section[Root.size()] == '.');
+}
+
+static bool isExplicitP2ExternalSection(const GlobalVariable &Global) {
+  if (!Global.hasSection())
+    return false;
+  StringRef Section = Global.getSection();
+  return isSectionFamily(Section, ".p2.xdata") ||
+         isSectionFamily(Section, ".p2.xbss");
+}
+
+static bool isExplicitP2HubSection(const GlobalVariable &Global) {
+  return Global.hasSection() && isSectionFamily(Global.getSection(), ".p2.hub");
+}
+
+static bool isCompilerOwnedGlobal(const GlobalVariable &Global) {
+  // These globals describe the LLVM module rather than C object storage.  In
+  // particular, llvm.used and the ctor/dtor lists must stay available to the
+  // ordinary ELF emission machinery even when translation-unit data is
+  // externalized wholesale.
+  return Global.getName().startswith("llvm.") || Global.hasAppendingLinkage() ||
+         (Global.hasSection() && Global.getSection() == "llvm.metadata");
+}
+
+static bool isP2ExternalDataGlobal(const GlobalVariable &Global) {
+  if (isExplicitP2HubSection(Global))
+    return false;
+  if (isExplicitP2ExternalSection(Global))
+    return true;
+  if (isCompilerOwnedGlobal(Global))
+    return false;
+  return EnableP2ExternalizeData ||
+         (EnableP2ExternalizeConstantData && Global.isConstant());
+}
+
+[[noreturn]] static void failExternalData(const GlobalValue &Global,
+                                          const Twine &Reason) {
+  std::string Message;
+  raw_string_ostream OS(Message);
+  OS << "P2 external-data validation failed for '@" << Global.getName()
+     << "': " << Reason;
+  OS.flush();
+  report_fatal_error(StringRef(Message), false);
+}
+
+static void validateExternalDataType(Type *Ty, const GlobalValue &Owner) {
+  if (auto *PointerTy = dyn_cast<PointerType>(Ty)) {
+    if (PointerTy->getAddressSpace() != 0)
+      failExternalData(Owner, "nonzero address spaces are unsupported by the "
+                              "tagged external-data ABI");
+    return;
+  }
+
+  if (auto *ArrayTy = dyn_cast<ArrayType>(Ty)) {
+    validateExternalDataType(ArrayTy->getElementType(), Owner);
+    return;
+  }
+  if (auto *VectorTy = dyn_cast<VectorType>(Ty)) {
+    validateExternalDataType(VectorTy->getElementType(), Owner);
+    return;
+  }
+  if (auto *StructTy = dyn_cast<StructType>(Ty)) {
+    for (Type *ElementTy : StructTy->elements())
+      validateExternalDataType(ElementTy, Owner);
+  }
+}
+
+// External data is copied from the ELF image into PSRAM before any C code can
+// observe it.  LLVM permits undef and poison in global initializers for bytes
+// whose source-language value is unspecified (notably aggregate padding and
+// deliberately uninitialized runtime fields).  Leaving those values to the
+// object writer makes the PSRAM image depend on backend implementation detail,
+// while rejecting them prevents otherwise valid programs such as CPython from
+// being externalized.  Give every undefined leaf the deterministic value zero
+// before validating relocations or selecting xdata versus xbss.
+static Constant *materializeUndefinedExternalData(Constant *Initializer) {
+  if (isa<UndefValue>(Initializer))
+    return Constant::getNullValue(Initializer->getType());
+
+  SmallVector<Constant *, 16> Elements;
+  bool Changed = false;
+
+  if (auto *Struct = dyn_cast<ConstantStruct>(Initializer)) {
+    Elements.reserve(Struct->getNumOperands());
+    for (const Use &Operand : Struct->operands()) {
+      auto *Element = cast<Constant>(Operand.get());
+      Constant *Materialized = materializeUndefinedExternalData(Element);
+      Elements.push_back(Materialized);
+      Changed |= Materialized != Element;
+    }
+    return Changed ? ConstantStruct::get(cast<StructType>(Struct->getType()),
+                                         Elements)
+                   : Initializer;
+  }
+
+  if (auto *Array = dyn_cast<ConstantArray>(Initializer)) {
+    Elements.reserve(Array->getNumOperands());
+    for (const Use &Operand : Array->operands()) {
+      auto *Element = cast<Constant>(Operand.get());
+      Constant *Materialized = materializeUndefinedExternalData(Element);
+      Elements.push_back(Materialized);
+      Changed |= Materialized != Element;
+    }
+    return Changed ? ConstantArray::get(cast<ArrayType>(Array->getType()),
+                                        Elements)
+                   : Initializer;
+  }
+
+  if (auto *Vector = dyn_cast<ConstantVector>(Initializer)) {
+    Elements.reserve(Vector->getNumOperands());
+    for (const Use &Operand : Vector->operands()) {
+      auto *Element = cast<Constant>(Operand.get());
+      Constant *Materialized = materializeUndefinedExternalData(Element);
+      Elements.push_back(Materialized);
+      Changed |= Materialized != Element;
+    }
+    return Changed ? ConstantVector::get(Elements) : Initializer;
+  }
+
+  if (auto *Expression = dyn_cast<ConstantExpr>(Initializer)) {
+    Elements.reserve(Expression->getNumOperands());
+    for (const Use &Operand : Expression->operands()) {
+      auto *Element = cast<Constant>(Operand.get());
+      Constant *Materialized = materializeUndefinedExternalData(Element);
+      Elements.push_back(Materialized);
+      Changed |= Materialized != Element;
+    }
+    if (!Changed)
+      return Initializer;
+
+    Constant *Materialized =
+        Expression->getWithOperands(Elements, Expression->getType());
+    return isa<UndefValue>(Materialized)
+               ? Constant::getNullValue(Materialized->getType())
+               : Materialized;
+  }
+
+  return Initializer;
+}
