diff --git a/clang/test/CodeGen/p2-external-data.c b/clang/test/CodeGen/p2-external-data.c
new file mode 100644
index 0000000000000000000000000000000000000000..160674595e67b25d1cf242dc416cdc8c8a8cbb7b
--- /dev/null
+++ b/clang/test/CodeGen/p2-external-data.c
@@ -0,0 +1,38 @@
+// REQUIRES: p2-registered-target
+// RUN: %clang_cc1 -triple p2 -emit-llvm -o - %s | FileCheck %s --check-prefix=IR
+// RUN: %clang_cc1 -triple p2 -O0 -emit-obj -mllvm -p2-unified-memory -mllvm -p2-externalize-data -o %t %s
+// RUN: llvm-readobj --sections --relocations %t | FileCheck %s --check-prefix=AUTO
+
+#define P2_XDATA __attribute__((section(".p2.xdata.api")))
+#define P2_XBSS __attribute__((section(".p2.xbss.api")))
+#define P2_HUB __attribute__((section(".p2.hub.api")))
+
+int explicit_data P2_XDATA = 7;
+int explicit_bss P2_XBSS;
+int resident_data P2_HUB = 3;
+extern int external_data P2_XDATA;
+extern int external_hub P2_HUB;
+
+int automatic_data = 11;
+int automatic_bss;
+static const char automatic_string[] = "tagged";
+
+// IR-DAG: @explicit_data = global i32 7, section ".p2.xdata.api"
+// IR-DAG: @explicit_bss = global i32 0, section ".p2.xbss.api"
+// IR-DAG: @resident_data = global i32 3, section ".p2.hub.api"
+// IR-DAG: @external_data = external global i32, section ".p2.xdata.api"
+// IR-DAG: @external_hub = external global i32, section ".p2.hub.api"
+
+// AUTO-DAG: Name: .p2.xdata.api
+// AUTO-DAG: Name: .p2.xbss.api
+// AUTO-DAG: Name: .p2.hub.api
+// AUTO-DAG: Name: .p2.xdata
+// AUTO-DAG: Name: .p2.xbss
+// AUTO-DAG: Name: .p2.xdata.ro
+// AUTO-DAG: R_P2_20 __p2_xmem_load32
+// AUTO-DAG: R_P2_20 __p2_xmem_load8
+
+int read_all(void) {
+  return explicit_data + explicit_bss + resident_data + external_data +
+         external_hub + automatic_data + automatic_bss + automatic_string[1];
+}
diff --git a/clang/test/CodeGen/p2-hub-overlay-attrs.c b/clang/test/CodeGen/p2-hub-overlay-attrs.c
