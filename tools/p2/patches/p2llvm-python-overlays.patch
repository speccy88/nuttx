diff --git a/llvm/lib/Target/P2/P2HubOverlay.cpp b/llvm/lib/Target/P2/P2HubOverlay.cpp
new file mode 100644
index 0000000000000000000000000000000000000000..238c12a36dca9c770ff63d0ba867a8e72a833971
--- /dev/null
+++ b/llvm/lib/Target/P2/P2HubOverlay.cpp
@@ -0,0 +1,835 @@
+//===-- P2HubOverlay.cpp - Build transparent Hub overlay veneers ----------===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+//
+// Propeller 2 can execute only from its 20-bit Hub address space.  This late
+// module pass moves selected function implementations into linker overlay
+// groups while leaving the original symbol as a four-byte resident veneer.
+// Consequently, direct calls and function pointers retain their normal C ABI
+// identity.  The resident dispatcher consumes the veneer CALLA return address
+// as an implicit zero-based table index, loads the selected group, removes the
+// veneer frame, and tail-enters the implementation.
+//
+// This transformation deliberately runs after ordinary IR optimization.  A
+// veneer is a naked function containing exactly one side-effecting inline-asm
+// CALLA and no return instruction.  Every reference to the implementation,
+// including recursion, is rewritten to the veneer before code selection.
+//
+// The pass is off by default and P2-only.  It is enabled with
+// -p2-hub-overlays.  Functions carrying the string attribute
+// "p2-hub-overlay-group" are selected explicitly.  -p2-hub-overlays-all
+// selects every safe definition not marked "p2-hub-resident", using either a
+// nonzero default group, deterministic hash grouping, or deterministic
+// link-assigned grouping.  Link-assigned functions are emitted into stable
+// per-function sections so the final linker helper can pack call-local bodies
+// into exact, dense groups after their machine-code sizes are known.  The slot
+// address is explicit because each immutable external entry record contains
+// the implementation offset expected by the target runtime ABI.  Entry
+// records live in the initialized .p2.xdata image; the resident dispatcher
+// reaches them through its bounded xmem cache rather than spending Hub RAM on
+// one eight-byte record per veneer.
+//
+//===----------------------------------------------------------------------===//
+
+#include "P2.h"
+
+#include "llvm/ADT/ArrayRef.h"
+#include "llvm/ADT/DenseMap.h"
+#include "llvm/ADT/SmallPtrSet.h"
+#include "llvm/ADT/SmallString.h"
+#include "llvm/ADT/SmallVector.h"
+#include "llvm/ADT/STLExtras.h"
+#include "llvm/ADT/StringExtras.h"
+#include "llvm/IR/BasicBlock.h"
+#include "llvm/IR/Constants.h"
+#include "llvm/IR/Function.h"
+#include "llvm/IR/GlobalAlias.h"
+#include "llvm/IR/GlobalIFunc.h"
+#include "llvm/IR/GlobalVariable.h"
+#include "llvm/IR/IRBuilder.h"
+#include "llvm/IR/InlineAsm.h"
+#include "llvm/IR/InstIterator.h"
+#include "llvm/IR/Instructions.h"
+#include "llvm/IR/Module.h"
+#include "llvm/IR/Operator.h"
+#include "llvm/Pass.h"
+#include "llvm/Support/CommandLine.h"
+#include "llvm/Support/ErrorHandling.h"
+#include "llvm/Support/Format.h"
+#include "llvm/Support/MD5.h"
+#include "llvm/Support/Path.h"
+#include "llvm/Support/SHA256.h"
+#include "llvm/Support/raw_ostream.h"
+#include "llvm/Transforms/Utils/ModuleUtils.h"
+
+#include <algorithm>
+#include <array>
+#include <cstdint>
+#include <functional>
+#include <limits>
+#include <string>
+
+using namespace llvm;
+
+#define DEBUG_TYPE "p2-hub-overlay"
+
+static cl::opt<bool> EnableP2HubOverlays(
+    "p2-hub-overlays", cl::init(false),
+    cl::desc("Emit transparent Propeller 2 Hub code overlays"));
+
+static cl::opt<bool> P2HubOverlayAll(
+    "p2-hub-overlays-all", cl::init(false),
+    cl::desc("Overlay all safe P2 function definitions not marked resident"));
+
+static cl::opt<unsigned> P2HubOverlayDefaultGroup(
+    "p2-hub-overlay-group", cl::init(0),
+    cl::desc("Default nonzero overlay group for -p2-hub-overlays-all"));
+
+static cl::opt<unsigned> P2HubOverlayAutoGroups(
+    "p2-hub-overlay-auto-groups", cl::init(0),
+    cl::desc("Deterministically hash overlay-all functions into N groups"));
+
+static cl::opt<bool> P2HubOverlayLinkAssigned(
+    "p2-hub-overlay-link-assigned", cl::init(false),
+    cl::desc("Emit stable per-function sections for link-assigned groups"));
+
+static cl::opt<std::string> P2HubOverlaySourceRoot(
+    "p2-hub-overlay-source-root", cl::init(""),
+    cl::desc("Absolute lexical source root for link-assigned identities"));
+
+static cl::opt<std::string> P2HubOverlaySourceNamespace(
+    "p2-hub-overlay-source-namespace", cl::init(""),
+    cl::desc("Stable build namespace for link-assigned identities"));
+
+static cl::opt<std::string> P2HubOverlaySourceVariant(
+    "p2-hub-overlay-source-variant", cl::init(""),
+    cl::desc("Optional stable build variant for link-assigned identities"));
+
+static cl::opt<uint64_t> P2HubOverlaySlotAddress(
+    "p2-hub-overlay-slot-address", cl::init(0),
+    cl::desc("Fixed Hub byte address of the shared overlay execution slot"));
+
+namespace {
+
+constexpr StringLiteral OverlayGroupAttr = "p2-hub-overlay-group";
+constexpr StringLiteral ResidentAttr = "p2-hub-resident";
+constexpr StringLiteral StubSection = ".p2.overlay.stubs";
+constexpr StringLiteral EntrySection = ".p2.xdata.ro.overlay.entries";
+constexpr StringLiteral BodySectionPrefix = ".p2.overlay.body.";
+constexpr StringLiteral AutoBodySectionPrefix = ".p2.overlay.auto.";
+constexpr StringLiteral BodyNamePrefix = "__p2_ovlbody.";
+constexpr StringLiteral EntryNamePrefix = "__p2_ovlentry.";
+constexpr StringLiteral GroupRefNamePrefix = "__p2_overlay_groupref_";
+constexpr uint64_t P2ArchitecturalAddressLimit = UINT64_C(1) << 20;
+constexpr uint64_t P2PinnedLoaderLimit = UINT64_C(0x7c000);
+
+bool isIdentityToken(StringRef Value, bool AllowEmpty) {
+  if (Value.empty())
+    return AllowEmpty;
+  if (Value.size() > 64)
+    return false;
+
+  auto IsLowerAlnum = [](char C) {
+    return (C >= 'a' && C <= 'z') || (C >= '0' && C <= '9');
+  };
+  if (!IsLowerAlnum(Value.front()))
+    return false;
+  return llvm::all_of(Value.drop_front(), [&](char C) {
+    return IsLowerAlnum(C) || C == '.' || C == '_' || C == '-';
+  });
+}
+
+void updateIdentityField(SHA256 &Hasher, StringRef Value) {
+  std::array<uint8_t, 8> Length{};
+  uint64_t Size = Value.size();
+  for (unsigned I = 0; I != Length.size(); ++I)
+    Length[Length.size() - I - 1] = static_cast<uint8_t>(Size >> (I * 8));
+  Hasher.update(ArrayRef<uint8_t>(Length));
+  Hasher.update(Value);
+}
+
+std::string identityToken(StringRef Domain, ArrayRef<StringRef> Fields) {
+  SHA256 Hasher;
+  Hasher.update(Domain);
+  const uint8_t Separator = 0;
+  Hasher.update(ArrayRef<uint8_t>(&Separator, 1));
+  for (StringRef Field : Fields)
+    updateIdentityField(Hasher, Field);
+  return toHex(Hasher.final(), true);
+}
+
+struct Candidate {
+  Function *F;
+  uint32_t Group;
+  std::string AutoSection;
+  std::string GroupRef;
+};
+
+template <typename AttrOwner>
+bool clearDispatcherSensitiveAttrs(AttrOwner &Owner) {
+  bool Changed = false;
+  for (Attribute::AttrKind Kind :
+       {Attribute::ArgMemOnly, Attribute::InaccessibleMemOnly,
+        Attribute::InaccessibleMemOrArgMemOnly, Attribute::NoCallback,
+        Attribute::NoFree, Attribute::NoRecurse, Attribute::NoSync,
+        Attribute::ReadNone, Attribute::ReadOnly, Attribute::Speculatable,
+        Attribute::WillReturn}) {
+    if (!Owner.getAttributes().hasFnAttr(Kind))
+      continue;
+    Owner.removeFnAttr(Kind);
+    Changed = true;
+  }
+  return Changed;
+}
+
+class P2HubOverlay final : public ModulePass {
+public:
+  static char ID;
+
+  P2HubOverlay() : ModulePass(ID) {}
+
+  StringRef getPassName() const override {
+    return "P2 Hub Overlay Veneer Lowering";
+  }
+
+  bool runOnModule(Module &M) override;
+
+private:
+  [[noreturn]] void fail(const Twine &Reason) const;
+  Optional<uint32_t> explicitGroup(const Function &F) const;
+  uint32_t automaticGroup(const Function &F, const Module &M) const;
+  std::string canonicalLinkSource(const Module &M) const;
+  void assignLinkSections(StringRef CanonicalSource,
+                          SmallVectorImpl<Candidate> &Candidates) const;
+  Optional<std::string> unsafeReason(const Function &F, const Module &M) const;
+  bool isCtorOrDtor(const Function &F, const Module &M) const;
+  bool hasBlockAddress(const Function &F) const;
+  bool hasIFuncUse(const Function &F, const Module &M) const;
+  Function *transform(Module &M, const Candidate &C,
+                      unsigned Ordinal) const;
+  void rewriteKnownSameGroupCalls(
+      ArrayRef<Candidate> Candidates,
+      const DenseMap<const Function *, Function *> &StubBodies,
+      const DenseMap<const Function *, uint32_t> &StubGroups) const;
+  std::string groupSection(uint32_t Group) const;
+};
+
+} // end anonymous namespace
+
+char P2HubOverlay::ID = 0;
+
+static RegisterPass<P2HubOverlay>
+    X("p2-hub-overlay", "P2 Hub Overlay Veneer Lowering", false, false);
+
+[[noreturn]] void P2HubOverlay::fail(const Twine &Reason) const {
+  std::string Message;
+  raw_string_ostream OS(Message);
+  OS << "P2 Hub overlay lowering failed: " << Reason;
+  OS.flush();
+  report_fatal_error(StringRef(Message), false);
+}
+
+Optional<uint32_t> P2HubOverlay::explicitGroup(const Function &F) const {
+  Attribute A = F.getFnAttribute(OverlayGroupAttr);
+  if (!A.isValid())
+    return None;
+
+  StringRef Value = A.getValueAsString();
+  uint64_t Group = 0;
+  if (Value.empty() || Value.getAsInteger(0, Group) || Group == 0 ||
+      Group > std::numeric_limits<uint32_t>::max())
+    fail(Twine("function '") + F.getName() +
+         "' has invalid p2-hub-overlay-group '" + Value + "'");
+  return static_cast<uint32_t>(Group);
+}
+
+uint32_t P2HubOverlay::automaticGroup(const Function &F,
+                                      const Module &M) const {
+  StringRef Source = M.getSourceFileName();
+  if (Source.empty())
+    Source = M.getModuleIdentifier();
+  StringRef Leaf = sys::path::filename(Source);
+  std::string Key = Leaf.str();
+  Key.push_back('\0');
+  Key.append(F.getName().begin(), F.getName().end());
+  return static_cast<uint32_t>(MD5Hash(Key) % P2HubOverlayAutoGroups) + 1;
+}
+
+std::string P2HubOverlay::canonicalLinkSource(const Module &M) const {
+  StringRef Source = M.getSourceFileName();
+  if (Source.empty())
+    fail("link-assigned grouping requires a nonempty module source filename");
+  if (Source == "-" || Source.startswith("<"))
+    fail(Twine("link-assigned module source filename '") + Source +
+         "' is not a filesystem path");
+
+  SmallString<256> Root(P2HubOverlaySourceRoot);
+  if (!sys::path::is_absolute(Root))
+    fail("-p2-hub-overlay-source-root must be an absolute path");
+  sys::path::remove_dots(Root, true);
+
+  SmallString<256> AbsoluteSource;
+  if (sys::path::is_absolute(Source)) {
+    AbsoluteSource.assign(Source.begin(), Source.end());
+  } else {
+    AbsoluteSource = Root;
+    sys::path::append(AbsoluteSource, Source);
+  }
+  sys::path::remove_dots(AbsoluteSource, true);
+
+  // Compare path components instead of a string prefix: /src must not own
+  // /src-other.  This is deliberately lexical.  Resolving the current
+  // directory, filesystem existence, or symlinks would reintroduce checkout
+  // and host dependence into the identity.
+  auto RootI = sys::path::begin(Root);
+  auto RootE = sys::path::end(Root);
+  auto SourceI = sys::path::begin(AbsoluteSource);
+  auto SourceE = sys::path::end(AbsoluteSource);
+  for (; RootI != RootE; ++RootI, ++SourceI) {
+    if (SourceI == SourceE)
+      fail(Twine("module source '") + Source +
+           "' is outside -p2-hub-overlay-source-root '" +
+           P2HubOverlaySourceRoot + "'");
+#if defined(_WIN32)
+    bool Same = SourceI->equals_insensitive(*RootI);
+#else
+    bool Same = *SourceI == *RootI;
+#endif
+    if (!Same)
+      fail(Twine("module source '") + Source +
+           "' is outside -p2-hub-overlay-source-root '" +
+           P2HubOverlaySourceRoot + "'");
+  }
+  if (SourceI == SourceE)
+    fail(Twine("module source '") + Source +
+         "' does not name a file beneath -p2-hub-overlay-source-root");
+
+  SmallString<256> Relative;
+  sys::path::append(Relative, SourceI, SourceE);
+  std::string Canonical = sys::path::convert_to_slash(Relative);
+  if (Canonical.empty() || sys::path::is_absolute(Canonical))
+    fail(Twine("cannot derive a root-relative identity for module source '") +
+         Source + "'");
+  for (StringRef Component : llvm::make_range(sys::path::begin(Canonical),
+                                               sys::path::end(Canonical))) {
+    if (Component.empty() || Component == "." || Component == "..")
+      fail(Twine("module source '") + Source +
+           "' has a noncanonical root-relative identity");
+  }
+  return Canonical;
+}
+
+void P2HubOverlay::assignLinkSections(
+    StringRef CanonicalSource, SmallVectorImpl<Candidate> &Candidates) const {
+  SmallVector<unsigned, 64> Automatic;
+  DenseMap<const Function *, unsigned> CandidateIndex;
+  for (unsigned I = 0; I != Candidates.size(); ++I) {
+    if (Candidates[I].Group != 0)
+      continue;
+    CandidateIndex[Candidates[I].F] = Automatic.size();
+    Automatic.push_back(I);
+  }
+  if (Automatic.empty())
+    return;
+
+  // Preserve direct-call affinity within each independently compiled module.
+  // The final linker knows exact section sizes but not the optimized IR call
+  // graph, so encode a deterministic heavy-edge DFS order in the section
+  // names.  Public entry points are considered before private helpers and the
+  // most frequently referenced local callees are visited first.
+
+  SmallVector<DenseMap<unsigned, unsigned>, 64> EdgeCounts(Automatic.size());
+  SmallVector<unsigned, 64> Incoming(Automatic.size(), 0);
+  for (unsigned Local = 0; Local != Automatic.size(); ++Local) {
+    Function *F = Candidates[Automatic[Local]].F;
+    for (const Instruction &I : instructions(F)) {
+      const auto *Call = dyn_cast<CallBase>(&I);
+      if (!Call || Call->isInlineAsm())
+        continue;
+      const Value *Called = Call->getCalledOperand()->stripPointerCasts();
+      const auto *Callee = dyn_cast<Function>(Called);
+      auto Found = Callee ? CandidateIndex.find(Callee) : CandidateIndex.end();
+      if (Found == CandidateIndex.end())
+        continue;
+      unsigned Target = Found->second;
+      ++EdgeCounts[Local][Target];
+      ++Incoming[Target];
+    }
+  }
+
+  SmallVector<SmallVector<std::pair<unsigned, unsigned>, 8>, 64> Edges;
+  Edges.resize(Automatic.size());
+  for (unsigned Local = 0; Local != Automatic.size(); ++Local) {
+    for (const auto &Edge : EdgeCounts[Local])
+      Edges[Local].push_back({Edge.first, Edge.second});
+    llvm::sort(Edges[Local], [&](const auto &LHS, const auto &RHS) {
+      if (LHS.second != RHS.second)
+        return LHS.second > RHS.second;
+      return Candidates[Automatic[LHS.first]].F->getName() <
+             Candidates[Automatic[RHS.first]].F->getName();
+    });
+  }
+
+  SmallVector<unsigned, 64> Roots;
+  for (unsigned I = 0; I != Automatic.size(); ++I)
+    Roots.push_back(I);
+  llvm::sort(Roots, [&](unsigned LHS, unsigned RHS) {
+    const Function *LF = Candidates[Automatic[LHS]].F;
+    const Function *RF = Candidates[Automatic[RHS]].F;
+    bool LPublic = !LF->hasLocalLinkage();
+    bool RPublic = !RF->hasLocalLinkage();
+    if (LPublic != RPublic)
+      return LPublic > RPublic;
+    if (Incoming[LHS] != Incoming[RHS])
+      return Incoming[LHS] > Incoming[RHS];
+    return LF->getName() < RF->getName();
+  });
+
+  std::array<StringRef, 3> TUFields = {
+      P2HubOverlaySourceNamespace, P2HubOverlaySourceVariant, CanonicalSource};
+  std::string TUToken = identityToken("p2-hub-overlay-tu-v1", TUFields);
+  SmallVector<bool, 64> Visited(Automatic.size(), false);
+  unsigned Order = 0;
+  std::function<void(unsigned)> Visit = [&](unsigned Local) {
+    if (Visited[Local])
+      return;
+    Visited[Local] = true;
+    Candidate &C = Candidates[Automatic[Local]];
+
+    std::array<StringRef, 2> FunctionFields = {TUToken, C.F->getName()};
+    std::string FunctionToken =
+        identityToken("p2-hub-overlay-function-v1", FunctionFields);
+
+    raw_string_ostream SectionOS(C.AutoSection);
+    SectionOS << AutoBodySectionPrefix << TUToken << "."
+              << format_hex_no_prefix(Order++, 8, false) << "."
+              << FunctionToken;
+    SectionOS.flush();
+
+    raw_string_ostream RefOS(C.GroupRef);
+    RefOS << GroupRefNamePrefix << TUToken << "_" << FunctionToken;
+    RefOS.flush();
+
+    for (const auto &Edge : Edges[Local])
+      Visit(Edge.first);
+  };
+  for (unsigned Root : Roots)
+    Visit(Root);
+}
+
+bool P2HubOverlay::hasBlockAddress(const Function &F) const {
+  for (const User *U : F.users()) {
+    if (isa<BlockAddress>(U))
+      return true;
+    if (const auto *C = dyn_cast<Constant>(U)) {
+      SmallVector<const Constant *, 8> Worklist(1, C);
+      SmallPtrSet<const Constant *, 16> Seen;
+      while (!Worklist.empty()) {
+        const Constant *Current = Worklist.pop_back_val();
+        if (!Seen.insert(Current).second)
+          continue;
+        if (isa<BlockAddress>(Current))
+          return true;
+        for (const User *Nested : Current->users())
+          if (const auto *NestedConstant = dyn_cast<Constant>(Nested))
+            Worklist.push_back(NestedConstant);
+      }
+    }
+  }
+  return false;
+}
+
+bool P2HubOverlay::hasIFuncUse(const Function &F, const Module &M) const {
+  for (const GlobalIFunc &IFunc : M.ifuncs()) {
+    const Constant *Resolver = IFunc.getResolver();
+    if (Resolver && Resolver->stripPointerCasts() == &F)
+      return true;
+  }
+  return false;
+}
+
+bool P2HubOverlay::isCtorOrDtor(const Function &F, const Module &M) const {
+  for (StringRef Name : {"llvm.global_ctors", "llvm.global_dtors"}) {
+    const GlobalVariable *List = M.getNamedGlobal(Name);
+    if (!List || !List->hasInitializer())
+      continue;
+    const auto *Array = dyn_cast<ConstantArray>(List->getInitializer());
+    if (!Array)
+      continue;
+    for (const Use &ElementUse : Array->operands()) {
+      const auto *Element = dyn_cast<ConstantStruct>(ElementUse.get());
+      if (!Element || Element->getNumOperands() < 2)
+        continue;
+      const Value *Callee = Element->getOperand(1)->stripPointerCasts();
+      if (Callee == &F)
+        return true;
+    }
+  }
+  return false;
+}
+
+Optional<std::string> P2HubOverlay::unsafeReason(const Function &F,
+                                                 const Module &M) const {
+  if (F.hasFnAttribute(Attribute::Naked))
+    return std::string("is already naked");
+  if (F.hasFnAttribute("interrupt") || F.hasFnAttribute("interrupt-handler"))
+    return std::string("is an interrupt handler");
+  if (F.hasFnAttribute(Attribute::ReturnsTwice))
+    return std::string("returns twice");
+  // Function::hasAddressTaken() deliberately does not classify a
+  // blockaddress as taking the function's callable address.  Check the use
+  // graph independently: moving the containing basic block would otherwise
+  // leave the blockaddress relocation attached to the resident veneer.
+  if (hasBlockAddress(F))
+    return std::string("has a blockaddress/code-label use");
+  if (hasIFuncUse(F, M))
+    return std::string("is used as an ELF ifunc resolver");
+  if (F.hasPrefixData() || F.hasPrologueData())
+    return std::string("has ABI prefix/prologue data");
+  if (MaybeAlign Alignment = F.getAlign())
+    if (Alignment->value() > 4)
+      return std::string(
+          "requires function alignment incompatible with packed veneers");
+  if (F.hasPersonalityFn())
+    return std::string(
+        "uses exception unwinding not tracked by the overlay shadow stack");
+  if (F.hasComdat())
+    return std::string("belongs to a COMDAT group");
+  if (F.hasAvailableExternallyLinkage() || F.hasAppendingLinkage() ||
+      F.hasCommonLinkage() || F.isInterposable())
+    return std::string("has replaceable or non-emitted linkage");
+  if (F.getName().startswith("__p2_overlay_") ||
+      F.getName().startswith("p2_overlay_"))
+    return std::string("is part of the resident overlay runtime");
+  if (F.getName() == "_start" || F.getName() == "__start" ||
+      F.getName() == "__entry" || F.getName() == "main")
+    return std::string("is a process/bootstrap entry point");
+  if (F.hasFnAttribute(Attribute::Cogtext) ||
+      F.hasFnAttribute(Attribute::Cogmain))
+    return std::string("uses a P2 COG/LUT execution ABI");
+  if (isCtorOrDtor(F, M))
+    return std::string("runs before or during overlay runtime lifetime");
+
+  StringRef Section = F.getSection();
+  if (!Section.empty() &&
+      (Section.startswith(".p2.entry") || Section.startswith(".p2.cog") ||
+       Section.startswith(".p2.lut") || Section.startswith(".init") ||
+       Section.startswith(".fini")))
+    return std::string("is assigned to a resident/startup section");
+
+  for (const Instruction &I : instructions(F)) {
+    if (isa<InvokeInst>(I) || isa<ResumeInst>(I) || isa<CleanupReturnInst>(I) ||
+        isa<CatchReturnInst>(I))
+      return std::string("contains exception control flow not tracked by the "
+                         "overlay shadow stack");
+    const auto *Call = dyn_cast<CallBase>(&I);
+    if (!Call || Call->isInlineAsm())
+      continue;
+    const Function *Callee = Call->getCalledFunction();
+    if (!Callee)
+      continue;
+    StringRef Name = Callee->getName();
+    if (Callee->hasFnAttribute(Attribute::ReturnsTwice) || Name == "setjmp" ||
+        Name == "_setjmp" || Name == "sigsetjmp" || Name == "longjmp" ||
+        Name == "_longjmp" || Name == "siglongjmp")
+      return std::string("uses setjmp/longjmp control flow not tracked by the "
+                         "overlay shadow stack");
+  }
+  return None;
+}
+
+std::string P2HubOverlay::groupSection(uint32_t Group) const {
+  std::string Name;
+  raw_string_ostream OS(Name);
+  OS << BodySectionPrefix << format_hex_no_prefix(Group, 8, false);
+  OS.flush();
+  return Name;
+}
+
+Function *P2HubOverlay::transform(Module &M, const Candidate &C,
+                                  unsigned Ordinal) const {
+  Function *Body = C.F;
+  LLVMContext &Context = M.getContext();
+  std::string PublicName = Body->getName().str();
+  GlobalValue::LinkageTypes Linkage = Body->getLinkage();
+  GlobalValue::VisibilityTypes Visibility = Body->getVisibility();
+  GlobalValue::DLLStorageClassTypes DLLStorage = Body->getDLLStorageClass();
+  GlobalValue::UnnamedAddr UnnamedAddr = Body->getUnnamedAddr();
+  bool DSOLocal = Body->isDSOLocal();
+
+  std::string Suffix = (Twine(Ordinal) + "." + PublicName).str();
+  Body->setName((BodyNamePrefix + Suffix).str());
+
+  Function *Stub = Function::Create(Body->getFunctionType(), Linkage,
+                                    Body->getAddressSpace(), PublicName, &M);
+  Stub->copyAttributesFrom(Body);
+  Stub->setCallingConv(Body->getCallingConv());
+  Stub->setVisibility(Visibility);
+  Stub->setDLLStorageClass(DLLStorage);
+  Stub->setUnnamedAddr(UnnamedAddr);
+  Stub->setDSOLocal(DSOLocal);
+  Stub->setSection(StubSection);
+  Stub->setAlignment(Align(4));
+  Stub->removeFnAttr(Attribute::AlwaysInline);
+  Stub->removeFnAttr(Attribute::InlineHint);
+  Stub->removeFnAttr(Attribute::OptimizeNone);
+  Stub->removeFnAttr(OverlayGroupAttr);
+  Stub->addFnAttr(ResidentAttr);
+  Stub->addFnAttr(Attribute::Naked);
+  Stub->addFnAttr(Attribute::NoInline);
+  Stub->addFnAttr(Attribute::NoUnwind);
+
+  BasicBlock *Entry = BasicBlock::Create(Context, "entry", Stub);
+  IRBuilder<> Builder(Entry);
+  FunctionType *AsmTy = FunctionType::get(Builder.getVoidTy(), false);
+  InlineAsm *Enter =
+      InlineAsm::get(AsmTy, "calla #\\__p2_overlay_enter", "", true);
+  Builder.CreateCall(Enter);
+  Builder.CreateUnreachable();
+
+  // All existing calls, recursive references, aliases and function-pointer
+  // constants now identify the original public symbol, which is the veneer.
+  // The entry descriptor is intentionally created only after this RAUW so its
+  // body relocation remains private to the overlay implementation.  Its
+  // explicit .p2.xdata.ro section makes the immutable descriptor external
+  // even without blanket data externalization.
+  Body->replaceAllUsesWith(Stub);
+
+  Body->setLinkage(GlobalValue::InternalLinkage);
+  Body->setVisibility(GlobalValue::DefaultVisibility);
+  Body->setDLLStorageClass(GlobalValue::DefaultStorageClass);
+  Body->setUnnamedAddr(GlobalValue::UnnamedAddr::None);
+  Body->setDSOLocal(true);
+  Body->setSection(C.Group != 0 ? groupSection(C.Group) : C.AutoSection);
+  Body->setAlignment(Align(4));
+  Body->removeFnAttr(OverlayGroupAttr);
+  Body->removeFnAttr(Attribute::AlwaysInline);
+  Body->removeFnAttr(Attribute::InlineHint);
+  Body->addFnAttr(ResidentAttr);
+  Body->addFnAttr(Attribute::NoInline);
+  for (Instruction &I : instructions(Body))
+    if (auto *Call = dyn_cast<CallInst>(&I))
+      Call->setTailCallKind(CallInst::TCK_None);
+
+  IntegerType *I32 = Builder.getInt32Ty();
+  Constant *BodyAddress = ConstantExpr::getPtrToInt(Body, I32);
+  Constant *EntryOffset = ConstantExpr::getSub(
+      BodyAddress, ConstantInt::get(I32, P2HubOverlaySlotAddress));
+  StructType *EntryTy = StructType::get(I32, I32);
+  Constant *GroupValue;
+  if (C.Group != 0) {
+    GroupValue = ConstantInt::get(I32, C.Group);
+  } else {
+    if (C.GroupRef.empty())
+      fail(Twine("automatic function '") + PublicName +
+           "' lacks a link-assigned group reference");
+    if (M.getNamedValue(C.GroupRef))
+      fail(Twine("duplicate link-assigned group reference '") + C.GroupRef +
+           "'");
+    auto *GroupRef = new GlobalVariable(
+        M, Builder.getInt8Ty(), true, GlobalValue::ExternalLinkage, nullptr,
+        C.GroupRef);
+    GroupValue = ConstantExpr::getPtrToInt(GroupRef, I32);
+  }
+  Constant *Initializer =
+      ConstantStruct::get(EntryTy, GroupValue, EntryOffset);
+  auto *Descriptor =
+      new GlobalVariable(M, EntryTy, true, GlobalValue::InternalLinkage,
+                         Initializer, (EntryNamePrefix + Suffix).str());
+  Descriptor->setSection(EntrySection);
+  Descriptor->setAlignment(Align(8));
+
+  // llvm.compiler.used keeps the descriptor paired with the veneer even
+  // under --gc-sections.  The veneer itself retains ordinary symbol liveness.
+  appendToCompilerUsed(M, {Descriptor});
+  return Stub;
+}
+
+void P2HubOverlay::rewriteKnownSameGroupCalls(
+    ArrayRef<Candidate> Candidates,
+    const DenseMap<const Function *, Function *> &StubBodies,
+    const DenseMap<const Function *, uint32_t> &StubGroups) const {
+  // An implementation can call another implementation directly when both
+  // definitions are in this module and carry the same explicit group.  The
+  // caller itself proves that image is resident, so entering the public
+  // veneer would add dispatcher work without providing a load or safety
+  // transition.  Keep every other use on the veneer: cross-group calls,
+  // link-assigned groups, aliases, function pointers, and calls whose body is
+  // owned by another translation unit retain the complete runtime ABI.
+
+  for (const Candidate &Caller : Candidates) {
+    if (Caller.Group == 0)
+      continue;
+    for (Instruction &I : instructions(Caller.F)) {
+      auto *Call = dyn_cast<CallBase>(&I);
+      if (!Call || Call->isInlineAsm())
+        continue;
+      Value *Called = Call->getCalledOperand();
+      const auto *Stub =
+          dyn_cast<Function>(Called->stripPointerCasts());
+      if (!Stub)
+        continue;
+      auto Group = StubGroups.find(Stub);
+      auto Body = StubBodies.find(Stub);
+      if (Group == StubGroups.end() || Body == StubBodies.end() ||
+          Group->second != Caller.Group)
+        continue;
+      Value *Direct = Body->second;
+      if (Direct->getType() != Called->getType())
+        Direct = ConstantExpr::getPointerBitCastOrAddrSpaceCast(
+            cast<Constant>(Direct), Called->getType());
+      Call->setCalledOperand(Direct);
+      Call->setMetadata(LLVMContext::MD_prof, nullptr);
+      Call->setMetadata(LLVMContext::MD_callees, nullptr);
+    }
+  }
+}
+
+bool P2HubOverlay::runOnModule(Module &M) {
+  if (!EnableP2HubOverlays) {
+    if (P2HubOverlayAll)
+      fail("-p2-hub-overlays-all requires -p2-hub-overlays");
+    if (P2HubOverlayLinkAssigned)
+      fail("-p2-hub-overlay-link-assigned requires -p2-hub-overlays");
+    if (!P2HubOverlaySourceRoot.empty() ||
+        !P2HubOverlaySourceNamespace.empty() ||
+        !P2HubOverlaySourceVariant.empty())
+      fail("link-assigned source identity options require "
+           "-p2-hub-overlay-link-assigned");
+    return false;
+  }
+
+  if (M.getTargetTriple().empty() ||
+      Triple(M.getTargetTriple()).getArch() != Triple::p2)
+    fail("overlay lowering is only valid for a P2 target module");
+  if (P2HubOverlaySlotAddress == 0 || (P2HubOverlaySlotAddress & 3) != 0 ||
+      P2HubOverlaySlotAddress >= P2ArchitecturalAddressLimit ||
+      P2HubOverlaySlotAddress >= P2PinnedLoaderLimit)
+    fail("-p2-hub-overlay-slot-address must be a four-byte-aligned, nonzero "
+         "Hub address below 0x7c000");
+  if (P2HubOverlayAll && P2HubOverlayDefaultGroup == 0 &&
+      P2HubOverlayAutoGroups == 0 && !P2HubOverlayLinkAssigned)
+    fail("-p2-hub-overlays-all requires either a nonzero "
+         "-p2-hub-overlay-group, -p2-hub-overlay-auto-groups, or "
+         "-p2-hub-overlay-link-assigned");
+  unsigned AutomaticModes = (P2HubOverlayDefaultGroup != 0) +
+                            (P2HubOverlayAutoGroups != 0) +
+                            (P2HubOverlayLinkAssigned ? 1 : 0);
+  if (AutomaticModes > 1)
+    fail("-p2-hub-overlay-group, -p2-hub-overlay-auto-groups, and "
+         "-p2-hub-overlay-link-assigned are mutually exclusive");
+  if (P2HubOverlayLinkAssigned && !P2HubOverlayAll)
+    fail("-p2-hub-overlay-link-assigned requires -p2-hub-overlays-all");
+  if (P2HubOverlayLinkAssigned) {
+    if (P2HubOverlaySourceRoot.empty())
+      fail("-p2-hub-overlay-link-assigned requires "
+           "-p2-hub-overlay-source-root");
+    if (!sys::path::is_absolute(P2HubOverlaySourceRoot))
+      fail("-p2-hub-overlay-source-root must be an absolute path");
+    if (!isIdentityToken(P2HubOverlaySourceNamespace, false))
+      fail("-p2-hub-overlay-source-namespace must match "
+           "[a-z0-9][a-z0-9._-]{0,63}");
+    if (!isIdentityToken(P2HubOverlaySourceVariant, true))
+      fail("-p2-hub-overlay-source-variant must be empty or match "
+           "[a-z0-9][a-z0-9._-]{0,63}");
+  } else if (!P2HubOverlaySourceRoot.empty() ||
+             !P2HubOverlaySourceNamespace.empty() ||
+             !P2HubOverlaySourceVariant.empty()) {
+    fail("link-assigned source identity options require "
+         "-p2-hub-overlay-link-assigned");
+  }
+
+  std::string CanonicalSource;
+  if (P2HubOverlayLinkAssigned)
+    CanonicalSource = canonicalLinkSource(M);
+
+  SmallVector<Candidate, 64> Candidates;
+  SmallVector<std::pair<std::string, std::string>, 16> KeptResident;
+  for (Function &F : M) {
+    Optional<uint32_t> ExplicitGroup = explicitGroup(F);
+    bool Explicit = ExplicitGroup.hasValue();
+    if (F.hasFnAttribute(ResidentAttr)) {
+      if (Explicit)
+        fail(Twine("function '") + F.getName() +
+             "' is both p2-hub-resident and p2-hub-overlay-group");
+      continue;
+    }
+    // An overlay attribute is commonly placed on a public header
+    // declaration.  The inheritable Clang attribute reaches the definition
+    // in its owning translation unit; declarations in unrelated modules do
+    // not emit code and therefore require no transformation.
+    if (F.isDeclaration() || F.isIntrinsic())
+      continue;
+    if (!Explicit && !P2HubOverlayAll)
+      continue;
+
+    uint32_t Group = Explicit
+                         ? *ExplicitGroup
+                         : (P2HubOverlayLinkAssigned
+                                ? 0
+                                : (P2HubOverlayAutoGroups != 0
+                                       ? automaticGroup(F, M)
+                                       : P2HubOverlayDefaultGroup));
+    if (Optional<std::string> Reason = unsafeReason(F, M)) {
+      if (Explicit)
+        fail(Twine("explicit function '") + F.getName() + "' " + *Reason);
+      if (!F.isDeclaration() && !F.isIntrinsic())
+        KeptResident.emplace_back(F.getName().str(), std::move(*Reason));
+      continue;
+    }
+    Candidates.push_back({&F, Group, std::string(), std::string()});
+  }
+
+  if (P2HubOverlayLinkAssigned)
+    assignLinkSections(CanonicalSource, Candidates);
+
+  for (const auto &Skipped : KeptResident)
+    errs() << "P2 Hub overlay: keeping '" << Skipped.first
+           << "' resident because it " << Skipped.second << "\n";
+  if (!KeptResident.empty())
+    errs() << "P2 Hub overlay: kept " << KeptResident.size()
+           << " unsafe definition(s) resident in overlay-all mode\n";
+
+  DenseMap<const Function *, Function *> StubBodies;
+  DenseMap<const Function *, uint32_t> StubGroups;
+  unsigned Ordinal = 0;
+  for (const Candidate &C : Candidates) {
+    Function *Stub = transform(M, C, Ordinal++);
+    StubBodies[Stub] = C.F;
+    if (C.Group != 0)
+      StubGroups[Stub] = C.Group;
+  }
+  rewriteKnownSameGroupCalls(Candidates, StubBodies, StubGroups);
+
+  // Entering an overlay can copy an image, synchronize with the resident
+  // loader, invoke its callback and dynamically recurse through another
+  // group.  Those hidden effects invalidate purity/speculation attributes
+  // that were inferred for the original body or copied onto a veneer.  They
+  // also make every tail-call marker unsafe: an external or indirect target
+  // in another translation unit may be an overlay even when this module has
+  // only a declaration.  This pass is deliberately late, so clearing the
+  // attributes globally is conservative without reopening IR optimization.
+  bool Changed = !Candidates.empty();
+  for (Function &F : M) {
+    Changed |= clearDispatcherSensitiveAttrs(F);
+    for (Instruction &I : instructions(F)) {
+      auto *Call = dyn_cast<CallBase>(&I);
+      if (!Call || Call->isInlineAsm())
+        continue;
+      Changed |= clearDispatcherSensitiveAttrs(*Call);
+      if (auto *DirectCall = dyn_cast<CallInst>(Call)) {
+        if (DirectCall->isTailCall()) {
+          DirectCall->setTailCallKind(CallInst::TCK_None);
+          Changed = true;
+        }
+      }
+    }
+  }
+  return Changed;
+}
+
+ModulePass *llvm::createP2HubOverlayPass() { return new P2HubOverlay(); }
