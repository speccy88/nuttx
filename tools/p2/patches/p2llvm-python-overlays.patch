+/* Minimal resident-layout owner used to syntax/link-test the composable P2
+ * overlay fragment.  The production NuttX script defines these same slot
+ * symbols while also owning the Hub memory region and resident metadata.
+ */
+__p2_overlay_slot_start = 0x00050000;
+__p2_overlay_slot_end = 0x00060000;
+
+SECTIONS
+{
+  . = 0x00001000;
+  .text : { *(.text .text.*) }
+  .rodata : { *(.rodata .rodata.*) }
+  .data : { *(.data .data.*) }
+  .bss (NOLOAD) : { *(.bss .bss.*) *(COMMON) }
+  .p2.overlay.stubs : ALIGN(4) { KEEP(*(.p2.overlay.stubs)) }
+  .p2.xdata 0x10000000 : AT(0x02000000)
+  {
+    KEEP(*(.p2.xdata.ro.overlay.entries))
+  }
+}
diff --git a/llvm/test/CodeGen/P2/atomic-fence.ll b/llvm/test/CodeGen/P2/atomic-fence.ll
new file mode 100644
index 0000000000000000000000000000000000000000..1aa2f1b61ddfe96bacf0eeaf97900e97317f25c0
--- /dev/null
+++ b/llvm/test/CodeGen/P2/atomic-fence.ll
@@ -0,0 +1,24 @@
+; RUN: llc -march=p2 -o - < %s | FileCheck %s
+;
+; P2 Hub transactions are issued in program order, without a data cache or
+; write buffer.  Fences therefore remain SelectionDAG chain barriers but do
+; not require a target instruction.
+
+define void @seq_cst_fence(i32* %before, i32* %after) {
+; CHECK-LABEL: seq_cst_fence:
+; CHECK:       wrlong
+; CHECK-NOT:   call
+; CHECK:       rdlong
+; CHECK:       reta
+  store volatile i32 1, i32* %before
+  fence seq_cst
+  %value = load volatile i32, i32* %after
+  ret void
+}
+
+define void @acquire_fence() {
+; CHECK-LABEL: acquire_fence:
+; CHECK:       reta
+  fence acquire
+  ret void
+}
diff --git a/llvm/test/CodeGen/P2/external-data-only.ll b/llvm/test/CodeGen/P2/external-data-only.ll
new file mode 100644
index 0000000000000000000000000000000000000000..a32b9b83e34360b7216d74ed57521a1d0d4c6d67
--- /dev/null
+++ b/llvm/test/CodeGen/P2/external-data-only.ll
@@ -0,0 +1,16 @@
+; RUN: llc -march=p2 -p2-unified-memory -p2-externalize-data -filetype=obj -o - < %s | llvm-readobj --sections - | FileCheck %s
+; RUN: llc -march=p2 -p2-unified-memory -p2-externalize-constant-data -filetype=obj -o - < %s | llvm-readobj --sections - | FileCheck %s --check-prefix=CONSTANT
+
+; Module initialization must externalize storage even when a translation unit
+; contains no function for this FunctionPass to visit.
+
+@only_initialized_data = global i32 42, align 4
+@only_zero_data = global [16 x i8] zeroinitializer, align 4
+@only_constant_data = constant i32 43, align 4
+
+; CHECK-DAG: Name: .p2.xdata
+; CHECK: Name: .p2.xbss
+; CHECK-NEXT: Type: SHT_NOBITS
+; CONSTANT: Name: .p2.xdata.ro
+; CONSTANT-NOT: Name: .p2.xdata
+; CONSTANT-NOT: Name: .p2.xbss
diff --git a/llvm/test/CodeGen/P2/external-data-undef.ll b/llvm/test/CodeGen/P2/external-data-undef.ll
new file mode 100644
index 0000000000000000000000000000000000000000..63a672144d9859de476a0c1146826a39a5d5d353
--- /dev/null
+++ b/llvm/test/CodeGen/P2/external-data-undef.ll
@@ -0,0 +1,41 @@
+; RUN: llc -march=p2 -p2-unified-memory -p2-externalize-data -filetype=obj -o %t.o < %s
+; RUN: llvm-readobj --hex-dump=.p2.xdata.scalar-undef %t.o | FileCheck %s --check-prefix=SCALAR-UNDEF
+; RUN: llvm-readobj --hex-dump=.p2.xdata.scalar-poison %t.o | FileCheck %s --check-prefix=SCALAR-POISON
+; RUN: llvm-readobj --hex-dump=.p2.xdata.aggregate %t.o | FileCheck %s --check-prefix=AGGREGATE
+; RUN: llvm-readobj --sections %t.o | FileCheck %s --check-prefix=XBSS
+
+; Undefined initializer leaves represent unspecified source-language bytes.
+; The external-data pass must choose a stable value for them because these
+; section images are copied verbatim into PSRAM.  Zero is deterministic and
+; also lets an explicitly placed all-undefined xbss object remain NOBITS.
+
+%padded = type { i8, i32, [3 x i16], <4 x i8> }
+
+@scalar_undef = global i32 undef, section ".p2.xdata.scalar-undef", align 4
+@scalar_poison = global i32 poison, section ".p2.xdata.scalar-poison", align 4
+@aggregate = global %padded {
+  i8 90,
+  i32 undef,
+  [3 x i16] [i16 4386, i16 poison, i16 13124],
+  <4 x i8> <i8 85, i8 undef, i8 119, i8 poison>
+}, section ".p2.xdata.aggregate", align 4
+@undefined_bss = global [8 x i8] undef, section ".p2.xbss.undefined", align 4
+
+; SCALAR-UNDEF: Hex dump of section '.p2.xdata.scalar-undef':
+; SCALAR-UNDEF-NEXT: 0x00000000 00000000
+
+; SCALAR-POISON: Hex dump of section '.p2.xdata.scalar-poison':
+; SCALAR-POISON-NEXT: 0x00000000 00000000
+
+; The expected zeros cover the undefined i32, undefined aggregate elements,
+; and the ABI padding after i8 and before the vector.
+; AGGREGATE: Hex dump of section '.p2.xdata.aggregate':
+; AGGREGATE-NEXT: 0x00000000 5a000000 00000000 22110000 44330000
+; AGGREGATE-NEXT: 0x00000010 55007700
+
+; XBSS: Name: .p2.xbss.undefined
+; XBSS-NEXT: Type: SHT_NOBITS
+
+define void @anchor() {
+  ret void
+}
diff --git a/llvm/test/CodeGen/P2/external-data-unsupported.ll b/llvm/test/CodeGen/P2/external-data-unsupported.ll
new file mode 100644
index 0000000000000000000000000000000000000000..4191a7956c1097730b1032055cbac2334aee75e6
--- /dev/null
+++ b/llvm/test/CodeGen/P2/external-data-unsupported.ll
@@ -0,0 +1,82 @@
+; RUN: split-file %s %t
+; RUN: not --crash llc -march=p2 -stop-after=p2-unified-memory-lowering -o /dev/null < %t/requires-unified.ll 2>&1 | FileCheck %s --check-prefix=REQUIRES-UNIFIED
+; RUN: not --crash llc -march=p2 -p2-externalize-constant-data -stop-after=p2-unified-memory-lowering -o /dev/null < %t/no-constants.ll 2>&1 | FileCheck %s --check-prefix=REQUIRES-UNIFIED
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/tls.ll 2>&1 | FileCheck %s --check-prefix=TLS
+; RUN: not --crash llc -march=p2 -p2-unified-memory -p2-externalize-data -stop-after=p2-unified-memory-lowering -o /dev/null < %t/common.ll 2>&1 | FileCheck %s --check-prefix=COMMON
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/weak.ll 2>&1 | FileCheck %s --check-prefix=WEAK
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/alias.ll 2>&1 | FileCheck %s --check-prefix=ALIAS
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/ifunc.ll 2>&1 | FileCheck %s --check-prefix=IFUNC
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/nonzero-xbss.ll 2>&1 | FileCheck %s --check-prefix=NONZERO-XBSS
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/address-space.ll 2>&1 | FileCheck %s --check-prefix=ADDRESS-SPACE
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/wide-relocation.ll 2>&1 | FileCheck %s --check-prefix=WIDE-RELOCATION
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/weak-relocation.ll 2>&1 | FileCheck %s --check-prefix=WEAK-RELOCATION
+; RUN: not --crash llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -o /dev/null < %t/blockaddress.ll 2>&1 | FileCheck %s --check-prefix=BLOCKADDRESS
+
+; REQUIRES-UNIFIED: LLVM ERROR: P2 external data requires -p2-unified-memory
+; TLS: LLVM ERROR: P2 external-data validation failed for '@tls': TLS storage is unsupported
+; COMMON: LLVM ERROR: P2 external-data validation failed for '@tentative': common linkage has no unique external-data owner
+; WEAK: LLVM ERROR: P2 external-data validation failed for '@replaceable': weak/linkonce linkage has no unique external-data owner
+; ALIAS: LLVM ERROR: P2 external-data validation failed for '@external_alias': aliases are unsupported in a module containing P2 external data
+; IFUNC: LLVM ERROR: P2 external-data validation failed for '@dispatch': ifuncs are unsupported in a module containing P2 external data
+; NONZERO-XBSS: LLVM ERROR: P2 external-data validation failed for '@not_bss': .p2.xbss sections require a zero initializer
+; ADDRESS-SPACE: LLVM ERROR: P2 external-data validation failed for '@wrong_space': nonzero global address spaces are unsupported
+; WIDE-RELOCATION: LLVM ERROR: P2 external-data validation failed for '@wide_pointer': pointer relocations stored as integers must be exactly 32 bits
+; WEAK-RELOCATION: LLVM ERROR: P2 external-data validation failed for '@weak_pointer': relocation against common/weak symbol '@weak_target' is ambiguous
+; BLOCKADDRESS: LLVM ERROR: P2 external-data validation failed for '@unsafe_block': blockaddress relocations are unsupported in external data
+
+;--- requires-unified.ll
+@external = global i32 0, section ".p2.xbss"
+define void @use() { ret void }
+
+;--- tls.ll
+@tls = thread_local global i32 0, section ".p2.xbss"
+define void @use() { ret void }
+
+;--- no-constants.ll
+define void @use() { ret void }
+
+;--- common.ll
+@tentative = common global i32 0, align 4
+define void @use() { ret void }
+
+;--- weak.ll
+@replaceable = weak global i32 1, section ".p2.xdata"
+define void @use() { ret void }
+
+;--- alias.ll
+@object = global i32 1, section ".p2.xdata"
+@external_alias = alias i32, i32* @object
+define void @use() { ret void }
+
+;--- ifunc.ll
+@object = global i32 1, section ".p2.xdata"
+@dispatch = ifunc void (), void ()* ()* @resolve
+define void ()* @resolve() { ret void ()* @implementation }
+define void @implementation() { ret void }
+
+;--- nonzero-xbss.ll
+@not_bss = global i32 1, section ".p2.xbss"
+define void @use() { ret void }
+
+;--- address-space.ll
+@wrong_space = addrspace(1) global i32 0, section ".p2.xbss"
+define void @use() { ret void }
+
+;--- wide-relocation.ll
+@target = global i32 0
+@wide_pointer = constant i64 ptrtoint (i32* @target to i64), section ".p2.xdata"
+define void @use() { ret void }
+
+;--- weak-relocation.ll
+@weak_target = extern_weak global i32
+@weak_pointer = constant i32* @weak_target, section ".p2.xdata"
+define void @use() { ret void }
+
+;--- blockaddress.ll
+@unsafe_block = constant i8* blockaddress(@target, %destination), section ".p2.xdata"
+define void @target() {
+entry:
+  br label %destination
+destination:
+  ret void
+}
diff --git a/llvm/test/CodeGen/P2/external-data.ll b/llvm/test/CodeGen/P2/external-data.ll
new file mode 100644
index 0000000000000000000000000000000000000000..cf3da28b5a76a653d7b5647a1c5a99bc474f941b
--- /dev/null
+++ b/llvm/test/CodeGen/P2/external-data.ll
@@ -0,0 +1,108 @@
+; RUN: llc -march=p2 -p2-unified-memory -stop-after=p2-unified-memory-lowering -print-after=p2-unified-memory-lowering -o /dev/null < %s 2>&1 | FileCheck %s --check-prefix=EXPLICIT
+; RUN: llc -march=p2 -p2-unified-memory -p2-externalize-data -stop-after=p2-unified-memory-lowering -print-after=p2-unified-memory-lowering -o /dev/null < %s 2>&1 | FileCheck %s --check-prefix=AUTO
+; RUN: llc -march=p2 -p2-unified-memory -p2-externalize-constant-data -stop-after=p2-unified-memory-lowering -print-after=p2-unified-memory-lowering -o /dev/null < %s 2>&1 | FileCheck %s --check-prefix=CONSTANT
+; RUN: llc -march=p2 -p2-unified-memory -p2-externalize-data -filetype=obj -o - < %s | llvm-readobj --sections - | FileCheck %s --check-prefix=SECTIONS
+; RUN: llc -march=p2 -p2-unified-memory -p2-externalize-data -filetype=obj -o - < %s | llvm-readobj --sections - | FileCheck %s --check-prefix=XBSS
+; RUN: llc -march=p2 -p2-unified-memory -p2-externalize-data -filetype=obj -o - < %s | llvm-readobj --relocations - | FileCheck %s --check-prefix=RELOCS
+
+%entry = type { i32*, i8* }
+
+@hub_word = global i32 1, align 4
+@resident_word = global i32 2, section ".p2.hub.data", align 4
+@explicit_word = global i32 3, section ".p2.xdata.user", align 4
+@explicit_bytes = global [8 x i8] zeroinitializer, section ".p2.xbss.user", align 4
+@reloc_table = constant %entry {
+  i32* @explicit_word,
+  i8* getelementptr inbounds ([8 x i8], [8 x i8]* @explicit_bytes,
+                              i32 0, i32 3)
+}, section ".p2.xdata.ro.relocs", align 4
+@auto_zero = global [12 x i8] zeroinitializer, align 4
+@auto_const = constant [4 x i8] c"P2\00\00", align 1
+@external_word = external global i32
+@external_const = external constant i32
+
+; SECTIONS-DAG: Name: .p2.xdata
+; SECTIONS-DAG: Name: .p2.xdata.user
+; SECTIONS-DAG: Name: .p2.xbss.user
+; SECTIONS-DAG: Name: .p2.xdata.ro.relocs
+; SECTIONS-DAG: Name: .p2.xbss
+; SECTIONS-DAG: Name: .p2.xdata.ro
+; SECTIONS-DAG: Name: .p2.hub.data
+
+; XBSS: Name: .p2.xbss.user
+; XBSS-NEXT: Type: SHT_NOBITS
+; XBSS: Name: .p2.xbss
+; XBSS-NEXT: Type: SHT_NOBITS
+
+; RELOCS: Section {{.*}} .rela.p2.xdata.ro.relocs {
+; RELOCS-DAG: R_P2_32 explicit_word 0x0
+; RELOCS-DAG: R_P2_32 explicit_bytes 0x3
+
+define i32 @explicit_access(i32 %value) {
+; EXPLICIT-LABEL: define i32 @explicit_access(
+; EXPLICIT: %external.raw = call i32 @__p2_xmem_load32(i8* bitcast (i32* @explicit_word to i8*))
+; EXPLICIT: call void @__p2_xmem_store32(i8* bitcast (i32* @explicit_word to i8*), i32 %value)
+; EXPLICIT: %hub = load i32, i32* @hub_word
+; EXPLICIT-NOT: @hub_word to i8*
+; EXPLICIT: ret i32
+  %external = load i32, i32* @explicit_word, align 4
+  store i32 %value, i32* @explicit_word, align 4
+  %hub = load i32, i32* @hub_word, align 4
+  %sum = add i32 %external, %hub
+  ret i32 %sum
+}
+
+define i8 @constant_gep_access(i8 %value) {
+; EXPLICIT-LABEL: define i8 @constant_gep_access(
+; EXPLICIT: %slot = getelementptr inbounds [8 x i8], [8 x i8]* @explicit_bytes, i32 0, i32 3
+; EXPLICIT: call i8 @__p2_xmem_load8(i8* %slot)
+; EXPLICIT: call void @__p2_xmem_store8(i8* %slot, i8 %value)
+  %slot = getelementptr inbounds [8 x i8], [8 x i8]* @explicit_bytes,
+                                  i32 0, i32 3
+  %old = load i8, i8* %slot, align 1
+  store i8 %value, i8* %slot, align 1
+  ret i8 %old
+}
+
+define i32* @external_address_is_stable() {
+; EXPLICIT-LABEL: define i32* @external_address_is_stable(
+; EXPLICIT: ret i32* @explicit_word
+  ret i32* @explicit_word
+}
+
+define i32 @automatic_and_resident_access() {
+; AUTO-LABEL: define i32 @automatic_and_resident_access(
+; AUTO: %auto.raw = call i32 @__p2_xmem_load32(i8* bitcast (i32* @hub_word to i8*))
+; AUTO: %decl.raw = call i32 @__p2_xmem_load32(i8* bitcast (i32* @external_word to i8*))
+; AUTO: %resident = load i32, i32* @resident_word
+; AUTO-NOT: @resident_word to i8*
+; AUTO: ret i32
+  %auto = load i32, i32* @hub_word, align 4
+  %decl = load i32, i32* @external_word, align 4
+  %resident = load i32, i32* @resident_word, align 4
+  %sum0 = add i32 %auto, %decl
+  %sum1 = add i32 %sum0, %resident
+  ret i32 %sum1
+}
+
+define i32 @constant_only_access() {
+; CONSTANT-LABEL: define i32 @constant_only_access(
+; CONSTANT: %const.raw = call i8 @__p2_xmem_load8(i8* getelementptr inbounds ([4 x i8], [4 x i8]* @auto_const, i32 0, i32 1))
+; CONSTANT: %decl.raw = call i32 @__p2_xmem_load32(i8* bitcast (i32* @external_const to i8*))
+; CONSTANT: %mutable = load i32, i32* @hub_word
+; CONSTANT: %mutable_decl = load i32, i32* @external_word
+; CONSTANT-NOT: @hub_word to i8*
+; CONSTANT-NOT: @external_word to i8*
+; CONSTANT: ret i32
+  %const = load i8, i8* getelementptr inbounds ([4 x i8],
+                                               [4 x i8]* @auto_const,
+                                               i32 0, i32 1), align 1
+  %extended = zext i8 %const to i32
+  %decl = load i32, i32* @external_const, align 4
+  %mutable = load i32, i32* @hub_word, align 4
+  %mutable_decl = load i32, i32* @external_word, align 4
+  %sum0 = add i32 %extended, %decl
+  %sum1 = add i32 %sum0, %mutable
+  %sum2 = add i32 %sum1, %mutable_decl
+  ret i32 %sum2
+}
diff --git a/llvm/test/CodeGen/P2/hub-overlay-errors.ll b/llvm/test/CodeGen/P2/hub-overlay-errors.ll
