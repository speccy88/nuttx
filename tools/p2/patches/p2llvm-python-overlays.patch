diff --git a/clang/lib/Sema/SemaDeclAttr.cpp b/clang/lib/Sema/SemaDeclAttr.cpp
index b7faf2a0393b9f5de8491a23e391f999ee0c8a35..cf2835ada6e554f67350bd86200e42846201f1c3 100644
--- a/clang/lib/Sema/SemaDeclAttr.cpp
+++ b/clang/lib/Sema/SemaDeclAttr.cpp
@@ -7828,6 +7828,32 @@ static void handleCogcacheAttr(Sema &S, Decl *D, const ParsedAttr &AL) {
    handleSimpleAttribute<CogcacheAttr>(S, D, AL);
 }
 
+static void handleP2HubOverlayAttr(Sema &S, Decl *D, const ParsedAttr &AL) {
+  if (!isFunctionOrMethod(D)) {
+    S.Diag(D->getLocation(), diag::warn_attribute_wrong_decl_type)
+        << "'p2_hub_overlay'" << ExpectedFunctionOrMethod;
+    return;
+  }
+  uint32_t Group = 0;
+  if (!checkUInt32Argument(S, AL, AL.getArgAsExpr(0), Group, 0, true))
+    return;
+  if (Group == 0) {
+    S.Diag(AL.getLoc(), diag::err_attribute_requires_positive_integer)
+        << &AL << /*positive*/ 0;
+    return;
+  }
+  D->addAttr(::new (S.Context) P2HubOverlayAttr(S.Context, AL, Group));
+}
+
+static void handleP2HubResidentAttr(Sema &S, Decl *D, const ParsedAttr &AL) {
+  if (!isFunctionOrMethod(D)) {
+    S.Diag(D->getLocation(), diag::warn_attribute_wrong_decl_type)
+        << "'p2_hub_resident'" << ExpectedFunctionOrMethod;
+    return;
+  }
+  handleSimpleAttribute<P2HubResidentAttr>(S, D, AL);
+}
