+double p2_test_adddf3(double left, double right);
+double p2_test_muldf3(double left, double right);
+
+static uint64_t random_state = UINT64_C(0x4d595df4d0f33173);
+
+static uint64_t next_random(void) {
+  uint64_t value = random_state;
+  value ^= value >> 12;
+  value ^= value << 25;
+  value ^= value >> 27;
+  random_state = value;
+  return value * UINT64_C(0x2545f4914f6cdd1d);
+}
+
+static double double_from_bits(uint64_t bits) {
+  double value;
+  memcpy(&value, &bits, sizeof(value));
+  return value;
+}
+
+static uint64_t double_to_bits(double value) {
+  uint64_t bits;
+  memcpy(&bits, &value, sizeof(bits));
+  return bits;
+}
+
+static uint32_t float_to_bits(float value) {
+  uint32_t bits;
+  memcpy(&bits, &value, sizeof(bits));
+  return bits;
+}
+
+static uint32_t expected_trunc_nan(uint64_t input) {
+  const uint32_t sign = (uint32_t)(input >> 32) & UINT32_C(0x80000000);
+  const uint64_t payload = input & UINT64_C(0x0007ffffffffffff);
+  return sign | UINT32_C(0x7fc00000) |
+         (uint32_t)((payload >> 29) & UINT64_C(0x003fffff));
+}
+
+static int check_trunc(uint64_t input) {
+  volatile double source = double_from_bits(input);
+  const uint64_t absolute = input & UINT64_C(0x7fffffffffffffff);
+  const uint32_t got = float_to_bits(p2_test_truncdfsf2(source));
+  uint32_t expected;
+
+  if (absolute > UINT64_C(0x7ff0000000000000))
+    expected = expected_trunc_nan(input);
+  else
+    expected = float_to_bits((float)source);
+
+  if (got == expected)
+    return 0;
+
+  fprintf(stderr,
+          "__truncdfsf2(0x%016" PRIx64 ") = 0x%08" PRIx32
+          ", expected 0x%08" PRIx32 "\n",
+          input, got, expected);
+  return 1;
+}
+
+static int check_fix(uint64_t input) {
+  volatile double source = double_from_bits(input);
+  int64_t expected;
+  int64_t got;
+
+  if (!isfinite(source) || source < -0x1p63 || source >= 0x1p63)
+    return 0;
+
+  expected = (int64_t)source;
+  got = p2_test_fixdfdi(source);
+  if (got == expected)
+    return 0;
+
+  fprintf(stderr,
+          "__fixdfdi(0x%016" PRIx64 ") = 0x%016" PRIx64
+          ", expected 0x%016" PRIx64 "\n",
+          input, (uint64_t)got, (uint64_t)expected);
+  return 1;
+}
+
+static int check_float(int64_t input) {
+  volatile int64_t source = input;
+  const uint64_t got = double_to_bits(p2_test_floatdidf(source));
+  const uint64_t expected = double_to_bits((double)source);
+
+  if (got == expected)
+    return 0;
+
+  fprintf(stderr,
+          "__floatdidf(0x%016" PRIx64 ") = 0x%016" PRIx64
+          ", expected 0x%016" PRIx64 "\n",
+          (uint64_t)input, got, expected);
+  return 1;
+}
+
+static int check_unsigned_float(uint32_t input) {
+  volatile uint32_t source = input;
+  const uint64_t got = double_to_bits(p2_test_floatunsidf(source));
+  const uint64_t expected = double_to_bits((double)source);
+
+  if (got == expected)
+    return 0;
+
+  fprintf(stderr,
+          "__floatunsidf(0x%08" PRIx32 ") = 0x%016" PRIx64
+          ", expected 0x%016" PRIx64 "\n",
+          input, got, expected);
+  return 1;
+}
+
+static int check_binary(const char *name, double (*operation)(double, double),
+                        uint64_t left_bits, uint64_t right_bits,
+                        int multiply) {
+  volatile double left = double_from_bits(left_bits);
+  volatile double right = double_from_bits(right_bits);
+  volatile double expected = multiply ? left * right : left + right;
+  const uint64_t got = double_to_bits(operation(left, right));
+  const uint64_t expected_bits = double_to_bits(expected);
+
+  if (got == expected_bits)
+    return 0;
+
+  fprintf(stderr,
+          "%s(0x%016" PRIx64 ", 0x%016" PRIx64 ") = 0x%016" PRIx64
+          ", expected 0x%016" PRIx64 "\n",
+          name, left_bits, right_bits, got, expected_bits);
+  return 1;
+}
+
+static int check_binary_exact(const char *name,
+                              double (*operation)(double, double),
+                              uint64_t left_bits, uint64_t right_bits,
+                              uint64_t expected) {
+  volatile double left = double_from_bits(left_bits);
+  volatile double right = double_from_bits(right_bits);
+  const uint64_t got = double_to_bits(operation(left, right));
+
+  if (got == expected)
+    return 0;
+
+  fprintf(stderr,
+          "%s(0x%016" PRIx64 ", 0x%016" PRIx64 ") = 0x%016" PRIx64
+          ", expected 0x%016" PRIx64 "\n",
+          name, left_bits, right_bits, got, expected);
+  return 1;
+}
+
+int main(void) {
+  static const uint64_t trunc_edges[] = {
+      UINT64_C(0x0000000000000000), UINT64_C(0x8000000000000000),
+      UINT64_C(0x0000000000000001), UINT64_C(0x8000000000000001),
+      UINT64_C(0x36a0000000000000), UINT64_C(0x36b0000000000000),
+      UINT64_C(0x36b8000000000000), UINT64_C(0x380fffffc8000000),
+      UINT64_C(0x380fffffe8000000), UINT64_C(0x380ffffff0000000),
+      UINT64_C(0x3810000000000000), UINT64_C(0x3ff0000010000000),
+      UINT64_C(0x3ff0000018000000), UINT64_C(0x47efffffe0000000),
+      UINT64_C(0x47effffff0000000), UINT64_C(0x47f0000000000000),
+      UINT64_C(0x7ff0000000000000), UINT64_C(0xfff0000000000000),
+      UINT64_C(0x7ff0000000000001), UINT64_C(0x7ff8000000000000),
+      UINT64_C(0xfff753b1887bcf03), UINT64_C(0xfff911d3c0abfdda),
+  };
+  static const uint64_t fix_edges[] = {
+      UINT64_C(0x0000000000000000), UINT64_C(0x8000000000000000),
+      UINT64_C(0x3fefffffffffffff), UINT64_C(0xbfefffffffffffff),
+      UINT64_C(0x3ff0000000000000), UINT64_C(0xbff0000000000000),
+      UINT64_C(0x400fffffffffffff), UINT64_C(0xc00fffffffffffff),
+      UINT64_C(0x41efffffffe00000), UINT64_C(0xc1f0000000040000),
+      UINT64_C(0x43dfffffffffffff), UINT64_C(0xc3e0000000000000),
+  };
+  static const int64_t float_edges[] = {
+      INT64_C(0),
+      INT64_C(1),
+      -INT64_C(1),
+      INT64_C(0x001fffffffffffff),
+      INT64_C(0x0020000000000000),
+      INT64_C(0x0020000000000001),
+      INT64_C(0x0020000000000002),
+      INT64_C(0x023479fd0e092da1),
+      INT64_C(0x023479fd0e092db0),
+      INT64_C(0x023479fd0e092dd1),
+      INT64_MAX,
+      INT64_MIN,
+      INT64_MIN + INT64_C(1),
+  };
+  static const uint32_t unsigned_float_edges[] = {
+      UINT32_C(0),          UINT32_C(1),          UINT32_C(2),
+      UINT32_C(0x007fffff), UINT32_C(0x00800000), UINT32_C(0x00ffffff),
+      UINT32_C(0x01000000), UINT32_C(0x7fffffff), UINT32_C(0x80000000),
+      UINT32_MAX,
+  };
+  static const uint64_t finite_double_edges[] = {
+      UINT64_C(0x0000000000000001), UINT64_C(0x000fffffffffffff),
+      UINT64_C(0x0010000000000000), UINT64_C(0x3ca0000000000000),
+      UINT64_C(0x3ff0000000000000), UINT64_C(0x4000000000000000),
+      UINT64_C(0x7fefffffffffffff), UINT64_C(0x8000000000000001),
+      UINT64_C(0x800fffffffffffff), UINT64_C(0xbff0000000000000),
+      UINT64_C(0xffefffffffffffff),
+  };
+  static const struct {
+    uint64_t left;
+    uint64_t right;
+    uint64_t expected;
+  } add_zero_edges[] = {
+      {UINT64_C(0x0000000000000000), UINT64_C(0x0000000000000000),
+       UINT64_C(0x0000000000000000)},
+      {UINT64_C(0x8000000000000000), UINT64_C(0x0000000000000000),
+       UINT64_C(0x0000000000000000)},
+      {UINT64_C(0x0000000000000000), UINT64_C(0x8000000000000000),
+       UINT64_C(0x0000000000000000)},
+      {UINT64_C(0x8000000000000000), UINT64_C(0x8000000000000000),
+       UINT64_C(0x8000000000000000)},
+      {UINT64_C(0x0000000000000000), UINT64_C(0x3e112e0be826d695),
+       UINT64_C(0x3e112e0be826d695)},
+      {UINT64_C(0xbe112e0be826d695), UINT64_C(0x8000000000000000),
+       UINT64_C(0xbe112e0be826d695)},
+      {UINT64_C(0x0000000000000000), UINT64_C(0x7ff0000000000001),
+       UINT64_C(0x7ff8000000000001)},
+      {UINT64_C(0xfff0000000000123), UINT64_C(0x8000000000000000),
+       UINT64_C(0xfff8000000000123)},
+  };
+  static const struct {
+    uint64_t left;
+    uint64_t right;
+    uint64_t expected;
+  } multiply_zero_edges[] = {
+      {UINT64_C(0x0000000000000000), UINT64_C(0x3e112e0be826d695),
+       UINT64_C(0x0000000000000000)},
+      {UINT64_C(0x8000000000000000), UINT64_C(0x3e112e0be826d695),
+       UINT64_C(0x8000000000000000)},
+      {UINT64_C(0x8000000000000000), UINT64_C(0xbe112e0be826d695),
+       UINT64_C(0x0000000000000000)},
+      {UINT64_C(0x0000000000000000), UINT64_C(0xbe112e0be826d695),
+       UINT64_C(0x8000000000000000)},
+      {UINT64_C(0x8000000000000000), UINT64_C(0x0000000000000000),
+       UINT64_C(0x8000000000000000)},
+      {UINT64_C(0x0000000000000000), UINT64_C(0x7ff0000000000000),
+       UINT64_C(0x7ff8000000000000)},
+      {UINT64_C(0xfff0000000000000), UINT64_C(0x8000000000000000),
+       UINT64_C(0x7ff8000000000000)},
+      {UINT64_C(0x0000000000000000), UINT64_C(0x7ff0000000000001),
+       UINT64_C(0x7ff8000000000001)},
+      {UINT64_C(0xfff0000000000123), UINT64_C(0x8000000000000000),
+       UINT64_C(0xfff8000000000123)},
+  };
+  unsigned int index;
+  unsigned int failures = 0;
+
+  if (sizeof(double) * CHAR_BIT != 64 || sizeof(float) * CHAR_BIT != 32 ||
+      DBL_MANT_DIG != 53) {
+    fprintf(stderr, "host does not use IEEE binary32/binary64\n");
+    return 77;
+  }
+
+  for (index = 0; index < sizeof(trunc_edges) / sizeof(trunc_edges[0]); index++)
+    failures += check_trunc(trunc_edges[index]);
+  for (index = 0; index < sizeof(fix_edges) / sizeof(fix_edges[0]); index++)
+    failures += check_fix(fix_edges[index]);
+  for (index = 0; index < sizeof(float_edges) / sizeof(float_edges[0]); index++)
+    failures += check_float(float_edges[index]);
+  for (index = 0;
+       index < sizeof(unsigned_float_edges) / sizeof(unsigned_float_edges[0]);
+       index++)
+    failures += check_unsigned_float(unsigned_float_edges[index]);
+  for (index = 0; index < sizeof(add_zero_edges) / sizeof(add_zero_edges[0]);
+       index++)
+    failures += check_binary_exact("__adddf3", p2_test_adddf3,
+                                   add_zero_edges[index].left,
+                                   add_zero_edges[index].right,
+                                   add_zero_edges[index].expected);
+  for (index = 0;
+       index < sizeof(multiply_zero_edges) / sizeof(multiply_zero_edges[0]);
+       index++)
+    failures += check_binary_exact("__muldf3", p2_test_muldf3,
+                                   multiply_zero_edges[index].left,
+                                   multiply_zero_edges[index].right,
+                                   multiply_zero_edges[index].expected);
+  for (index = 0;
+       index < sizeof(finite_double_edges) / sizeof(finite_double_edges[0]);
+       index++) {
+    const uint64_t left = finite_double_edges[index];
+    const uint64_t right = finite_double_edges
+        [(index * 7U + 3U) %
+         (sizeof(finite_double_edges) / sizeof(finite_double_edges[0]))];
+    failures += check_binary("__adddf3", p2_test_adddf3, left, right, 0);
+    failures += check_binary("__muldf3", p2_test_muldf3, left, right, 1);
+  }
+
+  for (index = 0; index < 250000; index++) {
+    const uint64_t bits = next_random();
+    const uint64_t left = next_random();
+    const uint64_t right = next_random();
+    failures += check_trunc(bits);
+    failures += check_fix(bits);
+    failures += check_float((int64_t)next_random());
+    failures += check_unsigned_float((uint32_t)next_random());
+    if ((left & UINT64_C(0x7ff0000000000000)) !=
+            UINT64_C(0x7ff0000000000000) &&
+        (right & UINT64_C(0x7ff0000000000000)) !=
+            UINT64_C(0x7ff0000000000000)) {
+      failures += check_binary("__adddf3", p2_test_adddf3, left, right, 0);
+      failures += check_binary("__muldf3", p2_test_muldf3, left, right, 1);
+    }
+    if (failures != 0)
+      return 1;
+  }
+
+  puts("PASS: runtime builtin edge and randomized vectors");
+  return failures != 0;
+}
