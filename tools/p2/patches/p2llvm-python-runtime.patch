diff --git a/libp2/lib/builtins/tests/runtime_builtins_test.c b/libp2/lib/builtins/tests/runtime_builtins_test.c
new file mode 100644
index 0000000..a3fd657
--- /dev/null
+++ b/libp2/lib/builtins/tests/runtime_builtins_test.c
@@ -0,0 +1,177 @@
+//===-- runtime_builtins_test.c - P2 runtime builtin tests ----------------===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+
+#include <float.h>
+#include <inttypes.h>
+#include <limits.h>
+#include <math.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <string.h>
+
+float p2_test_truncdfsf2(double value);
+int64_t p2_test_fixdfdi(double value);
+double p2_test_floatdidf(int64_t value);
+
+static uint64_t random_state = UINT64_C(0x4d595df4d0f33173);
+
+static uint64_t next_random(void) {
+  uint64_t value = random_state;
+  value ^= value >> 12;
+  value ^= value << 25;
+  value ^= value >> 27;
+  random_state = value;
+  return value * UINT64_C(0x2545f4914f6cdd1d);
+}
+
+static double double_from_bits(uint64_t bits) {
+  double value;
+  memcpy(&value, &bits, sizeof(value));
+  return value;
+}
+
+static uint64_t double_to_bits(double value) {
+  uint64_t bits;
+  memcpy(&bits, &value, sizeof(bits));
+  return bits;
+}
+
+static uint32_t float_to_bits(float value) {
+  uint32_t bits;
+  memcpy(&bits, &value, sizeof(bits));
+  return bits;
+}
+
+static uint32_t expected_trunc_nan(uint64_t input) {
+  const uint32_t sign = (uint32_t)(input >> 32) & UINT32_C(0x80000000);
+  const uint64_t payload = input & UINT64_C(0x0007ffffffffffff);
+  return sign | UINT32_C(0x7fc00000) |
+         (uint32_t)((payload >> 29) & UINT64_C(0x003fffff));
+}
+
+static int check_trunc(uint64_t input) {
+  volatile double source = double_from_bits(input);
+  const uint64_t absolute = input & UINT64_C(0x7fffffffffffffff);
+  const uint32_t got = float_to_bits(p2_test_truncdfsf2(source));
+  uint32_t expected;
+
+  if (absolute > UINT64_C(0x7ff0000000000000))
+    expected = expected_trunc_nan(input);
+  else
+    expected = float_to_bits((float)source);
+
+  if (got == expected)
+    return 0;
+
+  fprintf(stderr,
+          "__truncdfsf2(0x%016" PRIx64 ") = 0x%08" PRIx32
+          ", expected 0x%08" PRIx32 "\n",
+          input, got, expected);
+  return 1;
+}
+
+static int check_fix(uint64_t input) {
+  volatile double source = double_from_bits(input);
+  int64_t expected;
+  int64_t got;
+
+  if (!isfinite(source) || source < -0x1p63 || source >= 0x1p63)
+    return 0;
+
+  expected = (int64_t)source;
+  got = p2_test_fixdfdi(source);
+  if (got == expected)
+    return 0;
+
+  fprintf(stderr,
+          "__fixdfdi(0x%016" PRIx64 ") = 0x%016" PRIx64
+          ", expected 0x%016" PRIx64 "\n",
+          input, (uint64_t)got, (uint64_t)expected);
+  return 1;
+}
+
+static int check_float(int64_t input) {
+  volatile int64_t source = input;
+  const uint64_t got = double_to_bits(p2_test_floatdidf(source));
+  const uint64_t expected = double_to_bits((double)source);
+
+  if (got == expected)
+    return 0;
+
+  fprintf(stderr,
+          "__floatdidf(0x%016" PRIx64 ") = 0x%016" PRIx64
+          ", expected 0x%016" PRIx64 "\n",
+          (uint64_t)input, got, expected);
+  return 1;
+}
+
+int main(void) {
+  static const uint64_t trunc_edges[] = {
+      UINT64_C(0x0000000000000000), UINT64_C(0x8000000000000000),
+      UINT64_C(0x0000000000000001), UINT64_C(0x8000000000000001),
+      UINT64_C(0x36a0000000000000), UINT64_C(0x36b0000000000000),
+      UINT64_C(0x36b8000000000000), UINT64_C(0x380fffffc8000000),
+      UINT64_C(0x380fffffe8000000), UINT64_C(0x380ffffff0000000),
+      UINT64_C(0x3810000000000000), UINT64_C(0x3ff0000010000000),
+      UINT64_C(0x3ff0000018000000), UINT64_C(0x47efffffe0000000),
+      UINT64_C(0x47effffff0000000), UINT64_C(0x47f0000000000000),
+      UINT64_C(0x7ff0000000000000), UINT64_C(0xfff0000000000000),
+      UINT64_C(0x7ff0000000000001), UINT64_C(0x7ff8000000000000),
+      UINT64_C(0xfff753b1887bcf03), UINT64_C(0xfff911d3c0abfdda),
+  };
+  static const uint64_t fix_edges[] = {
+      UINT64_C(0x0000000000000000), UINT64_C(0x8000000000000000),
+      UINT64_C(0x3fefffffffffffff), UINT64_C(0xbfefffffffffffff),
+      UINT64_C(0x3ff0000000000000), UINT64_C(0xbff0000000000000),
+      UINT64_C(0x400fffffffffffff), UINT64_C(0xc00fffffffffffff),
+      UINT64_C(0x41efffffffe00000), UINT64_C(0xc1f0000000040000),
+      UINT64_C(0x43dfffffffffffff), UINT64_C(0xc3e0000000000000),
+  };
+  static const int64_t float_edges[] = {
+      INT64_C(0),
+      INT64_C(1),
+      -INT64_C(1),
+      INT64_C(0x001fffffffffffff),
+      INT64_C(0x0020000000000000),
+      INT64_C(0x0020000000000001),
+      INT64_C(0x0020000000000002),
+      INT64_C(0x023479fd0e092da1),
+      INT64_C(0x023479fd0e092db0),
+      INT64_C(0x023479fd0e092dd1),
+      INT64_MAX,
+      INT64_MIN,
+      INT64_MIN + INT64_C(1),
+  };
+  unsigned int index;
+  unsigned int failures = 0;
+
+  if (sizeof(double) * CHAR_BIT != 64 || sizeof(float) * CHAR_BIT != 32 ||
+      DBL_MANT_DIG != 53) {
+    fprintf(stderr, "host does not use IEEE binary32/binary64\n");
+    return 77;
+  }
+
+  for (index = 0; index < sizeof(trunc_edges) / sizeof(trunc_edges[0]); index++)
+    failures += check_trunc(trunc_edges[index]);
+  for (index = 0; index < sizeof(fix_edges) / sizeof(fix_edges[0]); index++)
+    failures += check_fix(fix_edges[index]);
+  for (index = 0; index < sizeof(float_edges) / sizeof(float_edges[0]); index++)
+    failures += check_float(float_edges[index]);
+
+  for (index = 0; index < 250000; index++) {
+    const uint64_t bits = next_random();
+    failures += check_trunc(bits);
+    failures += check_fix(bits);
+    failures += check_float((int64_t)next_random());
+    if (failures != 0)
+      return 1;
+  }
+
+  puts("PASS: runtime builtin edge and randomized vectors");
+  return failures != 0;
+}
diff --git a/libp2/lib/builtins/tests/test_runtime_builtins.py b/libp2/lib/builtins/tests/test_runtime_builtins.py
new file mode 100644
index 0000000..023790d
--- /dev/null
+++ b/libp2/lib/builtins/tests/test_runtime_builtins.py
@@ -0,0 +1,260 @@
+#!/usr/bin/env python3
+
+# Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+# See https://llvm.org/LICENSE.txt for license information.
+# SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+
+"""Focused host and P2 checks for the standalone compiler builtins archive."""
+
+import importlib.util
+import io
+import os
+import pathlib
+import shutil
+import stat
+import subprocess
+import sys
+import tempfile
+import unittest
+from contextlib import redirect_stderr
+from unittest import mock
+
+BUILTINS = pathlib.Path(__file__).resolve().parents[1]
+ROOT = BUILTINS.parents[2]
+HARNESS = pathlib.Path(__file__).with_name("runtime_builtins_test.c")
+
+
+def load_build_module():
+    specification = importlib.util.spec_from_file_location(
+        "p2llvm_build", ROOT / "build.py"
+    )
+    module = importlib.util.module_from_spec(specification)
+    specification.loader.exec_module(module)
+    return module
+
+
+class RuntimeBuiltinsTest(unittest.TestCase):
+    @classmethod
+    def setUpClass(cls):
+        cls.host_cc = shutil.which(os.environ.get("CC", "clang"))
+
+    def compile_host_test(self, directory, sanitize=False):
+        common = [
+            self.host_cc,
+            "-std=c11",
+            "-O2",
+            "-Wall",
+            "-Wextra",
+            "-Werror",
+            "-I" + str(BUILTINS),
+        ]
+        if sanitize:
+            common.extend(["-fsanitize=undefined", "-fno-sanitize-recover=undefined"])
+
+        objects = []
+        sources = (
+            ("truncdfsf2.c", "__truncdfsf2", "p2_test_truncdfsf2"),
+            ("fixdfdi.c", "__fixdfdi", "p2_test_fixdfdi"),
+            ("floatdidf.c", "__floatdidf", "p2_test_floatdidf"),
+        )
+        for source, original, replacement in sources:
+            output = pathlib.Path(directory) / (source + ".o")
+            subprocess.run(
+                common
+                + [
+                    "-D{}={}".format(original, replacement),
+                    "-c",
+                    str(BUILTINS / source),
+                    "-o",
+                    str(output),
+                ],
+                check=True,
+                capture_output=True,
+                text=True,
+            )
+            objects.append(output)
+
+        executable = pathlib.Path(directory) / "runtime-builtins-test"
+        subprocess.run(
+            common
+            + [str(HARNESS)]
+            + [str(path) for path in objects]
+            + ["-o", str(executable)],
+            check=True,
+            capture_output=True,
+            text=True,
+        )
+        return executable
+
+    @unittest.skipUnless(
+        shutil.which(os.environ.get("CC", "clang")), "no host C compiler"
+    )
+    def test_host_edge_and_randomized_vectors(self):
+        with tempfile.TemporaryDirectory() as directory:
+            executable = self.compile_host_test(directory)
+            result = subprocess.run(
+                [str(executable)], check=True, capture_output=True, text=True
+            )
+        self.assertIn("PASS: runtime builtin", result.stdout)
+
+    @unittest.skipUnless(
+        shutil.which(os.environ.get("CC", "clang")), "no host C compiler"
+    )
+    def test_host_undefined_behavior_sanitizer(self):
+        with tempfile.TemporaryDirectory() as directory:
+            executable = self.compile_host_test(directory, sanitize=True)
+            result = subprocess.run(
+                [str(executable)],
+                check=True,
+                capture_output=True,
+                text=True,
+                env={**os.environ, "UBSAN_OPTIONS": "halt_on_error=1"},
+            )
