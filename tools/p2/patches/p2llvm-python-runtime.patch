+#!/usr/bin/env python3
+
+# Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+# See https://llvm.org/LICENSE.txt for license information.
+# SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+
+"""Focused host and P2 checks for the standalone compiler builtins archive."""
+
+import importlib.util
+import io
+import os
+import pathlib
+import shutil
+import stat
+import subprocess
+import sys
+import tempfile
+import unittest
+from contextlib import redirect_stderr
+from unittest import mock
+
+BUILTINS = pathlib.Path(__file__).resolve().parents[1]
+ROOT = BUILTINS.parents[2]
+P2_INCLUDE = BUILTINS.parents[1] / "include"
+HARNESS = pathlib.Path(__file__).with_name("runtime_builtins_test.c")
+
+
+def load_build_module():
+    specification = importlib.util.spec_from_file_location(
+        "p2llvm_build", ROOT / "build.py"
+    )
+    module = importlib.util.module_from_spec(specification)
+    specification.loader.exec_module(module)
+    return module
+
+
+class RuntimeBuiltinsTest(unittest.TestCase):
+    @classmethod
+    def setUpClass(cls):
+        cls.host_cc = shutil.which(os.environ.get("CC", "clang"))
+
+    def compile_host_test(self, directory, sanitize=False):
+        common = [
+            self.host_cc,
+            "-std=c11",
+            "-O2",
+            "-Wall",
+            "-Wextra",
+            "-Werror",
+            "-I" + str(BUILTINS),
+        ]
+        if sanitize:
+            common.extend(["-fsanitize=undefined", "-fno-sanitize-recover=undefined"])
+
+        objects = []
+        sources = (
+            ("truncdfsf2.c", "__truncdfsf2", "p2_test_truncdfsf2"),
+            ("fixdfdi.c", "__fixdfdi", "p2_test_fixdfdi"),
+            ("floatdidf.c", "__floatdidf", "p2_test_floatdidf"),
+            ("floatunsidf.c", "__floatunsidf", "p2_test_floatunsidf"),
+            ("adddf3.c", "__adddf3", "p2_test_adddf3"),
+            ("muldf3.c", "__muldf3", "p2_test_muldf3"),
+        )
+        for source, original, replacement in sources:
+            output = pathlib.Path(directory) / (source + ".o")
+            subprocess.run(
+                common
+                + [
+                    "-D{}={}".format(original, replacement),
+                    "-c",
+                    str(BUILTINS / source),
+                    "-o",
+                    str(output),
+                ],
+                check=True,
+                capture_output=True,
+                text=True,
+            )
+            objects.append(output)
+
+        fp_mode = pathlib.Path(directory) / "fp_mode.c.o"
+        subprocess.run(
+            common
+            + ["-c", str(BUILTINS / "fp_mode.c"), "-o", str(fp_mode)],
+            check=True,
+            capture_output=True,
+            text=True,
+        )
+        objects.append(fp_mode)
+
+        executable = pathlib.Path(directory) / "runtime-builtins-test"
+        subprocess.run(
+            common
+            + [str(HARNESS)]
+            + [str(path) for path in objects]
+            + ["-o", str(executable)],
+            check=True,
+            capture_output=True,
+            text=True,
+        )
+        return executable
+
+    @unittest.skipUnless(
+        shutil.which(os.environ.get("CC", "clang")), "no host C compiler"
+    )
+    def test_host_edge_and_randomized_vectors(self):
+        with tempfile.TemporaryDirectory() as directory:
+            executable = self.compile_host_test(directory)
+            result = subprocess.run(
+                [str(executable)], check=True, capture_output=True, text=True
+            )
+        self.assertIn("PASS: runtime builtin", result.stdout)
+
+    @unittest.skipUnless(
+        shutil.which(os.environ.get("CC", "clang")), "no host C compiler"
+    )
+    def test_host_undefined_behavior_sanitizer(self):
+        with tempfile.TemporaryDirectory() as directory:
+            executable = self.compile_host_test(directory, sanitize=True)
+            result = subprocess.run(
+                [str(executable)],
+                check=True,
+                capture_output=True,
+                text=True,
+                env={**os.environ, "UBSAN_OPTIONS": "halt_on_error=1"},
+            )
+        self.assertEqual(result.stderr, "")
+
+    def test_atomic_archive_install_and_failure_propagation(self):
+        build = load_build_module()
+        with tempfile.TemporaryDirectory() as directory:
+            root = pathlib.Path(directory)
+            source = root / "source.a"
+            destination = root / "install" / "libcompiler_builtins.a"
+            payload = b"!<arch>\nP2 deterministic archive fixture\n"
+            source.write_bytes(payload)
+
+            self.assertTrue(build.install_regular_file(str(source), str(destination)))
+            self.assertEqual(destination.read_bytes(), payload)
+            self.assertEqual(stat.S_IMODE(destination.stat().st_mode), 0o644)
+
+            destination.write_bytes(b"stale")
+            destination.chmod(0o600)
+            self.assertTrue(build.install_regular_file(str(source), str(destination)))
+            self.assertEqual(destination.read_bytes(), payload)
+            self.assertEqual(stat.S_IMODE(destination.stat().st_mode), 0o644)
+
+            errors = io.StringIO()
+            with redirect_stderr(errors):
+                self.assertFalse(
+                    build.install_regular_file(
+                        str(root / "missing.a"), str(destination)
+                    )
+                )
+            self.assertIn("required build artifact is missing", errors.getvalue())
+
+        arguments = ["build.py", "--skip_llvm", "--skip_libc"]
+        with mock.patch.object(sys, "argv", arguments), mock.patch.object(
+            build, "build_libp2", return_value=False
+        ) as libp2, mock.patch.object(build, "build_libp2pp") as libp2pp:
+            self.assertEqual(build.main(), 1)
+            libp2.assert_called_once()
+            libp2pp.assert_not_called()
+
+    def test_p2_objects_and_archive_export_all_helpers(self):
+        p2llvm_root = os.environ.get("P2LLVM_ROOT")
+        if not p2llvm_root:
+            self.skipTest("set P2LLVM_ROOT for P2 object validation")
+
+        tools = {
+            name: pathlib.Path(p2llvm_root) / "bin" / name
+            for name in (
+                "clang",
+                "ld.lld",
+                "llvm-ar",
+                "llvm-nm",
+                "llvm-objdump",
+                "llvm-readelf",
+            )
+        }
+        if not all(path.is_file() for path in tools.values()):
+            self.skipTest(
+                "P2LLVM_ROOT lacks a required P2 compiler or ELF inspection tool"
+            )
+
+        with tempfile.TemporaryDirectory() as directory:
+            objects = []
+            objects_by_source = {}
+            runtime_sources = (
+                "truncdfsf2.c",
+                "fixdfdi.c",
+                "floatdidf.c",
+                "floatunsidf.c",
+                "adddf3.c",
+                "muldf3.c",
+                "fp_mode.c",
+                "ashldi3.c",
+                "ashrdi3.c",
+                "lshrdi3.c",
+                "muldi3.c",
+            )
+            explicit_placement_sources = (
+                "memcpy.c",
+                "memmove.c",
+                "memset.c",
+                "udivmoddi4.c",
+            )
+            for source in runtime_sources + explicit_placement_sources:
+                output = pathlib.Path(directory) / (source + ".o")
+                subprocess.run(
+                    [
+                        str(tools["clang"]),
+                        "--target=p2",
+                        "-Oz",
+                        "-ffunction-sections",
+                        "-fdata-sections",
+                        "-fno-exceptions",
+                        "-I" + str(BUILTINS),
+                        "-I" + str(P2_INCLUDE),
+                        "-c",
+                        str(BUILTINS / source),
+                        "-o",
+                        str(output),
+                    ],
+                    check=True,
+                    capture_output=True,
+                    text=True,
+                )
+                objects.append(output)
+                objects_by_source[source] = output
+
+                section_headers = subprocess.run(
+                    [str(tools["llvm-readelf"]), "-S", str(output)],
+                    check=True,
+                    capture_output=True,
+                    text=True,
+                ).stdout
+                self.assertNotRegex(
+                    section_headers,
+                    r"(?m)^\s*\[\s*\d+\]\s+(?:lut|\.p2\.lut)\s",
+                    source + " still emits executable code into the LUT image",
+                )
+
+            expected_undefined = {
+                "floatdidf.c": set(),
+                "floatunsidf.c": set(),
+            }
+            for source, expected in expected_undefined.items():
+                undefined = subprocess.run(
+                    [str(tools["llvm-nm"]), "-u", str(objects_by_source[source])],
+                    check=True,
+                    capture_output=True,
+                    text=True,
+                ).stdout
+                self.assertEqual(
+                    {line.split()[-1] for line in undefined.splitlines() if line},
+                    expected,
+                    source + " has an unexpected runtime dependency",
+                )
+
+            floatdidf_disassembly = subprocess.run(
+                [
+                    str(tools["llvm-objdump"]),
+                    "-d",
+                    "--no-show-raw-insn",
+                    "--disassemble-symbols=__floatdidf",
+                    str(objects_by_source["floatdidf.c"]),
+                ],
+                check=True,
+                capture_output=True,
+                text=True,
+            ).stdout
+            self.assertIn(
+                "Disassembly of section .text.__floatdidf",
+                floatdidf_disassembly,
+            )
+            self.assertNotIn(
+                "calla ",
+                floatdidf_disassembly,
+                "__floatdidf must not nest another runtime call",
+            )
+
+            for symbol, source, wrapper in (
+                ("__addXf3__", "adddf3.c", "__adddf3"),
+                ("__mulXf3__", "muldf3.c", "__muldf3"),
+            ):
+                defined = subprocess.run(
+                    [
+                        str(tools["llvm-nm"]),
+                        "--print-size",
+                        "--defined-only",
+                        str(objects_by_source[source]),
+                    ],
+                    check=True,
+                    capture_output=True,
+                    text=True,
+                ).stdout
+                self.assertRegex(
+                    defined,
+                    r"(?m)^\S+ \S+ T " + wrapper + r"$",
+                    wrapper + " must remain a public Hub-text helper",
+                )
+                disassembly = subprocess.run(
+                    [
+                        str(tools["llvm-objdump"]),
+                        "-d",
+                        "--no-show-raw-insn",
+                        "--disassemble-symbols=" + symbol,
+                        str(objects_by_source[source]),
+                    ],
+                    check=True,
+                    capture_output=True,
+                    text=True,
+                ).stdout
+                first_zero_branch = min(
+                    offset
+                    for offset in (disassembly.find("tjz"), disassembly.find("tjnz"))
+                    if offset >= 0
+                )
+                first_call = disassembly.find("calla")
+                self.assertGreater(
+                    first_call,
+                    first_zero_branch,
+                    symbol + " must classify zero before calling a 64-bit helper",
+                )
+
+            archive = pathlib.Path(directory) / "libcompiler_builtins.a"
+            subprocess.run(
+                [str(tools["llvm-ar"]), "rcsD", str(archive)]
+                + [str(path) for path in objects],
+                check=True,
+                capture_output=True,
+                text=True,
+            )
+            symbols = subprocess.run(
+                [str(tools["llvm-nm"]), "--defined-only", str(archive)],
+                check=True,
+                capture_output=True,
+                text=True,
+            ).stdout
+
+            probe_source = pathlib.Path(directory) / "conversion-probe.c"
+            probe_source.write_text(
+                "float narrow(double value) { return value; }\n"
+                "long long fix(double value) { return value; }\n"
+                "double widen(long long value) { return value; }\n"
+                "double widen_unsigned(unsigned value) { return value; }\n"
+                "double add(double left, double right) { return left + right; }\n"
+                "double multiply(double left, double right) { return left * right; }\n"
+            )
+            probe = pathlib.Path(directory) / "conversion-probe.o"
+            subprocess.run(
+                [
+                    str(tools["clang"]),
+                    "--target=p2",
+                    "-Oz",
+                    "-ffreestanding",
+                    "-fno-builtin",
+                    "-c",
+                    str(probe_source),
+                    "-o",
+                    str(probe),
+                ],
+                check=True,
+                capture_output=True,
+                text=True,
+            )
+            before_link = subprocess.run(
+                [str(tools["llvm-nm"]), "-u", str(probe)],
+                check=True,
+                capture_output=True,
+                text=True,
+            ).stdout
+
+            linked = pathlib.Path(directory) / "conversion-linked.o"
+            subprocess.run(
+                [
+                    str(tools["ld.lld"]),
+                    "-r",
+                    str(probe),
+                    str(archive),
+                    "-o",
+                    str(linked),
+                ],
+                check=True,
+                capture_output=True,
+                text=True,
+            )
+            after_link = subprocess.run(
+                [str(tools["llvm-nm"]), "-u", str(linked)],
+                check=True,
+                capture_output=True,
+                text=True,
+            ).stdout
+
+            layout_script = pathlib.Path(directory) / "hub-layout.ld"
+            layout_script.write_text(
+                "SECTIONS\n"
+                "{\n"
+                "  .p2.lut 0x200 : { *(lut) *(.p2.lut) }\n"
+                "  .text 0xa00 : { *(.text .text.*) }\n"
+                "  .rodata : { *(.rodata .rodata.*) }\n"
+                "  .data : { *(.data .data.*) }\n"
+                "  .bss : { *(.bss .bss.* COMMON) }\n"
+                "}\n",
+                encoding="utf-8",
+            )
+            image = pathlib.Path(directory) / "hub-layout.elf"
+            subprocess.run(
+                [
+                    str(tools["ld.lld"]),
+                    "-T",
+                    str(layout_script),
+                    "--entry=widen",
+                    str(probe),
+                    str(archive),
+                    "-o",
+                    str(image),
+                ],
+                check=True,
+                capture_output=True,
+                text=True,
+            )
+            image_sections = subprocess.run(
+                [str(tools["llvm-readelf"]), "-S", str(image)],
+                check=True,
+                capture_output=True,
+                text=True,
+            ).stdout
+            self.assertNotRegex(
+                image_sections,
+                r"(?m)^\s*\[\s*\d+\]\s+\.p2\.lut\s",
+                "runtime helpers unexpectedly populated the low-Hub LUT image",
+            )
+            self.assertRegex(
+                image_sections,
+                r"(?m)^\s*\[\s*\d+\]\s+\.text\s+\S+\s+00000a00\s",
+                "ordinary Hub text must begin at byte address 0x0a00",
+            )
+            image_symbols = subprocess.run(
+                [str(tools["llvm-nm"]), "--defined-only", str(image)],
+                check=True,
+                capture_output=True,
+                text=True,
+            ).stdout
+            symbol_addresses = {
+                fields[-1]: int(fields[0], 16)
+                for line in image_symbols.splitlines()
+                if len(fields := line.split()) >= 3
+            }
+            for symbol in (
+                "__truncdfsf2",
+                "__fixdfdi",
+                "__floatdidf",
+                "__floatunsidf",
+                "__adddf3",
+                "__muldf3",
+                "__ashldi3",
+                "__ashrdi3",
+                "__lshrdi3",
+                "__muldi3",
+            ):
+                self.assertGreaterEqual(
+                    symbol_addresses[symbol],
+                    0x0A00,
+                    symbol + " linked below the legal ordinary Hub-text window",
+                )
+
+        for symbol in (
+            "__truncdfsf2",
+            "__fixdfdi",
+            "__floatdidf",
+            "__floatunsidf",
+            "__adddf3",
+            "__muldf3",
+        ):
+            self.assertRegex(symbols, r"(?m)^\S+ T " + symbol + r"$")
+            self.assertIn(symbol, before_link)
+            self.assertNotIn(symbol, after_link)
+
+
+if __name__ == "__main__":
+    unittest.main()
