diff --git a/libp2/lib/builtins/floatdidf.c b/libp2/lib/builtins/floatdidf.c
index dcef670..6231ffc 100644
--- a/libp2/lib/builtins/floatdidf.c
+++ b/libp2/lib/builtins/floatdidf.c
@@ -24,9 +24,9 @@ COMPILER_RT_ABI double __floatdidf(di_int a) {
   if (a == 0)
     return 0.0;
   const unsigned N = sizeof(di_int) * CHAR_BIT;
-  const di_int s = a >> (N - 1);
-  a = (a ^ s) - s;
-  int sd = N - __builtin_clzll(a); // number of significant digits
+  const du_int s = (du_int)(a >> (N - 1));
+  du_int magnitude = ((du_int)a ^ s) - s;
+  int sd = N - __builtin_clzll(magnitude); // number of significant digits
   int e = sd - 1;                  // exponent
   if (sd > DBL_MANT_DIG) {
     //  start:  0000000000000000000001xxxxxxxxxxxxxxxxxxxxxxPQxxxxxxxxxxxxxxxxxx
@@ -38,32 +38,34 @@ COMPILER_RT_ABI double __floatdidf(di_int a) {
     //  R = "or" of all bits to the right of Q
     switch (sd) {
     case DBL_MANT_DIG + 1:
-      a <<= 1;
+      magnitude <<= 1;
       break;
     case DBL_MANT_DIG + 2:
       break;
     default:
-      a = ((du_int)a >> (sd - (DBL_MANT_DIG + 2))) |
-          ((a & ((du_int)(-1) >> ((N + DBL_MANT_DIG + 2) - sd))) != 0);
+      magnitude =
+          (magnitude >> (sd - (DBL_MANT_DIG + 2))) |
+          ((magnitude &
+            ((du_int)(-1) >> ((N + DBL_MANT_DIG + 2) - sd))) != 0);
     };
     // finish:
-    a |= (a & 4) != 0; // Or P into R
-    ++a;               // round - this step may add a significant bit
-    a >>= 2;           // dump Q and R
-    // a is now rounded to DBL_MANT_DIG or DBL_MANT_DIG+1 bits
-    if (a & ((du_int)1 << DBL_MANT_DIG)) {
-      a >>= 1;
+    magnitude |= (magnitude & 4) != 0; // Or P into R
+    ++magnitude;                       // round; may add a significant bit
+    magnitude >>= 2;                   // dump Q and R
+    // magnitude is now rounded to DBL_MANT_DIG or DBL_MANT_DIG+1 bits
+    if (magnitude & ((du_int)1 << DBL_MANT_DIG)) {
+      magnitude >>= 1;
       ++e;
     }
-    // a is now rounded to DBL_MANT_DIG bits
+    // magnitude is now rounded to DBL_MANT_DIG bits
   } else {
-    a <<= (DBL_MANT_DIG - sd);
-    // a is now rounded to DBL_MANT_DIG bits
+    magnitude <<= (DBL_MANT_DIG - sd);
+    // magnitude is now rounded to DBL_MANT_DIG bits
   }
   double_bits fb;
   fb.u.s.high = ((su_int)s & 0x80000000) |        // sign
                 ((su_int)(e + 1023) << 20) |      // exponent
-                ((su_int)(a >> 32) & 0x000FFFFF); // mantissa-high
-  fb.u.s.low = (su_int)a;                         // mantissa-low
+                ((su_int)(magnitude >> 32) & 0x000FFFFF); // mantissa-high
+  fb.u.s.low = (su_int)magnitude;                 // mantissa-low
   return fb.f;
-}
\ No newline at end of file
+}
