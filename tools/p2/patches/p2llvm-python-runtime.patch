diff --git a/libp2/lib/builtins/fp_mul_impl.inc b/libp2/lib/builtins/fp_mul_impl.inc
index 8cc8ed02e487dce4d89c7dfdac21f546a178910c..0f10102ad3e2c09936b396fc9f018f2d3b6c1dc4 100644
--- a/libp2/lib/builtins/fp_mul_impl.inc
+++ b/libp2/lib/builtins/fp_mul_impl.inc
@@ -12,2 +12,2 @@
-// Modified for P2LLVM by N. Ermoshkin
-// Only change is to disable inlining for wrapper functions to live in lut
+// Modified for P2LLVM to keep wrapper functions in LUT and to make the
+// binary64 zero path independent of nested 64-bit runtime calls.
@@ -19,0 +20,40 @@ static __attribute__ ((noinline))  fp_t __mulXf3__(fp_t a, fp_t b) {
+#if defined(DOUBLE_PRECISION)
+  volatile double_bits aBits;
+  volatile double_bits bBits;
+  aBits.f = a;
+  bBits.f = b;
+  const su_int aAbsHigh = aBits.u.s.high & UINT32_C(0x7fffffff);
+  const su_int bAbsHigh = bBits.u.s.high & UINT32_C(0x7fffffff);
+  const bool aZero = (aAbsHigh | aBits.u.s.low) == 0;
+  const bool bZero = (bAbsHigh | bBits.u.s.low) == 0;
+
+  /*
+   * Extracting a binary64 exponent normally emits __lshrdi3 on P2.  Handle
+   * zero using volatile 32-bit words before any nested compiler-rt call.
+   */
+  if (aZero || bZero) {
+    const su_int otherLow = aZero ? bBits.u.s.low : aBits.u.s.low;
+    const su_int otherHigh = aZero ? bBits.u.s.high : aBits.u.s.high;
+    const su_int otherAbsHigh = otherHigh & UINT32_C(0x7fffffff);
+    volatile double_bits result;
+
+    if ((otherAbsHigh & UINT32_C(0x7ff00000)) ==
+        UINT32_C(0x7ff00000)) {
+      /* Preserve and quiet a NaN; infinity times zero is a canonical qNaN. */
+      if (otherAbsHigh != UINT32_C(0x7ff00000) || otherLow != 0) {
+        result.u.s.low = otherLow;
+        result.u.s.high = otherHigh | UINT32_C(0x00080000);
+        return result.f;
+      }
+      result.u.s.low = 0;
+      result.u.s.high = UINT32_C(0x7ff80000);
+      return result.f;
+    }
+
+    result.u.s.low = 0;
+    result.u.s.high =
+        (aBits.u.s.high ^ bBits.u.s.high) & UINT32_C(0x80000000);
+    return result.f;
+  }
+#endif
+
