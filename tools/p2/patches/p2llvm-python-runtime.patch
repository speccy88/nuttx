diff --git a/build.py b/build.py
index 07567d4..a8361e3 100644
--- a/build.py
+++ b/build.py
@@ -1,6 +1,9 @@
 import argparse
 import os
+import shutil
 import subprocess
+import sys
+import tempfile
 
 DEBUG_BUILD_DIR = "llvm-project/build_debug"
 RELEASE_BUILD_DIR = "llvm-project/build_release"
@@ -24,6 +27,41 @@ def copy(src, dst, cwd=None, recurse=False):
 
     return True
 
+def install_regular_file(src, dst):
+    """Atomically install one non-empty regular file with a stable mode."""
+
+    if not os.path.isfile(src) or os.path.getsize(src) == 0:
+        print("ERROR: required build artifact is missing or empty: " + src,
+              file=sys.stderr)
+        return False
+
+    destination = os.path.abspath(dst)
+    destination_dir = os.path.dirname(destination)
+    os.makedirs(destination_dir, exist_ok=True)
+    descriptor, temporary = tempfile.mkstemp(
+        prefix="." + os.path.basename(destination) + ".",
+        dir=destination_dir)
+
+    try:
+        with open(src, 'rb') as source, os.fdopen(descriptor, 'wb') as output:
+            shutil.copyfileobj(source, output)
+        os.chmod(temporary, 0o644)
+        os.replace(temporary, destination)
+    except OSError as error:
+        print("ERROR: could not install {}: {}".format(destination, error),
+              file=sys.stderr)
+        try:
+            os.close(descriptor)
+        except OSError:
+            pass
+        try:
+            os.unlink(temporary)
+        except OSError:
+            pass
+        return False
+
+    return True
+
 def build_llvm(configure=True, debug=False, install_dest=None):
     '''
     if install_dest is None, then don't run install
@@ -120,6 +158,16 @@ def build_libp2(install_dest, llvm, clean=False, configure=True):
     if not copy(os.path.join(build_dir, 'lib', 'libp2.a'), os.path.join(install_dir, 'lib', 'libp2.a')):
         return False
 
+    # NuttX links with ld.lld directly, so keep the compiler ABI runtime in a
+    # standalone archive as well as embedding it in libp2.a.  Consumers which
+    # already supply their own C runtime can then use the soft-float/integer
+    # helpers without accidentally importing libp2 startup or libc shims.
+    if not install_regular_file(
+            os.path.join(build_dir, 'lib', 'builtins',
+                         'libcompiler_builtins.a'),
+            os.path.join(install_dir, 'lib', 'libcompiler_builtins.a')):
+        return False
+
     if not copy(os.path.join(build_dir, 'lib', 'p2db', 'libp2db.a'), os.path.join(install_dir, 'lib', 'libp2db.a')):
         return False
 
@@ -240,19 +288,20 @@ def main():
     # build LLVM
     if not skip_llvm:
         if not build_llvm(configure, debug, install_dest):
-            return
+            return 1
 
     # build libp2
     if not skip_libp2:
         if (install_dest):
-            r = build_libp2(install_dest, llvm, clean, configure)
-            r = build_libp2pp(install_dest, llvm, clean, configure)
+            if not build_libp2(install_dest, llvm, clean, configure):
+                return 1
+            if not build_libp2pp(install_dest, llvm, clean, configure):
+                return 1
         else:
-            r = build_libp2(build_dir, llvm, clean, configure)
-            r = build_libp2pp(build_dir, llvm, clean, configure)
-
-        if not r:
-            return
+            if not build_libp2(build_dir, llvm, clean, configure):
+                return 1
+            if not build_libp2pp(build_dir, llvm, clean, configure):
+                return 1
 
     # build libc
     if not skip_libc:
@@ -262,8 +311,10 @@ def main():
             r = build_libc(build_dir, llvm, clean, configure)
 
         if not r:
-            return
+            return 1
+
+    return 0
 
 
 if __name__ == "__main__":
-    main();
+    raise SystemExit(main())
