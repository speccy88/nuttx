diff --git a/libp2/lib/builtins/fp_add_impl.inc b/libp2/lib/builtins/fp_add_impl.inc
index eda093348ef2804335fe88b52582c8435b518405..7471414942b52476f5aa3f80206f0d183431e77d 100644
--- a/libp2/lib/builtins/fp_add_impl.inc
+++ b/libp2/lib/builtins/fp_add_impl.inc
@@ -12,2 +12,2 @@
-// Modified for P2LLVM by N. Ermoshkin
-// Only change is to disable inlining for wrapper functions to live in lut
+// Modified for P2LLVM to keep wrapper functions in LUT and to make the
+// binary64 zero path independent of nested 64-bit runtime calls.
@@ -20,0 +21,39 @@ static __attribute__ ((noinline)) fp_t __addXf3__(fp_t a, fp_t b) {
+#if defined(DOUBLE_PRECISION)
+  volatile double_bits aBits;
+  volatile double_bits bBits;
+  aBits.f = a;
+  bBits.f = b;
+  const su_int aAbsHigh = aBits.u.s.high & UINT32_C(0x7fffffff);
+  const su_int bAbsHigh = bBits.u.s.high & UINT32_C(0x7fffffff);
+  const bool aZero = (aAbsHigh | aBits.u.s.low) == 0;
+  const bool bZero = (bAbsHigh | bBits.u.s.low) == 0;
+
+  /* Handle additive identities before P2 needs a 64-bit alignment shift. */
+  if (aZero) {
+    if (bZero) {
+      volatile double_bits result;
+      result.u.s.low = 0;
+      result.u.s.high = aBits.u.s.high & bBits.u.s.high;
+      return result.f;
+    }
+    {
+      volatile double_bits result;
+      result.u.s.low = bBits.u.s.low;
+      result.u.s.high = bBits.u.s.high;
+      if ((bAbsHigh > UINT32_C(0x7ff00000)) ||
+          (bAbsHigh == UINT32_C(0x7ff00000) && result.u.s.low != 0))
+        result.u.s.high |= UINT32_C(0x00080000);
+      return result.f;
+    }
+  }
+  if (bZero) {
+    volatile double_bits result;
+    result.u.s.low = aBits.u.s.low;
+    result.u.s.high = aBits.u.s.high;
+    if ((aAbsHigh > UINT32_C(0x7ff00000)) ||
+        (aAbsHigh == UINT32_C(0x7ff00000) && result.u.s.low != 0))
+      result.u.s.high |= UINT32_C(0x00080000);
+    return result.f;
+  }
+#endif
+
