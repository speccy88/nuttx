+
+static SDValue p2BuildMULHU32(SDValue Left, SDValue Right, const SDLoc &DL,
+                              SelectionDAG &DAG) {
+    SDValue Mask = DAG.getConstant(0xffff, DL, MVT::i32);
+    SDValue Shift = DAG.getConstant(16, DL, MVT::i32);
+    SDValue LeftLow = DAG.getNode(ISD::AND, DL, MVT::i32, Left, Mask);
+    SDValue LeftHigh = DAG.getNode(ISD::SRL, DL, MVT::i32, Left, Shift);
+    SDValue RightLow = DAG.getNode(ISD::AND, DL, MVT::i32, Right, Mask);
+    SDValue RightHigh = DAG.getNode(ISD::SRL, DL, MVT::i32, Right, Shift);
+    SDValue Product0 = DAG.getNode(ISD::MUL, DL, MVT::i32,
+                                   LeftLow, RightLow);
+    SDValue Product1 = DAG.getNode(ISD::MUL, DL, MVT::i32,
+                                   LeftHigh, RightLow);
+    SDValue Product2 = DAG.getNode(ISD::MUL, DL, MVT::i32,
+                                   LeftLow, RightHigh);
+    SDValue Product3 = DAG.getNode(ISD::MUL, DL, MVT::i32,
+                                   LeftHigh, RightHigh);
+
+    // All four products are exact in 32 bits.  The middle accumulator is at
+    // most 3 * 0xffff, so these additions cannot overflow.
+    SDValue Middle = DAG.getNode(ISD::SRL, DL, MVT::i32, Product0, Shift);
+    Middle = DAG.getNode(ISD::ADD, DL, MVT::i32, Middle,
+                         DAG.getNode(ISD::AND, DL, MVT::i32,
+                                     Product1, Mask));
+    Middle = DAG.getNode(ISD::ADD, DL, MVT::i32, Middle,
+                         DAG.getNode(ISD::AND, DL, MVT::i32,
+                                     Product2, Mask));
+
+    SDValue High = DAG.getNode(ISD::ADD, DL, MVT::i32, Product3,
+                               DAG.getNode(ISD::SRL, DL, MVT::i32,
+                                           Product1, Shift));
+    High = DAG.getNode(ISD::ADD, DL, MVT::i32, High,
+                       DAG.getNode(ISD::SRL, DL, MVT::i32,
+                                   Product2, Shift));
+    return DAG.getNode(ISD::ADD, DL, MVT::i32, High,
+                       DAG.getNode(ISD::SRL, DL, MVT::i32, Middle, Shift));
+}
+
+static std::pair<SDValue, SDValue>
+p2BuildAddCarry32(SDValue Left, SDValue Right, const SDLoc &DL,
+                  SelectionDAG &DAG) {
+    SDValue Sum = DAG.getNode(ISD::ADD, DL, MVT::i32, Left, Right);
+    SDValue Both = DAG.getNode(ISD::AND, DL, MVT::i32, Left, Right);
+    SDValue Either = DAG.getNode(ISD::OR, DL, MVT::i32, Left, Right);
+    SDValue NotSum = DAG.getNode(ISD::XOR, DL, MVT::i32, Sum,
+                                 DAG.getAllOnesConstant(DL, MVT::i32));
+    SDValue CarryBits = DAG.getNode(ISD::OR, DL, MVT::i32, Both,
+                                    DAG.getNode(ISD::AND, DL, MVT::i32,
+                                                Either, NotSum));
+    SDValue Carry = DAG.getNode(ISD::SRL, DL, MVT::i32, CarryBits,
+                                DAG.getConstant(31, DL, MVT::i32));
+    return std::make_pair(Sum, Carry);
+}
+
+static SDValue p2BuildI64(SDValue Low, SDValue High, const SDLoc &DL,
+                          SelectionDAG &DAG) {
+    SDValue Result = SDValue(
+        DAG.getMachineNode(TargetOpcode::IMPLICIT_DEF, DL, MVT::i64), 0);
+    Result = DAG.getTargetInsertSubreg(P2::sub0, DL, MVT::i64, Result, Low);
+    return DAG.getTargetInsertSubreg(P2::sub1, DL, MVT::i64, Result, High);
+}
+
+SDValue P2TargetLowering::lowerMULHU32(SDValue Op,
+                                      SelectionDAG &DAG) const {
+    return p2BuildMULHU32(Op->getOperand(0), Op->getOperand(1), SDLoc(Op), DAG);
+}
+
+SDValue P2TargetLowering::lowerMULHS32(SDValue Op,
+                                      SelectionDAG &DAG) const {
+    SDLoc DL(Op);
+    SDValue Left = Op->getOperand(0);
+    SDValue Right = Op->getOperand(1);
+    SDValue High = p2BuildMULHU32(Left, Right, DL, DAG);
+    SDValue SignShift = DAG.getConstant(31, DL, MVT::i32);
+    SDValue LeftMask = DAG.getNode(ISD::SRA, DL, MVT::i32,
+                                   Left, SignShift);
+    SDValue RightMask = DAG.getNode(ISD::SRA, DL, MVT::i32,
+                                    Right, SignShift);
+
+    // For two's-complement operands, signed_high(a*b) is
+    // unsigned_high(a*b) - (a<0 ? b : 0) - (b<0 ? a : 0).
+    High = DAG.getNode(ISD::SUB, DL, MVT::i32, High,
+                       DAG.getNode(ISD::AND, DL, MVT::i32,
+                                   LeftMask, Right));
+    return DAG.getNode(ISD::SUB, DL, MVT::i32, High,
+                       DAG.getNode(ISD::AND, DL, MVT::i32,
+                                   RightMask, Left));
+}
+
+SDValue P2TargetLowering::lowerMULHU64(SDValue Op,
+                                      SelectionDAG &DAG) const {
+    SDLoc DL(Op);
+    SDValue Left = Op->getOperand(0);
+    SDValue Right = Op->getOperand(1);
+    SDValue LeftLow = DAG.getTargetExtractSubreg(P2::sub0, DL, MVT::i32,
+                                                 Left);
+    SDValue LeftHigh = DAG.getTargetExtractSubreg(P2::sub1, DL, MVT::i32,
+                                                  Left);
+    SDValue RightLow = DAG.getTargetExtractSubreg(P2::sub0, DL, MVT::i32,
+                                                  Right);
+    SDValue RightHigh = DAG.getTargetExtractSubreg(P2::sub1, DL, MVT::i32,
+                                                   Right);
+
+    SDValue P00High = p2BuildMULHU32(LeftLow, RightLow, DL, DAG);
+    SDValue P01Low = DAG.getNode(ISD::MUL, DL, MVT::i32,
+                                 LeftLow, RightHigh);
+    SDValue P01High = p2BuildMULHU32(LeftLow, RightHigh, DL, DAG);
+    SDValue P10Low = DAG.getNode(ISD::MUL, DL, MVT::i32,
+                                 LeftHigh, RightLow);
+    SDValue P10High = p2BuildMULHU32(LeftHigh, RightLow, DL, DAG);
+    SDValue P11Low = DAG.getNode(ISD::MUL, DL, MVT::i32,
+                                 LeftHigh, RightHigh);
+    SDValue P11High = p2BuildMULHU32(LeftHigh, RightHigh, DL, DAG);
+
+    // The carries from the low 64-bit product into limbs 1 and 2 are part of
+    // the upper 64 bits.
+    auto Limb1A = p2BuildAddCarry32(P00High, P01Low, DL, DAG);
+    auto Limb1B = p2BuildAddCarry32(Limb1A.first, P10Low, DL, DAG);
+    SDValue Carry1 = DAG.getNode(ISD::ADD, DL, MVT::i32,
+                                 Limb1A.second, Limb1B.second);
+
+    auto Limb2A = p2BuildAddCarry32(P01High, P10High, DL, DAG);
+    auto Limb2B = p2BuildAddCarry32(Limb2A.first, P11Low, DL, DAG);
+    auto Limb2C = p2BuildAddCarry32(Limb2B.first, Carry1, DL, DAG);
+    SDValue Carry2 = DAG.getNode(ISD::ADD, DL, MVT::i32,
+                                 Limb2A.second, Limb2B.second);
+    Carry2 = DAG.getNode(ISD::ADD, DL, MVT::i32,
+                         Carry2, Limb2C.second);
+    SDValue Limb3 = DAG.getNode(ISD::ADD, DL, MVT::i32, P11High, Carry2);
+    return p2BuildI64(Limb2C.first, Limb3, DL, DAG);
+}
+
+SDValue P2TargetLowering::lowerMULHS64(SDValue Op,
+                                      SelectionDAG &DAG) const {
+    SDLoc DL(Op);
+    SDValue Left = Op->getOperand(0);
+    SDValue Right = Op->getOperand(1);
+    SDValue High = lowerMULHU64(Op, DAG);
+    SDValue LeftHigh = DAG.getTargetExtractSubreg(P2::sub1, DL, MVT::i32,
+                                                  Left);
+    SDValue RightHigh = DAG.getTargetExtractSubreg(P2::sub1, DL, MVT::i32,
+                                                   Right);
+    SDValue SignShift = DAG.getConstant(31, DL, MVT::i32);
+    SDValue LeftMask32 = DAG.getNode(ISD::SRA, DL, MVT::i32,
+                                     LeftHigh, SignShift);
+    SDValue RightMask32 = DAG.getNode(ISD::SRA, DL, MVT::i32,
+                                      RightHigh, SignShift);
+    SDValue LeftMask64 = p2BuildI64(LeftMask32, LeftMask32, DL, DAG);
+    SDValue RightMask64 = p2BuildI64(RightMask32, RightMask32, DL, DAG);
+
+    High = DAG.getNode(ISD::SUB, DL, MVT::i64, High,
+                       DAG.getNode(ISD::AND, DL, MVT::i64,
+                                   LeftMask64, Right));
+    return DAG.getNode(ISD::SUB, DL, MVT::i64, High,
+                       DAG.getNode(ISD::AND, DL, MVT::i64,
+                                   RightMask64, Left));
+}
