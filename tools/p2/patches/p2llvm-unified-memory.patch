+//===-- P2UnifiedMemory.cpp - Route generic memory through xmem helpers ----===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+//
+// P2 Hub RAM is directly addressable, but external memory is reached through
+// board-specific transactions.  With -p2-unified-memory, pointers whose
+// provenance is not provably a Hub alloca, global, or bounded formal byval
+// object are routed through a small runtime ABI.  Only bounded constant
+// inbounds GEPs retain Hub provenance;
+// integer-derived, non-inbounds, and variable-offset pointers are deliberately
+// conservative.  The runtime is responsible for discriminating Hub and
+// external addresses.  Atomic operations are only permitted when provenance
+// proves that the address is native Hub memory; the scalar helper ABI
+// deliberately carries no ordering argument and therefore cannot preserve LLVM
+// atomic semantics.
+//
+// This pass runs from the P2 target's pre-ISel hook, after ordinary IR
+// optimization.  Calls are opaque memory side effects, which preserves
+// volatile accesses and keeps ordered accesses from moving across a helper.
+// P2 unified-memory configurations must not enable a later transformation,
+// such as SafeStack, that introduces arbitrary-pointer memory accesses.
+//
+//===----------------------------------------------------------------------===//
+
+#include "P2.h"
+
+#include "llvm/ADT/APInt.h"
+#include "llvm/ADT/SmallPtrSet.h"
+#include "llvm/ADT/SmallVector.h"
+#include "llvm/IR/Argument.h"
+#include "llvm/IR/Constants.h"
+#include "llvm/IR/DataLayout.h"
+#include "llvm/IR/Function.h"
+#include "llvm/IR/IRBuilder.h"
+#include "llvm/IR/InstIterator.h"
+#include "llvm/IR/Instructions.h"
+#include "llvm/IR/IntrinsicInst.h"
+#include "llvm/IR/Module.h"
+#include "llvm/IR/Operator.h"
+#include "llvm/Pass.h"
+#include "llvm/Support/CommandLine.h"
+#include "llvm/Support/ErrorHandling.h"
+#include "llvm/Support/raw_ostream.h"
+
+#include <cstdint>
+#include <limits>
+#include <string>
+
+using namespace llvm;
+
+#define DEBUG_TYPE "p2-unified-memory-lowering"
+
+static cl::opt<bool> EnableP2UnifiedMemory(
+    "p2-unified-memory", cl::init(false),
+    cl::desc("Route non-Hub P2 memory accesses through unified-memory helpers"));
+
+namespace {
+
+class P2UnifiedMemory final : public FunctionPass {
+public:
+  static char ID;
+
+  P2UnifiedMemory() : FunctionPass(ID) {}
+
+  StringRef getPassName() const override {
+    return "P2 Unified Memory Lowering";
+  }
+
+  bool runOnFunction(Function &F) override;
+
+private:
+  bool isProvablyHubPointer(const Value *Pointer,
+                            const DataLayout &DL) const;
+  bool isProvablyHubPointerImpl(
+      const Value *Pointer, const DataLayout &DL, APInt Offset,
+      SmallPtrSetImpl<const Value *> &Visiting) const;
+  bool isHubObjectAtOffset(const Value *Object, const DataLayout &DL,
+                           const APInt &Offset) const;
+  FunctionCallee getHelper(Module &M, StringRef Name, Type *ReturnTy,
+                           ArrayRef<Type *> ParameterTys) const;
+  Value *castAddress(IRBuilder<> &Builder, Value *Pointer) const;
+  Value *getI32Length(IRBuilder<> &Builder, Value *Length,
+                      const Instruction &At) const;
+  unsigned getScalarHelperWidth(Type *Ty, const DataLayout &DL,
+                                const Instruction &At) const;
+  uint32_t getFixedTransferSize(Type *Ty, const DataLayout &DL,
+                                const Instruction &At) const;
+  bool lowerLoad(LoadInst &Load, const DataLayout &DL) const;
+  bool lowerStore(StoreInst &Store, const DataLayout &DL) const;
+  bool lowerMemIntrinsic(MemIntrinsic &MI, const DataLayout &DL) const;
+  bool lowerLibcMemoryCall(CallBase &Call, const DataLayout &DL) const;
+  bool lowerByValArguments(CallBase &Call, const DataLayout &DL) const;
+  void rejectUnsupportedAtomicMemory(Instruction &I,
+                                     const DataLayout &DL) const;
+  void rejectUnsafeIntrinsic(IntrinsicInst &Intrinsic,
+                             const DataLayout &DL) const;
+  void rejectUnsafeCall(CallBase &Call, const DataLayout &DL) const;
+
+  [[noreturn]] void fail(const Instruction &At, const Twine &Reason) const;
+};
+
+} // end anonymous namespace
+
+char P2UnifiedMemory::ID = 0;
+
+static RegisterPass<P2UnifiedMemory>
+    X("p2-unified-memory-lowering", "P2 Unified Memory Lowering", false,
+      false);
+
+[[noreturn]] void P2UnifiedMemory::fail(const Instruction &At,
+                                        const Twine &Reason) const {
+  std::string Message;
+  raw_string_ostream OS(Message);
+  OS << "P2 unified-memory lowering failed in function '"
+     << At.getFunction()->getName() << "': " << Reason << ": ";
+  At.print(OS);
+  OS.flush();
+  report_fatal_error(StringRef(Message), false);
+}
+
+bool P2UnifiedMemory::isHubObjectAtOffset(const Value *Object,
+                                          const DataLayout &DL,
+                                          const APInt &Offset) const {
+  // GlobalAlias and GlobalIFunc can hide an arbitrary constant-expression
+  // address.  Only actual storage objects are eligible for a native proof.
+  // A formal byval argument is also such an object: the P2 calling convention
+  // copies it into the incoming Hub stack area, and this pass stages an
+  // unproven byval source into Hub before lowering the corresponding call.
+  // Do not extend this rule to ordinary pointer arguments.
+  auto *ByValArgument = dyn_cast<Argument>(Object);
+  if (!isa<AllocaInst>(Object) && !isa<GlobalVariable>(Object) &&
+      (!ByValArgument || !ByValArgument->hasByValAttr()))
+    return false;
+
+  // The object itself is a native Hub address.  A derived address needs an
+  // actual byte-range proof below; in particular, do not treat one-past or a
+  // wrapped offset as Hub merely because its underlying object is Hub.
+  if (Offset.isZero())
+    return true;
+  if (Offset.isNegative())
+    return false;
+
+  uint64_t ObjectSize;
+  if (auto *Alloca = dyn_cast<AllocaInst>(Object)) {
+    Type *AllocatedTy = Alloca->getAllocatedType();
+    auto *ArraySize = dyn_cast<ConstantInt>(Alloca->getArraySize());
+    if (!AllocatedTy->isSized() || !ArraySize ||
+        ArraySize->getValue().getActiveBits() > 64)
+      return false;
+
+    TypeSize ElementSize = DL.getTypeAllocSize(AllocatedTy);
+    if (ElementSize.isScalable())
+      return false;
+    uint64_t Count = ArraySize->getZExtValue();
+    uint64_t ElementBytes = ElementSize.getFixedSize();
+    if (Count != 0 &&
+        ElementBytes > std::numeric_limits<uint64_t>::max() / Count)
+      return false;
+    ObjectSize = ElementBytes * Count;
+  } else if (auto *Global = dyn_cast<GlobalVariable>(Object)) {
+    if (!Global->getValueType()->isSized())
+      return false;
+    TypeSize Size = DL.getTypeAllocSize(Global->getValueType());
+    if (Size.isScalable())
+      return false;
+    ObjectSize = Size.getFixedSize();
+  } else {
+    Type *ByValTy = ByValArgument->getParamByValType();
+    if (!ByValTy || !ByValTy->isSized())
+      return false;
+    TypeSize Size = DL.getTypeAllocSize(ByValTy);
+    if (Size.isScalable())
+      return false;
+    ObjectSize = Size.getFixedSize();
+  }
+
+  APInt Size(Offset.getBitWidth(), ObjectSize);
+  if (Size.getLimitedValue() != ObjectSize)
+    return false;
+  return Offset.ult(Size);
+}
+
+bool P2UnifiedMemory::isProvablyHubPointerImpl(
+    const Value *Pointer, const DataLayout &DL, APInt Offset,
+    SmallPtrSetImpl<const Value *> &Visiting) const {
+  if (!Visiting.insert(Pointer).second)
+    return false;
+
+  bool IsHub = false;
+  if (isa<IntToPtrInst>(Pointer) ||
+      (isa<ConstantExpr>(Pointer) &&
+       cast<ConstantExpr>(Pointer)->getOpcode() == Instruction::IntToPtr)) {
+    // Never reconstruct provenance across integer arithmetic.  In particular,
+    // ptrtoint(@hub) + P2_PSRAM_UNIFIED_BASE must remain a tagged xmem address.
+    IsHub = false;
+  } else if (isa<AllocaInst>(Pointer) || isa<GlobalVariable>(Pointer) ||
+             isa<Argument>(Pointer)) {
+    IsHub = isHubObjectAtOffset(Pointer, DL, Offset);
+  } else if (auto *GEP = dyn_cast<GEPOperator>(Pointer)) {
+    if (GEP->isInBounds()) {
+      APInt GEPOffset(Offset.getBitWidth(), 0);
+      if (GEP->accumulateConstantOffset(DL, GEPOffset)) {
+        Offset += GEPOffset;
+        IsHub = isProvablyHubPointerImpl(GEP->getPointerOperand(), DL,
+                                         Offset, Visiting);
+      }
+    }
+  } else if (auto *Cast = dyn_cast<CastInst>(Pointer)) {
+    if (Cast->getOpcode() == Instruction::BitCast ||
+        Cast->getOpcode() == Instruction::AddrSpaceCast) {
+      auto *SourceTy = cast<PointerType>(Cast->getOperand(0)->getType());
+      if (DL.getIndexSizeInBits(SourceTy->getAddressSpace()) ==
+          Offset.getBitWidth())
+        IsHub = isProvablyHubPointerImpl(Cast->getOperand(0), DL, Offset,
+                                         Visiting);
+    }
+  } else if (auto *Expression = dyn_cast<ConstantExpr>(Pointer)) {
+    if (Expression->getOpcode() == Instruction::BitCast ||
+        Expression->getOpcode() == Instruction::AddrSpaceCast) {
+      auto *SourceTy = cast<PointerType>(Expression->getOperand(0)->getType());
+      if (DL.getIndexSizeInBits(SourceTy->getAddressSpace()) ==
+          Offset.getBitWidth())
+        IsHub = isProvablyHubPointerImpl(Expression->getOperand(0), DL,
+                                         Offset, Visiting);
+    }
+  } else if (auto *Select = dyn_cast<SelectInst>(Pointer)) {
+    IsHub = isProvablyHubPointerImpl(Select->getTrueValue(), DL, Offset,
+                                     Visiting) &&
+            isProvablyHubPointerImpl(Select->getFalseValue(), DL, Offset,
+                                     Visiting);
+  } else if (auto *Phi = dyn_cast<PHINode>(Pointer)) {
+    IsHub = Phi->getNumIncomingValues() != 0;
+    for (const Value *Incoming : Phi->incoming_values()) {
+      if (!isProvablyHubPointerImpl(Incoming, DL, Offset, Visiting)) {
+        IsHub = false;
+        break;
+      }
+    }
+  } else if (auto *Freeze = dyn_cast<FreezeInst>(Pointer)) {
+    IsHub = isProvablyHubPointerImpl(Freeze->getOperand(0), DL, Offset,
+                                     Visiting);
+  }
+
+  Visiting.erase(Pointer);
+  return IsHub;
+}
+
+bool P2UnifiedMemory::isProvablyHubPointer(const Value *Pointer,
+                                           const DataLayout &DL) const {
+  if (!Pointer || !Pointer->getType()->isPointerTy())
+    return false;
+
+  auto *PointerTy = cast<PointerType>(Pointer->getType());
+  unsigned IndexBits = DL.getIndexSizeInBits(PointerTy->getAddressSpace());
+  if (IndexBits == 0)
+    return false;
+
+  SmallPtrSet<const Value *, 16> Visiting;
+  return isProvablyHubPointerImpl(Pointer, DL, APInt(IndexBits, 0),
+                                  Visiting);
+}
+
+FunctionCallee P2UnifiedMemory::getHelper(
+    Module &M, StringRef Name, Type *ReturnTy,
+    ArrayRef<Type *> ParameterTys) const {
+  FunctionType *ExpectedTy =
+      FunctionType::get(ReturnTy, ParameterTys, false);
+  FunctionCallee Helper = M.getOrInsertFunction(Name, ExpectedTy);
+
+  // getOrInsertFunction returns a bitcast if an incompatible declaration
+  // already owns the name.  Such a mismatch is an ABI error, not something
+  // this late pass can safely repair.
+  auto *FunctionValue = dyn_cast<Function>(Helper.getCallee());
+  if (!FunctionValue || FunctionValue->getFunctionType() != ExpectedTy) {
+    std::string Message =
+        (Twine("P2 unified-memory helper '") + Name +
+         "' has an incompatible declaration")
+            .str();
+    report_fatal_error(StringRef(Message), false);
+  }
+
+  return Helper;
+}
+
+Value *P2UnifiedMemory::castAddress(IRBuilder<> &Builder,
+                                    Value *Pointer) const {
+  Type *AddressTy = Builder.getInt8PtrTy();
+  if (Pointer->getType() == AddressTy)
+    return Pointer;
+  return Builder.CreatePointerBitCastOrAddrSpaceCast(Pointer, AddressTy,
+                                                      "xmem.addr");
+}
+
+Value *P2UnifiedMemory::getI32Length(IRBuilder<> &Builder, Value *Length,
+                                     const Instruction &At) const {
+  auto *LengthTy = dyn_cast<IntegerType>(Length->getType());
+  if (!LengthTy)
+    fail(At, "memory operation length is not an integer");
+
+  unsigned BitWidth = LengthTy->getBitWidth();
+  if (BitWidth == 32)
+    return Length;
+  if (BitWidth < 32)
+    return Builder.CreateZExt(Length, Builder.getInt32Ty(), "xmem.length");
+
+  auto *ConstantLength = dyn_cast<ConstantInt>(Length);
+  if (!ConstantLength || ConstantLength->getValue().getActiveBits() > 32)
+    fail(At, "memory operation length cannot be represented by the i32 "
+             "unified-memory ABI");
+  return Builder.CreateTrunc(Length, Builder.getInt32Ty(), "xmem.length");
+}
+
+unsigned P2UnifiedMemory::getScalarHelperWidth(Type *Ty, const DataLayout &DL,
+                                               const Instruction &At) const {
+  if (auto *IntegerTy = dyn_cast<IntegerType>(Ty)) {
+    switch (IntegerTy->getBitWidth()) {
+    case 1:
+    case 8:
+      return 8;
+    case 16:
+      return 16;
+    case 32:
+      return 32;
+    case 64:
+      return 64;
+    default:
+      return 0;
+    }
+  }
+
+  if (Ty->isPointerTy()) {
+    if (DL.isNonIntegralPointerType(Ty) || DL.getPointerTypeSizeInBits(Ty) != 32)
+      fail(At, "unified-memory ABI requires a 32-bit integral pointer type");
+    return 32;
+  }
+
+  if (Ty->isFloatTy())
+    return 32;
+  if (Ty->isDoubleTy())
+    return 64;
+
+  return 0;
+}
+
+uint32_t P2UnifiedMemory::getFixedTransferSize(
+    Type *Ty, const DataLayout &DL, const Instruction &At) const {
+  if (!Ty->isSized())
+    fail(At, "non-Hub load/store type is not sized");
+
+  TypeSize Size = DL.getTypeStoreSize(Ty);
+  if (Size.isScalable() ||
+      Size.getFixedSize() > std::numeric_limits<uint32_t>::max())
+    fail(At, "non-Hub load/store type is scalable or too large for the i32 "
+             "unified-memory ABI");
+  return static_cast<uint32_t>(Size.getFixedSize());
+}
+
+bool P2UnifiedMemory::lowerLoad(LoadInst &Load,
+                                const DataLayout &DL) const {
+  if (isProvablyHubPointer(Load.getPointerOperand(), DL))
+    return false;
+
+  if (Load.isAtomic())
+    fail(Load, "atomic load on non-Hub memory is unsupported");
+
+  Type *ValueTy = Load.getType();
+  unsigned Width = getScalarHelperWidth(ValueTy, DL, Load);
+  if (Width == 0) {
+    uint32_t Size = getFixedTransferSize(ValueTy, DL, Load);
+    Align Alignment = DL.getPrefTypeAlign(ValueTy);
+    Function &F = *Load.getFunction();
+    IRBuilder<> EntryBuilder(&*F.getEntryBlock().getFirstInsertionPt());
+    AllocaInst *HubCopy = EntryBuilder.CreateAlloca(
+        ValueTy, nullptr, Load.getName() + ".xmem.hub");
+    HubCopy->setAlignment(Alignment);
+
+    IRBuilder<> Builder(&Load);
+    Builder.SetCurrentDebugLocation(Load.getDebugLoc());
+    Value *Destination = castAddress(Builder, HubCopy);
+    Value *Source = castAddress(Builder, Load.getPointerOperand());
+    FunctionCallee Copy = getHelper(
+        *Load.getModule(), "__p2_xmem_memcpy", Builder.getVoidTy(),
+        {Builder.getInt8PtrTy(), Builder.getInt8PtrTy(), Builder.getInt32Ty()});
+    Builder.CreateCall(Copy, {Destination, Source, Builder.getInt32(Size)});
+    LoadInst *HubLoad =
+        Builder.CreateLoad(ValueTy, HubCopy, Load.getName() + ".xmem");
+    HubLoad->setAlignment(Alignment);
+
+    Load.replaceAllUsesWith(HubLoad);
+    Load.eraseFromParent();
+    return true;
+  }
+
+  LLVMContext &Context = Load.getContext();
+  Type *RawTy = IntegerType::get(Context, Width);
+  std::string HelperName =
+      (Twine("__p2_xmem_load") + Twine(Width)).str();
+
+  IRBuilder<> Builder(&Load);
+  Builder.SetCurrentDebugLocation(Load.getDebugLoc());
+  Value *Address = castAddress(Builder, Load.getPointerOperand());
+  FunctionCallee Helper =
+      getHelper(*Load.getModule(), HelperName, RawTy, {Builder.getInt8PtrTy()});
+  CallInst *Call = Builder.CreateCall(Helper, {Address}, Load.getName() + ".raw");
+
+  Value *Result = Call;
+  if (ValueTy->isIntegerTy(1))
+    Result = Builder.CreateTrunc(Call, ValueTy, Load.getName() + ".xmem");
+  else if (ValueTy->isPointerTy())
+    Result = Builder.CreateIntToPtr(Call, ValueTy, Load.getName() + ".xmem");
+  else if (ValueTy->isFloatingPointTy())
+    Result = Builder.CreateBitCast(Call, ValueTy, Load.getName() + ".xmem");
+
+  Load.replaceAllUsesWith(Result);
+  Load.eraseFromParent();
+  return true;
+}
+
+bool P2UnifiedMemory::lowerStore(StoreInst &Store,
+                                 const DataLayout &DL) const {
+  if (isProvablyHubPointer(Store.getPointerOperand(), DL))
+    return false;
+
+  if (Store.isAtomic())
+    fail(Store, "atomic store on non-Hub memory is unsupported");
+
+  Value *StoredValue = Store.getValueOperand();
+  Type *ValueTy = StoredValue->getType();
+  unsigned Width = getScalarHelperWidth(ValueTy, DL, Store);
+  if (Width == 0) {
+    uint32_t Size = getFixedTransferSize(ValueTy, DL, Store);
+    Align Alignment = DL.getPrefTypeAlign(ValueTy);
+    Function &F = *Store.getFunction();
+    IRBuilder<> EntryBuilder(&*F.getEntryBlock().getFirstInsertionPt());
+    AllocaInst *HubCopy =
+        EntryBuilder.CreateAlloca(ValueTy, nullptr, "xmem.store.hub");
+    HubCopy->setAlignment(Alignment);
+
+    IRBuilder<> Builder(&Store);
+    Builder.SetCurrentDebugLocation(Store.getDebugLoc());
+    StoreInst *HubStore = Builder.CreateStore(StoredValue, HubCopy);
+    HubStore->setAlignment(Alignment);
+    Value *Destination = castAddress(Builder, Store.getPointerOperand());
+    Value *Source = castAddress(Builder, HubCopy);
+    FunctionCallee Copy = getHelper(
+        *Store.getModule(), "__p2_xmem_memcpy", Builder.getVoidTy(),
+        {Builder.getInt8PtrTy(), Builder.getInt8PtrTy(), Builder.getInt32Ty()});
+    Builder.CreateCall(Copy, {Destination, Source, Builder.getInt32(Size)});
+
+    Store.eraseFromParent();
+    return true;
+  }
+
+  LLVMContext &Context = Store.getContext();
+  Type *RawTy = IntegerType::get(Context, Width);
+  std::string HelperName =
+      (Twine("__p2_xmem_store") + Twine(Width)).str();
+
+  IRBuilder<> Builder(&Store);
+  Builder.SetCurrentDebugLocation(Store.getDebugLoc());
+  Value *Address = castAddress(Builder, Store.getPointerOperand());
+  Value *RawValue = StoredValue;
+  if (ValueTy->isIntegerTy(1))
+    RawValue = Builder.CreateZExt(StoredValue, RawTy, "xmem.value");
+  else if (ValueTy->isPointerTy())
+    RawValue = Builder.CreatePtrToInt(StoredValue, RawTy, "xmem.value");
+  else if (ValueTy->isFloatingPointTy())
+    RawValue = Builder.CreateBitCast(StoredValue, RawTy, "xmem.value");
+
+  FunctionCallee Helper = getHelper(*Store.getModule(), HelperName,
+                                    Builder.getVoidTy(),
+                                    {Builder.getInt8PtrTy(), RawTy});
+  Builder.CreateCall(Helper, {Address, RawValue});
+  Store.eraseFromParent();
+  return true;
+}
+
+bool P2UnifiedMemory::lowerMemIntrinsic(MemIntrinsic &MI,
+                                        const DataLayout &DL) const {
+  Value *Destination = MI.getRawDest();
+  Value *Source = nullptr;
+  StringRef HelperName;
+
+  if (auto *Transfer = dyn_cast<MemTransferInst>(&MI)) {
+    Source = Transfer->getRawSource();
+    if (isProvablyHubPointer(Destination, DL) &&
+        isProvablyHubPointer(Source, DL))
+      return false;
+    HelperName = isa<MemMoveInst>(Transfer) ? "__p2_xmem_memmove"
+                                            : "__p2_xmem_memcpy";
+  } else if (isa<MemSetInst>(&MI)) {
+    if (isProvablyHubPointer(Destination, DL))
+      return false;
+    HelperName = "__p2_xmem_memset";
+  } else {
+    fail(MI, "unsupported memory intrinsic");
+  }
+
+  IRBuilder<> Builder(&MI);
+  Builder.SetCurrentDebugLocation(MI.getDebugLoc());
+  Type *I8PtrTy = Builder.getInt8PtrTy();
+  Value *DestinationAddress = castAddress(Builder, Destination);
+  Value *Length = getI32Length(Builder, MI.getLength(), MI);
+  FunctionCallee Helper;
+
+  if (Source) {
+    Value *SourceAddress = castAddress(Builder, Source);
+    Helper = getHelper(*MI.getModule(), HelperName, Builder.getVoidTy(),
+                       {I8PtrTy, I8PtrTy, Builder.getInt32Ty()});
+    Builder.CreateCall(Helper, {DestinationAddress, SourceAddress, Length});
+  } else {
+    auto &Set = cast<MemSetInst>(MI);
+    Value *SetValue = Set.getValue();
+    if (!SetValue->getType()->isIntegerTy(8))
+      fail(MI, "memset value is not i8");
+    Helper = getHelper(*MI.getModule(), HelperName, Builder.getVoidTy(),
+                       {I8PtrTy, Builder.getInt8Ty(), Builder.getInt32Ty()});
+    Builder.CreateCall(Helper, {DestinationAddress, SetValue, Length});
+  }
+
+  MI.eraseFromParent();
+  return true;
+}
+
+bool P2UnifiedMemory::lowerLibcMemoryCall(CallBase &Call,
+                                          const DataLayout &DL) const {
+  Function *Callee = Call.getCalledFunction();
+  if (!Callee)
+    return false;
+
+  StringRef Name = Callee->getName();
+  bool IsMemset = Name == "memset";
+  if (!IsMemset && Name != "memcpy" && Name != "memmove")
+    return false;
+
+  if (Call.arg_size() != 3 || !Call.getType()->isPointerTy() ||
+      !Call.getArgOperand(0)->getType()->isPointerTy() ||
+      !Call.getArgOperand(2)->getType()->isIntegerTy() ||
+      (IsMemset && !Call.getArgOperand(1)->getType()->isIntegerTy()) ||
+      (!IsMemset && !Call.getArgOperand(1)->getType()->isPointerTy()))
+    fail(Call, Twine("direct libc ") + Name +
+                   " call has an incompatible standard ABI");
+
+  Value *Destination = Call.getArgOperand(0);
+  Value *Source = IsMemset ? nullptr : Call.getArgOperand(1);
+  if (isProvablyHubPointer(Destination, DL) &&
+      (!Source || isProvablyHubPointer(Source, DL)))
+    return false;
+
+  // Replacing a pointer-returning libc call with a void helper plus the
+  // destination value cannot preserve musttail.  Reject before creating any
+  // helper IR rather than silently weakening a semantic guarantee.
+  if (auto *CallInstruction = dyn_cast<CallInst>(&Call))
+    if (CallInstruction->isMustTailCall())
+      fail(Call, Twine("musttail direct libc ") + Name +
+                     " call on non-Hub memory is unsupported");
+
+  // NuttX does not use exceptions, and Clang emits these libc operations as
+  // calls.  Refuse an invoke/callbr rather than silently discarding its unwind
+  // or indirect control-flow edge.
+  if (!isa<CallInst>(Call))
+    fail(Call, Twine("non-Hub direct libc ") + Name +
+                   " invoke/callbr is unsupported");
+  if (Call.hasOperandBundles())
+    fail(Call, Twine("non-Hub direct libc ") + Name +
+                   " call with operand bundles is unsupported");
+
+  IRBuilder<> Builder(&Call);
+  Builder.SetCurrentDebugLocation(Call.getDebugLoc());
+  Type *I8PtrTy = Builder.getInt8PtrTy();
+  Value *DestinationAddress = castAddress(Builder, Destination);
+  Value *Length = getI32Length(Builder, Call.getArgOperand(2), Call);
+  FunctionCallee Helper;
+
+  if (IsMemset) {
+    Value *SetValue = Builder.CreateIntCast(
+        Call.getArgOperand(1), Builder.getInt8Ty(), false, "xmem.set.value");
+    Helper = getHelper(*Call.getModule(), "__p2_xmem_memset",
+                       Builder.getVoidTy(),
+                       {I8PtrTy, Builder.getInt8Ty(), Builder.getInt32Ty()});
+    Builder.CreateCall(Helper, {DestinationAddress, SetValue, Length});
+  } else {
+    Value *SourceAddress = castAddress(Builder, Source);
+    StringRef HelperName =
+        Name == "memmove" ? "__p2_xmem_memmove" : "__p2_xmem_memcpy";
+    Helper = getHelper(*Call.getModule(), HelperName, Builder.getVoidTy(),
+                       {I8PtrTy, I8PtrTy, Builder.getInt32Ty()});
+    Builder.CreateCall(Helper,
+                       {DestinationAddress, SourceAddress, Length});
+  }
+
+  Value *ReturnValue = Destination;
+  if (ReturnValue->getType() != Call.getType())
+    ReturnValue = Builder.CreatePointerBitCastOrAddrSpaceCast(
+        ReturnValue, Call.getType(), "xmem.return");
+  Call.replaceAllUsesWith(ReturnValue);
+  Call.eraseFromParent();
+  return true;
+}
+
+bool P2UnifiedMemory::lowerByValArguments(CallBase &Call,
+                                          const DataLayout &DL) const {
+  bool Changed = false;
+  Function &F = *Call.getFunction();
+
+  for (unsigned ArgumentIndex = 0; ArgumentIndex < Call.arg_size();
+       ++ArgumentIndex) {
+    if (!Call.paramHasAttr(ArgumentIndex, Attribute::ByVal))
+      continue;
+
+    Value *Argument = Call.getArgOperand(ArgumentIndex);
+    if (isProvablyHubPointer(Argument, DL))
+      continue;
+
+    // musttail is a semantic guarantee: inserting a caller-owned Hub copy
+    // makes the tail call impossible and silently clearing the marker would
+    // change valid input IR.  Reject it deliberately before mutating the call.
+    if (auto *CallInstruction = dyn_cast<CallInst>(&Call))
+      if (CallInstruction->isMustTailCall())
+        fail(Call, "musttail call with a non-Hub byval argument is "
+                   "unsupported");
+
+    Type *ByValTy = Call.getParamByValType(ArgumentIndex);
+    if (!ByValTy || !ByValTy->isSized())
+      fail(Call, "non-Hub byval argument has no statically sized pointee type");
+
+    TypeSize Size = DL.getTypeAllocSize(ByValTy);
+    if (Size.isScalable() ||
+        Size.getFixedSize() > std::numeric_limits<uint32_t>::max())
+      fail(Call, "non-Hub byval argument is too large for the i32 "
+                 "unified-memory ABI");
+
+    MaybeAlign ParameterAlignment = Call.getParamAlign(ArgumentIndex);
+    Align Alignment = ParameterAlignment
+                          ? *ParameterAlignment
+                          : DL.getABITypeAlign(ByValTy);
+    IRBuilder<> EntryBuilder(&*F.getEntryBlock().getFirstInsertionPt());
+    AllocaInst *HubCopy = EntryBuilder.CreateAlloca(
+        ByValTy, nullptr, Argument->getName() + ".byval.hub");
+    HubCopy->setAlignment(Alignment);
+
+    IRBuilder<> Builder(&Call);
+    Builder.SetCurrentDebugLocation(Call.getDebugLoc());
+    Value *Destination = castAddress(Builder, HubCopy);
+    Value *Source = castAddress(Builder, Argument);
+    Value *Length = Builder.getInt32(static_cast<uint32_t>(Size.getFixedSize()));
+    FunctionCallee Copy = getHelper(
+        *Call.getModule(), "__p2_xmem_memcpy", Builder.getVoidTy(),
+        {Builder.getInt8PtrTy(), Builder.getInt8PtrTy(), Builder.getInt32Ty()});
+    Builder.CreateCall(Copy, {Destination, Source, Length});
+
+    Value *Replacement = HubCopy;
+    if (Replacement->getType() != Argument->getType())
+      Replacement = Builder.CreatePointerBitCastOrAddrSpaceCast(
+          Replacement, Argument->getType(), "xmem.byval.arg");
+    Call.setArgOperand(ArgumentIndex, Replacement);
+
+    // A tail call cannot retain a pointer into the caller's Hub stack.  The
+    // backend may still choose a sibling call after copying the byval payload
+    // into its own outgoing area, but this IR call is no longer tail-marked.
+    if (auto *CallInstruction = dyn_cast<CallInst>(&Call))
+      CallInstruction->setTailCallKind(CallInst::TCK_None);
+
+    Changed = true;
+  }
+
+  return Changed;
+}
+
+void P2UnifiedMemory::rejectUnsupportedAtomicMemory(
+    Instruction &I, const DataLayout &DL) const {
+  if (auto *RMW = dyn_cast<AtomicRMWInst>(&I)) {
+    if (!isProvablyHubPointer(RMW->getPointerOperand(), DL))
+      fail(I, "atomicrmw on non-Hub memory is unsupported");
+    return;
+  }
+
+  if (auto *CmpXchg = dyn_cast<AtomicCmpXchgInst>(&I)) {
+    if (!isProvablyHubPointer(CmpXchg->getPointerOperand(), DL))
+      fail(I, "cmpxchg on non-Hub memory is unsupported");
+    return;
+  }
+
+  auto *AtomicMemory = dyn_cast<AtomicMemIntrinsic>(&I);
+  if (!AtomicMemory)
+    return;
+
+  bool HasNonHubPointer =
+      !isProvablyHubPointer(AtomicMemory->getRawDest(), DL);
+  if (auto *Transfer = dyn_cast<AtomicMemTransferInst>(AtomicMemory))
+    HasNonHubPointer |=
+        !isProvablyHubPointer(Transfer->getRawSource(), DL);
+  if (HasNonHubPointer)
+    fail(I, "element-unordered-atomic memory intrinsic on non-Hub memory is "
+            "unsupported");
+}
+
+void P2UnifiedMemory::rejectUnsafeIntrinsic(IntrinsicInst &Intrinsic,
+                                            const DataLayout &DL) const {
+  if (!Intrinsic.mayReadOrWriteMemory())
+    return;
+
+  for (Value *Argument : Intrinsic.args()) {
+    Type *ArgumentTy = Argument->getType();
+    if (ArgumentTy->isPointerTy()) {
+      if (!isProvablyHubPointer(Argument, DL))
+        fail(Intrinsic,
+             "unsupported intrinsic may access non-Hub memory");
+      continue;
+    }
+
+    // Masked gather/scatter and VP memory intrinsics use vectors of pointers.
+    // This scalar helper ABI cannot preserve their lane semantics.
+    if (auto *VectorTy = dyn_cast<VectorType>(ArgumentTy)) {
+      if (VectorTy->getElementType()->isPointerTy())
+        fail(Intrinsic,
+             "vector-of-pointers memory intrinsic is unsupported");
+    }
+  }
+}
+
+void P2UnifiedMemory::rejectUnsafeCall(CallBase &Call,
+                                       const DataLayout &DL) const {
+  // Inline assembly is opaque to LLVM.  Reject every unproven pointer operand,
+  // not only '*m' constraints: a nominal register operand can still be
+  // dereferenced by the assembly template.
+  if (Call.isInlineAsm()) {
+    for (Value *Argument : Call.args()) {
+      if (Argument->getType()->isPointerTy() &&
+          !isProvablyHubPointer(Argument, DL))
+        fail(Call, "non-Hub pointer passed to inline assembly is unsupported");
+    }
+    return;
+  }
+
+  Value *CalledValue = Call.getCalledOperand()->stripPointerCasts();
+  auto *Callee = dyn_cast<Function>(CalledValue);
+  if (!Callee ||
+      (!Callee->getName().startswith("__atomic_") &&
+       !Callee->getName().startswith("__sync_")))
+    return;
+
+  // Clang lowers P2 C atomics to libatomic calls because the target reports no
+  // lock-free widths.  Letting such a call receive a tagged address would
+  // bypass this pass in compiler-generated library code, so reject it until a
+  // unified-memory atomic ABI is implemented.
+  for (Value *Argument : Call.args()) {
+    if (Argument->getType()->isPointerTy() &&
+        !isProvablyHubPointer(Argument, DL))
+      fail(Call, "atomic operation libcall (__atomic_/__sync_) on non-Hub "
+                 "memory is unsupported");
+  }
+}
+
+bool P2UnifiedMemory::runOnFunction(Function &F) {
+  if (!EnableP2UnifiedMemory || F.isDeclaration() ||
+      F.getName().startswith("__p2_xmem_"))
+    return false;
+
+  const DataLayout &DL = F.getParent()->getDataLayout();
+  SmallVector<Instruction *, 64> Worklist;
+  for (Instruction &I : instructions(F))
+    Worklist.push_back(&I);
+
+  bool Changed = false;
+  for (Instruction *I : Worklist) {
+    if (auto *Load = dyn_cast<LoadInst>(I)) {
+      Changed |= lowerLoad(*Load, DL);
+      continue;
+    }
+    if (auto *Store = dyn_cast<StoreInst>(I)) {
+      Changed |= lowerStore(*Store, DL);
+      continue;
+    }
+    if (isa<AtomicRMWInst>(I) || isa<AtomicCmpXchgInst>(I) ||
+        isa<AtomicMemIntrinsic>(I)) {
+      rejectUnsupportedAtomicMemory(*I, DL);
+      continue;
+    }
+    if (auto *MI = dyn_cast<MemIntrinsic>(I)) {
+      Changed |= lowerMemIntrinsic(*MI, DL);
+      continue;
+    }
+    if (auto *VAArg = dyn_cast<VAArgInst>(I)) {
+      if (!isProvablyHubPointer(VAArg->getPointerOperand(), DL))
+        fail(*VAArg, "va_arg on a non-Hub va_list is unsupported");
+      continue;
+    }
+    if (auto *Intrinsic = dyn_cast<IntrinsicInst>(I)) {
+      rejectUnsafeIntrinsic(*Intrinsic, DL);
+      continue;
+    }
+    if (auto *Call = dyn_cast<CallBase>(I)) {
+      rejectUnsafeCall(*Call, DL);
+      if (lowerLibcMemoryCall(*Call, DL)) {
+        Changed = true;
+        continue;
+      }
+      Changed |= lowerByValArguments(*Call, DL);
+    }
+  }
+
+  return Changed;
+}
+
+FunctionPass *llvm::createP2UnifiedMemoryPass() {
+  return new P2UnifiedMemory();
+}
