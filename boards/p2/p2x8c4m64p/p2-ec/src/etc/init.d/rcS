#include <nuttx/config.h>

#ifdef CONFIG_P2_EC32MB_FLASHBOOT

if [ -e /dev/smart0 ]
then
  mkdir -p /mnt/flash
  if mount -t smartfs /dev/smart0 /mnt/flash
  then
    echo P2FLASHBOOT:SMARTFS=/dev/smart0@/mnt/flash:MOUNTED:AUTOFORMAT=NO:DESTRUCTIVE_HANDLERS=ABSENT
  else
    echo P2FLASHBOOT:SMARTFS=/dev/smart0@/mnt/flash:FAIL:AUTOFORMAT=NO
  fi
else
  echo P2FLASHBOOT:SMARTFS=UNAVAILABLE:CHECK_FLASH_SWITCH
fi

#endif

#ifdef CONFIG_P2_EC32MB_SDCARD_AUTOMOUNT

if [ -e /dev/mmcsd0 ]
then
  mkdir -p /mnt/sd
  if mount -t vfat /dev/mmcsd0 /mnt/sd
  then
    echo P2STORAGE:SD=/dev/mmcsd0@/mnt/sd:MOUNTED:AUTOFORMAT=NO
  else
    echo P2STORAGE:SD=/dev/mmcsd0@/mnt/sd:FAIL:AUTOFORMAT=NO
  fi
else
  echo P2STORAGE:SD=UNAVAILABLE
fi

#endif

#ifdef CONFIG_SYSTEM_P2HELP
echo P2SHOWCASE:READY:BOARD=p2-ec:RUN=p2help
#endif

#ifdef CONFIG_P2_EDGE_BASE_IMAGE
echo P2BASE:READY:BOARD=p2-ec:APPS=berry,vi
#endif
