CONFIG_ARCH="p2"
CONFIG_ARCH_P2=y
CONFIG_ARCH_CHIP="p2x8c4m64p"
CONFIG_ARCH_CHIP_P2X8C4M64P=y
CONFIG_ARCH_BOARD="p2-ec32mb"
CONFIG_ARCH_BOARD_P2_EC32MB=y
CONFIG_ARCH_TOOLCHAIN_CLANG=y
CONFIG_BOARDCTL=y
CONFIG_BOARD_LATE_INITIALIZE=y
CONFIG_BCH=y
CONFIG_BUILD_FLAT=y
CONFIG_BUILTIN=y
CONFIG_DEBUG_FEATURES=y
CONFIG_DEV_CONSOLE=y
CONFIG_DISABLE_MQUEUE=y
CONFIG_DISABLE_POSIX_TIMERS=y
CONFIG_INIT_ENTRYPOINT="nsh_main"
CONFIG_INTELHEX_BINARY=n
CONFIG_LIBC_ARCH_ATOMIC=y
CONFIG_LIBM_NONE=y
CONFIG_NFILE_DESCRIPTORS=12
CONFIG_NSH_ARCHINIT=n
CONFIG_NSH_BUILTIN_APPS=y
CONFIG_NSH_FILEIOSIZE=65536
CONFIG_NSH_READLINE=y
CONFIG_PREALLOC_TIMERS=2
CONFIG_RAM_SIZE=524288
CONFIG_RAW_BINARY=y
CONFIG_P2_BOOT_TRACE=y
CONFIG_RR_INTERVAL=200
CONFIG_SCHED_HPWORK=n
CONFIG_START_DAY=1
CONFIG_START_MONTH=1
CONFIG_START_YEAR=2026
CONFIG_SYSTEM_NSH=y
CONFIG_UART0_BAUD=230400
CONFIG_UART0_SERIAL_CONSOLE=y

# The 360-MHz core clock and 120-MHz SD clock are out-of-spec HIL record
# settings.  The driver does not activate 120 MHz unless SD CMD6 High Speed
# negotiation succeeds and a repeated CRC16-valid RX phase calibration passes.

CONFIG_P2_EXPERIMENTAL_OVERCLOCK=y
CONFIG_P2_SYSCLK_HZ=360000000
CONFIG_P2_SMARTPIN=y
CONFIG_P2_EC32MB_SDIO_NATIVE=y
CONFIG_P2_EC32MB_SDIO_COMMAND_HZ=5000000
CONFIG_P2_EC32MB_SDIO_DIVISOR=3
CONFIG_P2_EC32MB_SDIO_ALLOW_OVERCLOCK=y
# CONFIG_P2_EC32MB_SDIO_VERIFY_FAST_CRC16 is not set
CONFIG_P2_EC32MB_SDIO_RESPONSE_CLOCKS=64
CONFIG_P2_EC32MB_SDIO_START_CLOCKS=1000000
CONFIG_P2_EC32MB_SDIO_BUSY_TIMEOUT_MS=1000
CONFIG_P2_EC32MB_SDIO_SERVICE_TIMEOUT_MS=1000
CONFIG_P2_EC32MB_SDIO_MAX_TRANSFER=262144

# Keep the onboard W25/SMART binding needed by the p2storage benchmark app.
# MMCSD_SPI remains disabled: native SDIO exclusively owns /dev/mmcsd0 and
# the W25 pins P58-P61 are independent of the external P16-P23 fixture.

CONFIG_P2_STORAGE=y
CONFIG_P2_EC32MB_STORAGE_BINDINGS=y
CONFIG_P2_EC32MB_W25_PROBE_FREQUENCY=400000
CONFIG_P2_STORAGE_LOCK_TIMEOUT_TICKS=500
CONFIG_P2_STORAGE_MAX_FREQUENCY=2000000
CONFIG_MTD=y
CONFIG_MTD_PARTITION=y
CONFIG_MTD_SMART=y
CONFIG_MTD_W25=y
CONFIG_W25_SPIFREQUENCY=2000000
CONFIG_W25_SPIMODE=3

CONFIG_MMCSD=y
CONFIG_MMCSD_SDIO=y
CONFIG_MMCSD_READONLY=y
CONFIG_MMCSD_MULTIBLOCK_LIMIT=512
CONFIG_SDIO_BLOCKSETUP=y
# CONFIG_MMCSD_SPI is not set
# CONFIG_MMCSD_MMCSUPPORT is not set
# CONFIG_MMCSD_HAVE_CARDDETECT is not set
# CONFIG_MMCSD_HAVE_WRITEPROTECT is not set
CONFIG_FS_FAT=y
CONFIG_FS_SMARTFS=y
CONFIG_TESTING_P2STORAGE=y
CONFIG_TESTING_P2STORAGE_SD_BENCHMARK=y
CONFIG_TESTING_P2STORAGE_BENCHMARK_BUFFER_SIZE=65536
# CONFIG_TESTING_P2STORAGE_DESTRUCTIVE is not set
CONFIG_TESTING_P2STORAGE_FLASH_DEVPATH="/dev/smart0"
CONFIG_TESTING_P2STORAGE_FLASH_MOUNTPOINT="/mnt/flash"
CONFIG_TESTING_P2STORAGE_SD_DEVPATH="/dev/mmcsd0"
CONFIG_TESTING_P2STORAGE_SD_MOUNTPOINT="/mnt/sd"
CONFIG_TESTING_P2STORAGE_RECORD_SIZE=256
CONFIG_TESTING_P2STORAGE_STREAM_SIZE=1048576
# CONFIG_SYSTEM_DD is not set
